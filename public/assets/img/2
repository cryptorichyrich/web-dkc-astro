    const lightText = '#000000';  // Added this as it was missing but used in CSS
    const darkText = '#f8f8ff';
    let toggleButton;
  
    // Function to apply dark mode styles
    function applyDarkStyles() {
      styles.textContent = `
        .quiz-container, .question-text, .progress-text{
          color:white;
        }
