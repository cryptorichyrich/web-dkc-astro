              color:#658eb8  !important;
            }
            .translit, .jawaban{
              color: white !important;
            }
              .verse-number{ color: black !important}
    `;
  }

  // Function to remove dark mode styles (reset for light mode)
  function removeDarkStyles() {
    styles.textContent = '';
  }

  // Function to toggle dark mode
  function toggleDarkMode() {
    document.body.style.transition = 'background-color 0.5s, color 0.5s';
    // Apply transitions to all relevant elements
    document.querySelectorAll('#toc-container, .calendar, footer, .week, .blog-tags span, .post-read-more, .post-preview .post-subtitle, .post-preview .post-title, .post-preview .post-subtitle:hover, .post-preview .post-title:hover, .form-section input[type="submit"], .featured-article, #player-container, .audio-player, .form-section, .prev-btn, .next-btn, .featured-title, .post-read-more, .play-button, .time-display, .volume-button, #number-search small, #bible-search small, #text-search small, .category-section, #bible-search label, #text-search label, #search-container, .search-container, #blog-post, .document-item hr, .toc-list li').forEach(el => {
      el.style.transition = 'background-color 0.5s, color 0.5s, border-top-color 0.5s';
    });

    if (document.body.hasAttribute('data-dark-mode')) {
      document.body.removeAttribute('data-dark-mode');
      removeDarkStyles();
      localStorage.setItem('darkMode', 'false');
      toggleButton.classList.remove('active'); // Slide up for light mode
    } else {
      document.body.setAttribute('data-dark-mode', 'true');
      applyDarkStyles();
      localStorage.setItem('darkMode', 'true');
      toggleButton.classList.add('active'); // Slide down for dark mode
    }
  }

  // Check if the current URL is /timeline-kanon-kitabsuci/
  if (window.location.pathname !== '/timeline-kanon-kitabsuci/') {
    // Create toggle button only if not on the specified page
    toggleButton = document.createElement('button');
    toggleButton.id = 'darkModeToggle';
      // Find the nav element where you want to append the button
      let navElement = document.querySelector('.navbar-nav.ml-auto');
      if(navElement) {
        navElement.appendChild(toggleButton);
      } else {
        console.warn("Could not find the navigation element to append the dark mode toggle.");
        // Fallback to append to body if nav element not found
        document.body.appendChild(toggleButton);
      }

    // Event listener for the toggle button
    toggleButton.addEventListener('click', toggleDarkMode);

    // Check local storage for dark mode preference
    const darkMode = localStorage.getItem('darkMode');
    if (darkMode === 'true' || (darkMode === null && window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.body.setAttribute('data-dark-mode', 'true');
      applyDarkStyles();
      toggleButton.classList.add('active');  // Set the switch to the 'sun' position for dark mode
    } else {
      removeDarkStyles();
      toggleButton.classList.remove('active'); // Set the switch to the 'moon' position for light mode
    }
  }
});
</script>

