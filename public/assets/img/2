            width: 250px;
            border: 1px solid #6e6a6a;
            border-radius: 3px;
            background-color: #141414;
            width: 100%;
        }        
        /* Keep .toc-list items the same color */
        .toc-list li,#toc h2 {
            color: var(--page-col) !important;
