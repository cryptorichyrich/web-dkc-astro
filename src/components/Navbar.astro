---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Beranda" },
  { href: "/kitabsuci", label: "Kitab Suci" },
  { href: "/renungan", label: "Renungan" },
  { href: "/katekismus", label: "Katekismus" },
  { href: "/lainnya", label: "Lainnya" },
];

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<!-- Desktop: top navbar -->
<nav class="hidden md:flex items-center justify-between px-6 py-3 bg-dkc-surface/95 backdrop-blur border-b border-dkc-border safe-top sticky top-0 z-50">
  <a href="/" class="flex items-center gap-3">
    <img src="/assets/img/avatar-icon.webp" alt="DKC" class="w-10 h-10 rounded-full border border-dkc-gold/30" />
    <span class="text-dkc-gold font-serif font-bold text-lg">Damai Kasih Channel</span>
  </a>
  <div class="flex items-center gap-6">
    {navItems.map(item => (
      <a href={item.href} class={`text-sm font-medium transition-colors ${isActive(item.href) ? 'text-dkc-gold' : 'text-dkc-muted hover:text-dkc-text'}`}>
        {item.label}
      </a>
    ))}
  </div>
</nav>

<!-- Mobile: bottom tab bar -->
<nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-dkc-surface/95 backdrop-blur border-t border-dkc-border safe-bottom"
     style="padding-bottom: max(env(safe-area-inset-bottom), 8px)">
  <div class="flex justify-around items-center px-2 pt-2">
    <a href="/" class={`mobile-nav-item ${isActive("/") ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      <span class="text-[10px] leading-none">Beranda</span>
    </a>
    <a href="/kitabsuci" class={`mobile-nav-item ${isActive("/kitabsuci") ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
      <span class="text-[10px] leading-none">Kitab Suci</span>
    </a>
    <a href="/renungan" class={`mobile-nav-item ${isActive("/renungan") ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
      <span class="text-[10px] leading-none">Renungan</span>
    </a>
    <a href="/katekismus" class={`mobile-nav-item ${isActive("/katekismus") ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
      <span class="text-[10px] leading-none">Katekismus</span>
    </a>
    <a href="/lainnya" class={`mobile-nav-item ${isActive("/lainnya") ? 'active' : ''}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><circle cx="19" cy="5" r="2"/><circle cx="5" cy="5" r="2"/><circle cx="19" cy="19" r="2"/><circle cx="5" cy="19" r="2"/></svg>
      <span class="text-[10px] leading-none">Lainnya</span>
    </a>
  </div>
</nav>

<!-- Spacer for mobile bottom nav -->
<div class="md:hidden h-16"></div>


