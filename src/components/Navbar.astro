  // ===== DESKTOP MEGA MENU =====
  const megaPanel = document.getElementById("mega-panel");
  const megaContent = document.getElementById("mega-content");
  let currentMega = null;
  let hideTimer = null;

  function buildMegaHTML(group) {
    const gridCols = group.submenu.length <= 4 ? "sm:grid-cols-2" : "sm:grid-cols-3";
    return `
      <div class="grid grid-cols-1 ${gridCols} gap-3 sm:gap-4">
        ${group.submenu.map(item => `
          <a href="${item.href}" data-mega-link
            class="flex items-start gap-3 px-3.5 py-3 rounded-2xl transition-all duration-200 ${item.highlight
              ? "bg-dkc-gold/10 border border-dkc-gold/20"
              : "border border-transparent hover:bg-dkc-card hover:border-dkc-gold/10"}">
            <span class="text-xl mt-0.5 shrink-0" style="transition: transform 0.2s">${item.icon}</span>
            <div class="min-w-0">
              <span class="text-sm font-medium block leading-tight text-dkc-text" style="transition: color 0.2s">${item.label}</span>
              <span class="text-[11px] text-dkc-muted block mt-0.5 leading-tight">${item.desc}</span>
            </div>
          </a>
        `).join("")}
      </div>
      <div class="mt-5 pt-3 border-t border-dkc-border/40 flex items-center justify-between">
        <p class="text-dkc-muted text-[11px]">Damai Kasih Channel — Apologetika, Katekese, dan Pembelaan Iman Katolik</p>
        <a href="/search" class="text-xs text-dkc-gold/60 hover:text-dkc-gold transition-colors flex items-center gap-1 shrink-0" style="transition: color 0.2s">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span>Cari</span>
        </a>
      </div>
    `;
  }

  function showMega(id) {
    const group = NAV_DATA.find(g => g.id === id);
    if (!group?.hasSubmenu) return;
    if (currentMega === id) { clearTimeout(hideTimer); hideTimer = null; return; }
    clearTimeout(hideTimer);
    hideTimer = null;

    // Reset all triggers
    document.querySelectorAll(".nav-trigger").forEach(el => el.classList.remove("active-mega"));
    // Activate this trigger
    const trigger = document.querySelector(`.nav-trigger[data-nav-id="${id}"]`);
    if (trigger) trigger.classList.add("active-mega");

    megaContent.innerHTML = buildMegaHTML(group);
    currentMega = id;
    requestAnimationFrame(() => megaPanel.classList.add("open"));
  }

  function hideMega() {
    hideTimer = setTimeout(() => {
      currentMega = null;
      megaPanel.classList.remove("open");
      document.querySelectorAll(".nav-trigger").forEach(el => el.classList.remove("active-mega"));
    }, 180);
  }

  // Attach desktop hover listeners
  document.querySelectorAll("[data-nav-group]").forEach(groupEl => {
    const id = groupEl.getAttribute("data-nav-group");
    groupEl.addEventListener("mouseenter", () => showMega(id));
    groupEl.addEventListener("mouseleave", hideMega);
  });

  // Mega panel itself — keep open while hovering on it
  if (megaPanel) {
    megaPanel.addEventListener("mouseenter", () => { clearTimeout(hideTimer); hideTimer = null; });
    megaPanel.addEventListener("mouseleave", hideMega);
  }

  // ===== MOBILE HAMBURGER MEGA MENU =====
  const megaMenuOverlay = document.getElementById("mega-menu-overlay");
  const hamburgerBtn = document.getElementById("hamburger-btn");
  const megaMenuCloseBtn = document.getElementById("mega-menu-close-btn");
  let megaMenuOpen = false;

  function openMegaMenu() {
    if (megaMenuOpen) return;
    megaMenuOpen = true;
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      megaMenuOverlay.classList.add("mega-menu-open");
    });
  }

  function closeMegaMenu() {
    if (!megaMenuOpen) return;
    megaMenuOpen = false;
    megaMenuOverlay.classList.remove("mega-menu-open");
    // Wait for animation to finish before restoring scroll
    setTimeout(() => {
      if (!megaMenuOpen) document.body.style.overflow = "";
    }, 380);
  }

  if (hamburgerBtn) {
    hamburgerBtn.addEventListener("click", openMegaMenu);
  }
  if (megaMenuCloseBtn) {
    megaMenuCloseBtn.addEventListener("click", closeMegaMenu);
  }
  // Close on backdrop click
  document.querySelectorAll("[data-mega-menu-close]").forEach(el => {
    el.addEventListener("click", closeMegaMenu);
  });

  // Esc key
  document.addEventListener("keydown", e => {
    if (e.key === "Escape") { hideMega(); closeMegaMenu(); closeBnavMenu(); }
  });

  // ===== BOTTOM NAV MEGAMENU =====
  const BNAV_MENUS = {
    devosi: {
      title: "Devosi",
      items: [
        { href: "/rosario", icon: "📿", label: "Doa Rosario", desc: "Misteri Gembira, Sedih, Mulia, Terang" },
        { href: "/jalan-salib", icon: "✝️", label: "Jalan Salib", desc: "14 Perhentian lengkap" },
        { href: "/doa-tobat", icon: "🙏", label: "Doa Tobat", desc: "Doa pertobatan & rekonsiliasi" },
        { href: "/doa-malaikat-tuhan", icon: "👼", label: "Malaikat Tuhan (Angelus)", desc: "Doa Angelus tradisional" },
        { href: "/doa-ratu-surga", icon: "👑", label: "Ratu Surga (Regina Caeli)", desc: "Doa Regina Caeli" },
        { href: "/koronka-kerahiman-ilahi", icon: "✨", label: "Koronka Kerahiman Ilahi", desc: "Doa kerahiman ilahi" },
        { href: "/kalender-liturgi", icon: "📅", label: "Kalender Liturgi", desc: "Kalender Gereja — pesta & peringatan" },
        { href: "/renungan", icon: "🕐", label: "Renungan Harian", desc: "Renungan harian" },
      ],
      linkAll: { href: "/devosi", label: "Semua Devosi →" },
    },
    artikel: {
      title: "Artikel",
      sections: [
        {
          heading: "Kategori",
          items: [
            { href: "/blog/tag/Apologetika", icon: "🛡️", label: "Apologetika", desc: "Pembelaan iman Katolik" },
            { href: "/blog/tag/Dogma", icon: "📕", label: "Dogma", desc: "Dogma Gereja Katolik" },
            { href: "/blog/tag/Alkitab", icon: "📜", label: "Alkitab", desc: "Kajian & tafsir" },
            { href: "/blog/tag/Sejarah", icon: "🏛️", label: "Sejarah", desc: "Sejarah Gereja" },
          ],
        },
      ],
      links: [
        { href: "/blog", icon: "📝", label: "Semua Artikel" },
        { href: "/search", icon: "🔍", label: "Cari Artikel" },
      ],
    },
    kitabsuci: {
      title: "Kitab Suci",
      items: [
        { href: "/kitabsuci", icon: "📖", label: "Alkitab TB (Deuterokanonika)", desc: "Terjemahan Baru lengkap" },
        { href: "/kitabsuci/pbtb2/", icon: "📚", label: "Alkitab TB2", desc: "Versi TB alternatif" },
        { href: "/vulgata", icon: "🏛️", label: "Vulgata (Latin)", desc: "Alkitab bahasa Latin" },
        { href: "/interlinear-greek", icon: "🔤", label: "Interlinear Greek", desc: "Teks Yunani asli" },
        { href: "/kamus-kitab-suci", icon: "📖", label: "Kamus Kitab Suci", desc: "Kamus alkitabiah lengkap" },
      ],
    },
    dokumen: {
      title: "Dokumen",
      items: [
        { href: "/katekismus", icon: "📕", label: "Katekismus Gereja Katolik (KGK)", desc: "Katekismus lengkap" },
        { href: "/khk", icon: "⚖️", label: "Hukum Kanonik (KHK)", desc: "Kitab Hukum Gereja" },
        { href: "/kvii", icon: "📜", label: "Konsili Vatikan II", desc: "Dokumen lengkap KV II" },
        { href: "/summa", icon: "📚", label: "Summa Theologiae", desc: "St. Thomas Aquinas — teologi sistematis" },
        { href: "/diagnosa/ajaran-bidat", icon: "⚔️", label: "Diagnosa Ajaran Bidat", desc: "Uji & identifikasi ajaran sesat" },
        { href: "/diagnosa/sedevacantisme", icon: "🛡️", label: "Diagnosa Sedevacantisme", desc: "Uji paham sedevacantisme" },
      ],
    },
  };

  const bnavMegamenu = document.getElementById("bnav-megamenu");
  const bnavPanel = document.getElementById("bnav-megamenu-panel");
  const bnavTitle = document.getElementById("bnav-megamenu-title");
  const bnavContent = document.getElementById("bnav-megamenu-content");
  const bnavBackdrop = document.getElementById("bnav-megamenu-backdrop");
  const bnavCloseBtn = document.getElementById("bnav-megamenu-close");
  const bottomNav = document.getElementById("mobile-bottom-nav");
  let bnavOpen = null;

  function buildBnavLinkHTML(item) {
    return `<a href="${item.href}" class="bnav-link">
      <span style="font-size:1rem;margin-top:2px;flex-shrink:0">${item.icon}</span>
      <div style="min-width:0">
        <span style="font-size:0.8125rem;font-weight:500;display:block;line-height:1.3;color:var(--color-dkc-text)">${item.label}</span>
        <span style="font-size:0.65625rem;color:var(--color-dkc-muted);display:block;margin-top:2px;line-height:1.3">${item.desc}</span>
      </div>
    </a>`;
  }

  function buildBnavHTML(section) {
    const data = BNAV_MENUS[section];
    if (!data) return "";

    let html = '<div style="display:flex;flex-direction:column;gap:2px">';

    // Simple items list
    if (data.items) {
      data.items.forEach(item => { html += buildBnavLinkHTML(item); });
    }

    // Grouped sections (for artikel)
    if (data.sections) {
      data.sections.forEach(sec => {
        html += `</div>`; // close previous gap container
        html += `<div class="bnav-section-divider" style="margin-top:0.75rem"><h4>${sec.heading}</h4></div>`;
        html += `<div style="display:flex;flex-direction:column;gap:2px">`;
        sec.items.forEach(item => { html += buildBnavLinkHTML(item); });
        html += `</div>`;
        html += `<div style="display:flex;flex-direction:column;gap:2px">`; // reopen for anything after
      });
    }

    html += '</div>';

    // "See all" link
    if (data.linkAll) {
      html += `<div style="margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid rgba(201,168,76,0.12)">
        <a href="${data.linkAll.href}" class="bnav-link" style="color:var(--color-dkc-gold);font-weight:500;font-size:0.8125rem">
          ${data.linkAll.label}
        </a>
      </div>`;
    }

    // Footer links (for artikel)
    if (data.links) {
      html += `<div style="margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid rgba(201,168,76,0.12);display:flex;gap:0.5rem">`;
      data.links.forEach(link => {
        html += `<a href="${link.href}" class="bnav-footer-link">
          <span>${link.icon}</span>
          <span>${link.label}</span>
        </a>`;
      });
      html += `</div>`;
    }

    return html;
  }

  function openBnavMenu(section) {
    // Toggle: if same section, close
    if (bnavOpen === section) {
      closeBnavMenu();
      return;
    }

    // Close any currently open popup
    closeBnavMenu();

    const popup = document.getElementById("popup-" + section);
    if (!popup) return;

    bnavOpen = section;

    // Show the popup
    popup.classList.remove("hidden");

    // Highlight active button
    document.querySelectorAll("[data-bnav]").forEach(btn => btn.classList.remove("bnav-active"));
    const activeBtn = document.querySelector(`[data-bnav="${section}"]`);
    if (activeBtn) activeBtn.classList.add("bnav-active");
  }

  function closeBnavMenu() {
    if (!bnavOpen) return;

    // Hide all popups
    document.querySelectorAll("[id^='popup-']").forEach(p => p.classList.add("hidden"));

    bnavOpen = null;
    document.querySelectorAll("[data-bnav]").forEach(btn => btn.classList.remove("bnav-active"));
  }

  // Attach click listeners to bottom nav buttons
  document.querySelectorAll("[data-bnav]").forEach(btn => {
    btn.addEventListener("click", (e) => {
      e.stopPropagation();
      const section = btn.getAttribute("data-bnav");
      openBnavMenu(section);
    });
  });

  // Close popups when clicking outside (not on popup or nav button)
  document.addEventListener("click", (e) => {
    if (!bnavOpen) return;
    const target = e.target;
    // Don't close if clicking inside a popup
    const openPopup = document.getElementById("popup-" + bnavOpen);
    if (openPopup && openPopup.contains(target)) return;
    // Don't close if clicking a bottom nav button (handled by its own listener)
    if (target.closest("[data-bnav]")) return;
    closeBnavMenu();
  });

  // Close on backdrop click (legacy bnav-megamenu, kept for compatibility)
  if (bnavBackdrop) {
    bnavBackdrop.addEventListener("click", closeBnavMenu);
  }
  if (bnavCloseBtn) {
    bnavCloseBtn.addEventListener("click", closeBnavMenu);
  }
</script>
