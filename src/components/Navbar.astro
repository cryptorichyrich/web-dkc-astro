---
const currentPath = Astro.url.pathname;

// ===== DATA: Each nav item with its submenu =====
const navGroups = [
  {
    id: "beranda",
    label: "Beranda",
    href: "/",
    mobileIcon: "home",
    hasSubmenu: false,
  },
  {
    id: "artikel",
    label: "Artikel",
    href: "/blog",
    mobileIcon: "book",
    hasSubmenu: true,
    style: "artikel",
    submenu: [
      { href: "/blog", icon: "📝", label: "Semua Artikel", desc: "Daftar artikel terbaru" },
      { href: "/blog/tag/Apologetika", icon: "🛡️", label: "Apologetika", desc: "Pembelaan iman Katolik" },
      { href: "/blog/tag/Katolik", icon: "✝️", label: "Katolik", desc: "Doktrin & ajaran Gereja" },
      { href: "/blog/tag/Protestant", icon: "📖", label: "Dialog", desc: "Dengan Protestan" },
      { href: "/blog/tag/Dogma", icon: "📕", label: "Dogma", desc: "Dogma Gereja Katolik" },
      { href: "/blog/tag/Maria", icon: "👑", label: "Mariologi", desc: "Bunda Maria" },
      { href: "/blog/tag/Alkitab", icon: "📜", label: "Alkitab", desc: "Kajian & tafsir" },
      { href: "/blog/tag/Sejarah", icon: "🏛️", label: "Sejarah", desc: "Sejarah Gereja" },
      { href: "/search", icon: "🔍", label: "Cari Artikel", desc: "Pencarian lengkap", highlight: true },
    ],
  },
  {
    id: "kitabsuci",
    label: "Kitab Suci",
    href: "/kitabsuci",
    mobileIcon: "bible",
    hasSubmenu: true,
    style: "kitabsuci",
    submenu: [
      { href: "/kitabsuci", icon: "📖", label: "Alkitab TB (Deuterokanonika)", desc: "Terjemahan Baru lengkap" },
      { href: "/kitabsuci/pbtb2/", icon: "📚", label: "Alkitab TB2", desc: "Versi TB alternatif" },
      { href: "/vulgata", icon: "🏛️", label: "Vulgata (Latin)", desc: "Alkitab bahasa Latin" },
      { href: "/interlinear-greek", icon: "🔤", label: "Interlinear Greek", desc: "Teks Yunani asli" },
      { href: "/kamus-kitab-suci", icon: "📖", label: "Kamus Kitab Suci", desc: "Kamus alkitabiah lengkap" },
      { href: "/kemenag", icon: "📋", label: "Kitab Suci Kemenag", desc: "Untuk perbandingan" },
      { href: "/timeline-kanon-kitabsuci", icon: "📜", label: "Sejarah Kanon Kitab Suci", desc: "Timeline pembentukan kanon" },
    ],
  },
  {
    id: "renungan",
    label: "Renungan",
    href: "/renungan",
    mobileIcon: "clock",
    hasSubmenu: true,
    style: "renungan",
    submenu: [
      { href: "/renungan", icon: "🕐", label: "Renungan Harian", desc: "Doa pada jam tertentu — semua ibadat lengkap" },
      { href: "/rosario", icon: "📿", label: "Rosario", desc: "Misteri Gembira, Sedih, Mulia, Terang" },
      { href: "/jalan-salib", icon: "✝️", label: "Jalan Salib", desc: "14 Perhentian lengkap" },
      { href: "/kalender-liturgi", icon: "📅", label: "Kalender Liturgi", desc: "Kalender Gereja — pesta & peringatan" },
    ],
  },
  {
    id: "katekismus",
    label: "Katekismus",
    href: "/katekismus",
    mobileIcon: "book",
    hasSubmenu: true,
    style: "katekismus",
    submenu: [
      { href: "/katekismus", icon: "📕", label: "KGK", desc: "Katekismus Gereja Katolik — lengkap" },
      { href: "/khk", icon: "⚖️", label: "Hukum Kanonik (KHK)", desc: "Kitab Hukum Gereja" },
      { href: "/kvii", icon: "📜", label: "Konsili Vatikan II", desc: "Dokumen lengkap KV II" },
      { href: "/summa", icon: "📚", label: "Summa Theologiae", desc: "St. Thomas Aquinas — teologi sistematis" },
      { href: "/diagnosa/ajaran-bidat", icon: "⚔️", label: "Diagnosa Bidat", desc: "Uji & identifikasi ajaran sesat" },
      { href: "/diagnosa/sedevacantisme", icon: "🛡️", label: "Diagnosa Sedevacantisme", desc: "Uji paham sedevacantisme" },
    ],
  },
  {
    id: "lainnya",
    label: "Lainnya",
    href: "#",
    mobileIcon: "more",
    hasSubmenu: true,
    style: "lainnya",
    submenu: [
      { href: "/suksesi-kepausan", icon: "♚", label: "Suksesi Kepausan", desc: "Rantai Paus dari St Petrus" },
      { href: "/flix", icon: "🎥", label: "Flix — Video", desc: "Galeri video DKC" },
      { href: "/blog/tag/Live", icon: "🔴", label: "Live DKC", desc: "Rekaman live streaming" },
      { href: "/tags", icon: "🏷️", label: "Semua Topik", desc: "Jelajahi per topik" },
      { href: "/tentang", icon: "ℹ️", label: "Tentang DKC", desc: "Tentang Damai Kasih Channel" },
      { href: "/search", icon: "🔍", label: "Pencarian", desc: "Cari seluruh situs" },
    ],
  },
];

const mobilePrimary = navGroups.filter(g => g.hasSubmenu);

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  if (href === "#") return false;
  return currentPath.startsWith(href);
}

function activeClass(href: string): string {
  if (href === "/") return currentPath === "/" ? "active" : "";
  if (href === "#") return "";
  return currentPath.startsWith(href) ? "active" : "";
}
---

<!-- ==================== MOBILE TOP HEADER ==================== -->
<header class="md:hidden sticky top-0 z-50 bg-dkc-surface/90 backdrop-blur-xl border-b border-dkc-border/60">
  <div class="flex items-center gap-2 px-4 h-12">
    <!-- Left: Hamburger Button -->
    <button id="hamburger-btn" class="w-9 h-9 rounded-full bg-dkc-card border border-dkc-border flex items-center justify-center text-dkc-gold hover:bg-dkc-gold/10 hover:border-dkc-gold/30 transition-all active:scale-95" aria-label="Menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <!-- Center: Site name with glow -->
    <a href="/" class="absolute left-1/2 -translate-x-1/2 flex items-center">
      <span class="text-white text-sm font-semibold tracking-wide" style="text-shadow: 0 0 12px rgba(201,168,76,0.5), 0 0 24px rgba(201,168,76,0.2);">Damai Kasih Channel</span>
    </a>
    <!-- Right: Theme + Search -->
    <div class="ml-auto flex items-center gap-1.5">
      <button class="dkc-theme-btn" aria-label="Toggle dark/light mode" title="Toggle mode"></button>
      <a href="/search" class="w-9 h-9 rounded-full bg-dkc-card border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-dkc-gold hover:border-dkc-gold/30 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </a>
    </div>
  </div>
</header>

<!-- ==================== MOBILE HAMBURGER MEGA MENU ==================== -->
<div id="mega-menu-overlay" class="md:hidden fixed inset-0 z-[60] pointer-events-none" style="opacity: 0; transition: opacity 0.3s ease;">
  <!-- Backdrop -->
  <div id="mega-menu-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-md" data-mega-menu-close></div>
  <!-- Slide-in Panel -->
  <div id="mega-menu-panel" class="mega-menu-panel absolute top-0 left-0 bottom-0 w-[88vw] max-w-[400px] overflow-y-auto overscroll-contain" style="transform: translateX(-100%); transition: transform 0.38s cubic-bezier(0.32, 0.72, 0, 1);">
    <!-- Top Bar: Logo + Close -->
    <div class="sticky top-0 z-10 glass-panel-header px-5 pt-5 pb-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <img src="/assets/img/channels4_profile.webp" alt="DKC" class="w-10 h-10 rounded-full border-2 border-dkc-gold/50 shadow-md shadow-dkc-gold/10" />
        <div>
          <span class="text-dkc-gold font-serif font-bold text-base leading-tight block">Damai Kasih</span>
          <span class="text-dkc-muted text-[10px] tracking-wider uppercase leading-tight block">Channel</span>
        </div>
      </div>
      <button id="mega-menu-close-btn" class="w-9 h-9 rounded-full bg-dkc-card border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-dkc-gold hover:border-dkc-gold/30 transition-all active:scale-95" aria-label="Close menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Home link -->
    <div class="px-4 pb-2">
      <a href="/" class="flex items-center gap-3 px-4 py-3 rounded-2xl bg-dkc-gold/10 border border-dkc-gold/15 transition-all active:scale-[0.98]">
        <span class="text-lg">🏠</span>
        <span class="text-sm font-semibold text-dkc-gold">Beranda</span>
      </a>
    </div>

    <!-- Nav Groups -->
    <div class="px-4 pb-6 space-y-5">
      {navGroups.filter(g => g.hasSubmenu).map(group => (
        <section>
          <!-- Group Header -->
          <div class="flex items-center gap-2 px-1 pb-2 pt-1">
            <span class="text-sm">{group.submenu?.[0]?.icon || "📋"}</span>
            <h3 class="text-dkc-gold font-serif font-bold text-sm tracking-wide uppercase">{group.label}</h3>
            <div class="flex-1 h-px bg-gradient-to-r from-dkc-gold/20 to-transparent ml-2"></div>
          </div>
          <!-- Group Items -->
          <div class="space-y-1">
            {group.submenu?.map(item => (
              <a
                href={item.href}
                class:list={[
                  "flex items-start gap-3 px-3.5 py-2.5 rounded-xl transition-all duration-200 active:scale-[0.98]",
                  isActive(item.href)
                    ? "bg-dkc-gold/10 border border-dkc-gold/15"
                    : "bg-transparent border border-transparent active:bg-dkc-gold/5",
                ]}
              >
                <span class="text-base mt-0.5 shrink-0">{item.icon}</span>
                <div class="min-w-0">
                  <span class:list={[
                    "text-[13px] font-medium block leading-tight",
                    isActive(item.href) ? "text-dkc-gold" : "text-dkc-text",
                  ]}>{item.label}</span>
                  <span class="text-[10.5px] text-dkc-muted block mt-0.5 leading-tight">{item.desc}</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    <!-- Footer -->
    <div class="glass-panel-footer px-5 py-5">
      <div class="flex items-center justify-center gap-5 mb-4">
        <!-- YouTube -->
        <a href="https://youtube.com/@DamaiKasihChannel" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-dkc-card border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-red-500 hover:border-red-500/30 transition-all" aria-label="YouTube">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
        <!-- Instagram -->
        <a href="https://instagram.com/damaikasihchannel" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-dkc-card border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-pink-500 hover:border-pink-500/30 transition-all" aria-label="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
        <!-- TikTok -->
        <a href="https://tiktok.com/@damaikasihchannel" target="_blank" rel="noopener" class="w-10 h-10 rounded-full bg-dkc-card border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-white hover:border-white/30 transition-all" aria-label="TikTok">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"/></svg>
        </a>
      </div>
      <p class="text-center text-dkc-muted text-[10px] leading-relaxed">© 2024 Damai Kasih Channel<br />Apologetika, Katekese & Pembelaan Iman</p>
    </div>
  </div>
</div>

<!-- ==================== DESKTOP ==================== -->
<header class="hidden md:block sticky top-0 z-50">
  <div class="bg-dkc-surface/90 backdrop-blur-xl border-b border-dkc-border/60 relative">
    <div class="max-w-6xl mx-auto flex items-center justify-center px-6 h-14">
      <!-- Nav items centered -->
      <div class="flex items-center" id="desktop-nav-links">
        {navGroups.map(group => (
          <div
            data-nav-group={group.id}
            class="nav-group relative"
          >
            <a
              href={group.href}
              data-nav-id={group.id}
              class:list={[
                "nav-trigger inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium rounded-lg transition-all duration-200 cursor-pointer",
                activeClass(group.href),
              ]}
            >
              {group.label}
              {group.hasSubmenu && (
                <svg class="nav-chevron w-3.5 h-3.5 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              )}
            </a>
          </div>
        ))}
      </div>
      <!-- Right: Theme toggle -->
      <div class="ml-4 flex items-center">
        <button class="dkc-theme-btn" aria-label="Toggle dark/light mode" title="Toggle mode"></button>
      </div>
    </div>
  </div>

  <!-- ===== SINGLE SHARED MEGA PANEL ===== -->
  <div
    id="mega-panel"
    class="absolute left-0 right-0 top-full z-40 opacity-0 invisible pointer-events-none"
    style="transition: opacity 0.25s ease, visibility 0.25s ease;"
  >
    <div class="absolute inset-0 bg-dkc-deep/85 backdrop-blur-2xl"></div>
    <div class="relative h-px bg-gradient-to-r from-transparent via-dkc-gold/40 to-transparent"></div>
    <div id="mega-content" class="relative max-w-6xl mx-auto px-6 py-8">
      <!-- Content injected by JS -->
    </div>
  </div>

  <!-- Floating Logo at bottom center of header -->
  <div class="absolute left-1/2 -translate-x-1/2 -bottom-[22px] z-50">
    <a href="/" aria-label="Home" class="block">
      <div class="relative">
        <div class="absolute inset-0 bg-dkc-gold/20 rounded-full blur-md"></div>
        <img src="/assets/img/channels4_profile.webp" alt="Damai Kasih Channel" class="relative w-11 h-11 rounded-full border-2 border-dkc-gold/50 shadow-lg shadow-dkc-gold/10" />
      </div>
    </a>
  </div>
</header>

<!-- Spacer for mobile bottom nav -->
<div class="md:hidden h-16"></div>

<!-- ==================== BOTTOM NAV QUICK POPUPS ==================== -->
<!-- Popup: Devosi -->
<div id="popup-devosi" class="md:hidden fixed left-0 right-0 bottom-[60px] z-[55] max-h-[40vh] overflow-y-auto overscroll-contain bg-dkc-surface/95 backdrop-blur-xl border-t border-dkc-border/60 rounded-t-xl p-4 shadow-[0_-8px_40px_rgba(0,0,0,0.5)] hidden" style="padding-bottom: max(env(safe-area-inset-bottom), 1rem);">
  <div class="flex items-center gap-2 px-1 pb-2">
    <span class="text-xs">📿</span>
    <h4 class="text-dkc-gold font-serif font-bold text-xs tracking-wide uppercase">Devosi</h4>
    <div class="flex-1 h-px bg-gradient-to-r from-dkc-gold/20 to-transparent"></div>
  </div>
  <div class="grid grid-cols-2 gap-1">
    <a href="/rosario" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">📿</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Doa Rosario</span><span class="text-[9px] text-dkc-muted block leading-tight">Misteri lengkap</span></div>
    </a>
    <a href="/jalan-salib" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">✝️</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Jalan Salib</span><span class="text-[9px] text-dkc-muted block leading-tight">14 Perhentian</span></div>
    </a>
    <a href="/doa-tobat" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">🙏</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Doa Tobat</span><span class="text-[9px] text-dkc-muted block leading-tight">Doa pertobatan</span></div>
    </a>
    <a href="/doa-malaikat-tuhan" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">👼</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Angelus</span><span class="text-[9px] text-dkc-muted block leading-tight">Malaikat Tuhan</span></div>
    </a>
    <a href="/doa-ratu-surga" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">👑</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Regina Caeli</span><span class="text-[9px] text-dkc-muted block leading-tight">Ratu Surga</span></div>
    </a>
    <a href="/koronka-kerahiman-ilahi" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">✨</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Koronka</span><span class="text-[9px] text-dkc-muted block leading-tight">Kerahiman Ilahi</span></div>
    </a>
    <a href="/kalender-liturgi" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">📅</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Kalender Liturgi</span><span class="text-[9px] text-dkc-muted block leading-tight">Kalender Gereja</span></div>
    </a>
    <a href="/renungan" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">🕐</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Renungan</span><span class="text-[9px] text-dkc-muted block leading-tight">Renungan Harian</span></div>
    </a>
  </div>
</div>

<!-- Popup: Artikel -->
<div id="popup-artikel" class="md:hidden fixed left-0 right-0 bottom-[60px] z-[55] max-h-[40vh] overflow-y-auto overscroll-contain bg-dkc-surface/95 backdrop-blur-xl border-t border-dkc-border/60 rounded-t-xl p-4 shadow-[0_-8px_40px_rgba(0,0,0,0.5)] hidden" style="padding-bottom: max(env(safe-area-inset-bottom), 1rem);">
  <div class="flex items-center gap-2 px-1 pb-2">
    <span class="text-xs">📝</span>
    <h4 class="text-dkc-gold font-serif font-bold text-xs tracking-wide uppercase">Artikel</h4>
    <div class="flex-1 h-px bg-gradient-to-r from-dkc-gold/20 to-transparent"></div>
  </div>
  <div class="grid grid-cols-2 gap-1">
    <a href="/blog" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">📝</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Semua Artikel</span><span class="text-[9px] text-dkc-muted block leading-tight">Daftar artikel terbaru</span></div>
    </a>
    <a href="/search" class="flex items-center gap-2 px-2.5 py-2 rounded-lg hover:bg-dkc-gold/5 active:scale-[0.98] transition-all">
      <span class="text-sm shrink-0">🔍</span>
      <div class="min-w-0"><span class="text-[11px] font-medium text-dkc-text block leading-tight">Pencarian</span><span class="text-[9px] text-dkc-muted block leading-tight">Cari di seluruh situs</span></div>
    </a>
