    ]},
  ];

  // ===== DESKTOP MEGA MENU =====
  const megaPanel = document.getElementById("mega-panel");
  const megaContent = document.getElementById("mega-content");
  let currentMega = null;
  let hideTimer = null;

  function buildMegaHTML(group) {
    const gridCols = group.submenu.length <= 4 ? "sm:grid-cols-2" : "sm:grid-cols-3";
    return `
      <div class="grid grid-cols-1 ${gridCols} gap-3 sm:gap-4">
        ${group.submenu.map(item => `
          <a href="${item.href}" data-mega-link
            class="flex items-start gap-3 px-3.5 py-3 rounded-2xl transition-all duration-200 ${item.highlight
              ? "bg-dkc-gold/10 border border-dkc-gold/20"
              : "border border-transparent hover:bg-dkc-card hover:border-dkc-gold/10"}">
            <span class="text-xl mt-0.5 shrink-0" style="transition: transform 0.2s">${item.icon}</span>
            <div class="min-w-0">
              <span class="text-sm font-medium block leading-tight text-dkc-text" style="transition: color 0.2s">${item.label}</span>
              <span class="text-[11px] text-dkc-muted block mt-0.5 leading-tight">${item.desc}</span>
            </div>
          </a>
        `).join("")}
      </div>
      <div class="mt-5 pt-3 border-t border-dkc-border/40 flex items-center justify-between">
        <p class="text-dkc-muted text-[11px]">Damai Kasih Channel — Apologetika, Katekese, dan Pembelaan Iman Katolik</p>
        <a href="/search" class="text-xs text-dkc-gold/60 hover:text-dkc-gold transition-colors flex items-center gap-1 shrink-0" style="transition: color 0.2s">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <span>Cari</span>
        </a>
      </div>
    `;
  }

  function showMega(id) {
    const group = NAV_DATA.find(g => g.id === id);
    if (!group?.hasSubmenu) return;
    if (currentMega === id) { clearTimeout(hideTimer); hideTimer = null; return; }
    clearTimeout(hideTimer);
    hideTimer = null;

    // Reset all triggers
    document.querySelectorAll(".nav-trigger").forEach(el => el.classList.remove("active-mega"));
    // Activate this trigger
    const trigger = document.querySelector(`.nav-trigger[data-nav-id="${id}"]`);
    if (trigger) trigger.classList.add("active-mega");

    megaContent.innerHTML = buildMegaHTML(group);
    currentMega = id;
    requestAnimationFrame(() => megaPanel.classList.add("open"));
  }

  function hideMega() {
    hideTimer = setTimeout(() => {
      currentMega = null;
      megaPanel.classList.remove("open");
      document.querySelectorAll(".nav-trigger").forEach(el => el.classList.remove("active-mega"));
    }, 180);
  }

  // Attach desktop hover listeners
  document.querySelectorAll("[data-nav-group]").forEach(groupEl => {
    const id = groupEl.getAttribute("data-nav-group");
    groupEl.addEventListener("mouseenter", () => showMega(id));
    groupEl.addEventListener("mouseleave", hideMega);
  });

  // Mega panel itself — keep open while hovering on it
  if (megaPanel) {
    megaPanel.addEventListener("mouseenter", () => { clearTimeout(hideTimer); hideTimer = null; });
    megaPanel.addEventListener("mouseleave", hideMega);
  }

  // ===== MOBILE HAMBURGER MEGA MENU =====
  const megaMenuOverlay = document.getElementById("mega-menu-overlay");
  const hamburgerBtn = document.getElementById("hamburger-btn");
  const megaMenuCloseBtn = document.getElementById("mega-menu-close-btn");
  let megaMenuOpen = false;

  function openMegaMenu() {
    if (megaMenuOpen) return;
    megaMenuOpen = true;
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      megaMenuOverlay.classList.add("mega-menu-open");
    });
  }

  function closeMegaMenu() {
    if (!megaMenuOpen) return;
    megaMenuOpen = false;
    megaMenuOverlay.classList.remove("mega-menu-open");
    // Wait for animation to finish before restoring scroll
    setTimeout(() => {
      if (!megaMenuOpen) document.body.style.overflow = "";
    }, 380);
  }

  if (hamburgerBtn) {
    hamburgerBtn.addEventListener("click", openMegaMenu);
  }
  if (megaMenuCloseBtn) {
    megaMenuCloseBtn.addEventListener("click", closeMegaMenu);
  }
  // Close on backdrop click
  document.querySelectorAll("[data-mega-menu-close]").forEach(el => {
    el.addEventListener("click", closeMegaMenu);
  });

  // Esc key
  document.addEventListener("keydown", e => {
    if (e.key === "Escape") { hideMega(); closeMegaMenu(); }
  });
</script>
