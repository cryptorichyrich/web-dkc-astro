---
import "@/styles/global.css";
---

<!doctype html>
<html lang="id" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <slot name="head" />
  </head>
  <body>
    <slot />

    <!-- Global Reading Progress Bar (hidden on index page) -->
    <div id="global-progress-bar" class="fixed top-0 left-0 w-full h-[4px] z-[70] bg-dkc-surface/30 pointer-events-none">
      <div id="global-progress-fill" class="h-full bg-gradient-to-r from-dkc-gold/80 to-dkc-gold/50 transition-[width] duration-150 ease-out" style="width:0%"></div>
    </div>

    <!-- Global TTS Floating Button -->
    <button id="global-tts-btn" class="fixed bottom-20 md:bottom-6 right-4 z-[55] w-10 h-10 rounded-full bg-dkc-card border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-dkc-gold hover:border-dkc-gold/30 transition-all shadow-lg shadow-black/20 active:scale-95" title="Bacakan halaman ini" aria-label="Text-to-Speech">
      <svg id="global-tts-icon-play" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/></svg>
      <svg id="global-tts-icon-stop" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="6" width="12" height="12" rx="1"/></svg>
    </button>
  </body>
</html>

<style>
  /* Hide progress bar on index page */
  :root[data-page="index"] #global-progress-bar {
    display: none;
  }
  /* TTS pulsing animation while speaking */
  @keyframes tts-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(201,168,76,0.4); }
    50% { box-shadow: 0 0 0 8px rgba(201,168,76,0); }
  }
  #global-tts-btn.tts-speaking {
    animation: tts-pulse 1.5s ease-in-out infinite;
    color: var(--color-dkc-gold) !important;
    border-color: rgba(201,168,76,0.4) !important;
  }
</style>

<script>
  // ===== Global Reading Progress Bar =====
  (function() {
    const fill = document.getElementById('global-progress-fill');
    const bar = document.getElementById('global-progress-bar');
    if (!fill || !bar) return;

    // Hide on index page
    const path = window.location.pathname;
    if (path === '/') {
      bar.style.display = 'none';
      return;
    }

    function updateProgress() {
      const scrollTop = Math.max(window.scrollY, document.documentElement.scrollTop, document.body.scrollTop);
      const scrollHeight = Math.max(document.documentElement.scrollHeight, document.body.scrollHeight);
      const clientHeight = Math.max(document.documentElement.clientHeight, document.body.clientHeight);
      const maxScroll = scrollHeight - clientHeight;
      const pct = maxScroll > 0 ? Math.min((scrollTop / maxScroll) * 100, 100) : 0;
      fill.style.width = pct + '%';
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
  })();

  // ===== Global TTS Button =====
  (function() {
    const btn = document.getElementById('global-tts-btn');
    const iconPlay = document.getElementById('global-tts-icon-play');
    const iconStop = document.getElementById('global-tts-icon-stop');
    if (!btn || !iconPlay || !iconStop) return;

    let playing = false;
    let utterance: SpeechSynthesisUtterance | null = null;

    // Preload voices
    let cachedVoices: SpeechSynthesisVoice[] = [];
    function loadVoices() {
      cachedVoices = window.speechSynthesis.getVoices();
    }
    loadVoices();
    if (window.speechSynthesis.onvoiceschanged !== undefined) {
      window.speechSynthesis.onvoiceschanged = loadVoices;
    }

    function getMainText(): string {
      // Try multiple selectors to find page content
      const selectors = [
        '#article-body',           // Blog articles
        '#reading-content',        // Bible / interlinear
        '#ref-results',            // Reference reader (KHK, KGK)
        '#kvii-content',           // KV2
        '.prayer-content',         // Prayer pages
        'main',                    // Fallback: any main element
      ];

      for (const sel of selectors) {
        const el = document.querySelector(sel);
        if (el && el.textContent && el.textContent.trim().length > 50) {
          return el.textContent.trim();
        }
      }
      return '';
    }

    function stopTTS() {
      window.speechSynthesis.cancel();
      playing = false;
      iconPlay.classList.remove('hidden');
      iconStop.classList.add('hidden');
      btn.classList.remove('tts-speaking');
    }

    function startTTS() {
      const text = getMainText();
      if (!text) return;

      // Unlock audio context — cancel any pending speech first
      window.speechSynthesis.cancel();
      playing = true;
      iconPlay.classList.add('hidden');
      iconStop.classList.remove('hidden');
      btn.classList.add('tts-speaking');

      // Truncate to ~10000 chars for reasonable TTS length
      const maxLen = 10000;
      const ttsText = text.length > maxLen ? text.slice(0, maxLen) + '...' : text;

      utterance = new SpeechSynthesisUtterance(ttsText);

      // Detect language from page content
      const isGreekPage = window.location.pathname.includes('interlinear-greek');
      const isLatinPage = window.location.pathname.includes('vulgata');

      if (isGreekPage) {
        utterance.lang = 'en-US';
        utterance.rate = 0.85;
      } else if (isLatinPage) {
        utterance.lang = 'la';
        utterance.rate = 0.8;
      } else {
        utterance.lang = 'id-ID';
        utterance.rate = 0.95;
      }

      // Try to find a matching voice (use cached voices, reload if empty)
      const voices = cachedVoices.length > 0 ? cachedVoices : window.speechSynthesis.getVoices();
      if (utterance.lang === 'id-ID') {
        const idVoice = voices.find(v => v.lang.startsWith('id'));
        if (idVoice) utterance.voice = idVoice;
      }

      utterance.onend = () => stopTTS();
      utterance.onerror = (e) => {
        // Brief visual flash on error
        btn.style.background = 'rgba(239,83,80,0.2)';
        setTimeout(() => { btn.style.background = ''; }, 500);
        stopTTS();
      };

      window.speechSynthesis.speak(utterance);
    }

    btn.addEventListener('click', () => {
      if (playing) {
        stopTTS();
      } else {
        startTTS();
      }
    });

    // Stop TTS when leaving page
    window.addEventListener('beforeunload', () => {
      if (playing) window.speechSynthesis.cancel();
    });
  })();
</script>
