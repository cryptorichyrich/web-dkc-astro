---
import "@/styles/global.css";
---

<!doctype html>
<html lang="id" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.googleapis.com" />
    <link rel="dns-prefetch" href="https://fonts.gstatic.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('dkc-theme');
        if (t === 'light') {
          document.documentElement.classList.remove('dark');
          document.documentElement.classList.add('light');
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot />

    <!-- Global Reading Progress Bar -->
    <div id="global-progress-bar"><div id="global-progress-fill"></div></div>
  </body>
</html>

<style is:global>
  /* Progress Bar */
  #global-progress-bar { position: fixed; top: 0; left: 0; width: 100%; height: 4px; z-index: 9999; pointer-events: none; background: rgba(17,17,17,0.5); }
  #global-progress-fill { height: 100%; width: 0%; background: linear-gradient(to right, #c9a84c, #c9a84ccc); transition: width 100ms ease-out; }

  /* Dark mode toggle — embedded in navbar */
  .dkc-theme-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-dkc-card, #1a1a1a);
    border: 1px solid var(--color-dkc-border, #2a2a2a);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #888;
    cursor: pointer;
    transition: all 0.2s;
  }
  .dkc-theme-btn:hover { color: #c9a84c; border-color: rgba(201,168,76,0.3); }
  .dkc-theme-btn svg { width: 16px; height: 16px; }
  html.light .dkc-theme-btn {
    background: #f5f0e8;
    border-color: #e0d8c8;
    color: #666;
  }
  html.light .dkc-theme-btn:hover { color: #c9a84c; border-color: rgba(201,168,76,0.3); }
</style>

<script is:inline>
(function() {
  // ===== Global Reading Progress Bar =====
  var fill = document.getElementById('global-progress-fill');
  var bar = document.getElementById('global-progress-bar');
  if (fill && bar) {
    if (window.location.pathname === '/') {
      bar.style.display = 'none';
    } else {
      function updateProgress() {
        var scrollTop = window.scrollY || document.documentElement.scrollTop || document.body.scrollTop || 0;
        var scrollHeight = Math.max(document.documentElement.scrollHeight || 0, document.body.scrollHeight || 0);
        var clientHeight = Math.max(document.documentElement.clientHeight || 0, document.body.clientHeight || 0);
        var maxScroll = scrollHeight - clientHeight;
        var pct = maxScroll > 0 ? Math.min((scrollTop / maxScroll) * 100, 100) : 0;
        fill.style.width = pct + '%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });
      updateProgress();
    }
  }

  // ===== Dark Mode Toggle — find buttons in Navbar =====
  var themeButtons = document.querySelectorAll('.dkc-theme-btn');

  function updateThemeIcons() {
    var isLight = document.documentElement.classList.contains('light');
    var sunIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';
    var moonIcon = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
    themeButtons.forEach(function(btn) {
      btn.innerHTML = isLight ? moonIcon : sunIcon;
    });
  }

  themeButtons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var isLight = document.documentElement.classList.contains('light');
      if (isLight) {
        document.documentElement.classList.remove('light');
        document.documentElement.classList.add('dark');
        localStorage.setItem('dkc-theme', 'dark');
      } else {
        document.documentElement.classList.remove('dark');
        document.documentElement.classList.add('light');
        localStorage.setItem('dkc-theme', 'light');
      }
      updateThemeIcons();
    });
  });

  updateThemeIcons();
})();
</script>
