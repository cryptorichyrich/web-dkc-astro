---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog", ({ data }) => data.publishedAt <= new Date());
  const pageSize = 12;
  const totalPages = Math.ceil(allPosts.length / pageSize);
  return Array.from({length: totalPages}, (_, i) => ({
    params: { page: String(i + 1) },
    props: { pageNum: i + 1, totalPages },
  }));
}

const { pageNum, totalPages } = Astro.props;

const allPosts = await getCollection("blog", ({ data }) => data.publishedAt <= new Date());
const sorted = allPosts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const pageSize = 12;
const posts = sorted.slice((pageNum - 1) * pageSize, pageNum * pageSize);

// Build truncated page list: first, last, current ±1, with ellipsis gaps
const delta = 1;
const pageNumbers: (number | string)[] = [];
for (let i = 1; i <= totalPages; i++) {
  if (i === 1 || i === totalPages || (i >= pageNum - delta && i <= pageNum + delta)) {
    pageNumbers.push(i);
  } else if (pageNumbers[pageNumbers.length - 1] !== '...') {
    pageNumbers.push('...');
  }
}
---

<BaseLayout>
  <Fragment slot="head">
    <title>Artikel — Damai Kasih Channel</title>
    <meta name="description" content="Kumpulan artikel apologetika Katolik." />
  </Fragment>
  <Navbar />
  
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <div class="flex items-center justify-between mb-4">
      <h1 class="section-title mb-0">Artikel Terbaru</h1>
      {totalPages > 1 && (
        <span class="text-dkc-muted text-sm">Halaman {pageNum} dari {totalPages}</span>
      )}
    </div>
    
    {posts.length === 0 ? (
      <p class="text-dkc-muted">Belum ada artikel.</p>
    ) : (
      <div class="grid gap-4 md:grid-cols-2">
        {posts.map(post => {
          const img = post.data.coverImage || post.data.thumbnailImage || post.data.heroImage;
          const date = post.data.publishedAt
            ? new Date(post.data.publishedAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })
            : '';
          return (
            <a href={`/blog/${post.id}`} class="glass-card overflow-hidden group transition-all hover:border-dkc-gold/40">
              {img && (
                <div class="aspect-video bg-dkc-card overflow-hidden">
                  <img
                    src={img}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    onerror="this.parentElement.style.display='none'"
                  />
                </div>
              )}
              <div class="p-4">
                <h2 class="text-dkc-text font-semibold text-sm leading-snug line-clamp-2 group-hover:text-dkc-gold transition-colors">
                  {post.data.title}
                </h2>
                <div class="flex items-center gap-2 mt-2 text-xs text-dkc-muted">
                  <span>{post.data.author}</span>
                  {date && <><span>·</span><time>{date}</time></>}
                </div>
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1 mt-2">
                    {post.data.tags.slice(0, 3).map(tag => (
                      <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}

    {totalPages > 1 && (
      <nav class="flex justify-center items-center gap-2 sm:gap-4 mt-8 overflow-x-auto">
        {pageNum > 1 && <a href={pageNum === 2 ? '/blog/1' : `/blog/${pageNum - 1}`} class="text-dkc-gold hover:underline whitespace-nowrap text-sm">← Sebelumnya</a>}
        <div class="flex items-center gap-1.5">
          {pageNumbers.map((p) => (
            p === '...' ? (
              <span class="w-8 h-8 flex items-center justify-center text-dkc-muted text-sm select-none">…</span>
            ) : (
              <a
                href={p === 1 ? '/blog/1' : `/blog/${p}`}
                class:list={[
                  "w-8 h-8 rounded-lg text-sm flex items-center justify-center transition-colors shrink-0",
                  p === pageNum
                    ? "bg-dkc-gold text-dkc-surface font-semibold"
                    : "text-dkc-muted hover:text-dkc-gold hover:bg-dkc-gold/10"
                ]}
              >
                {p}
              </a>
            )
          ))}
        </div>
        {pageNum < totalPages && <a href={`/blog/${pageNum + 1}`} class="text-dkc-gold hover:underline whitespace-nowrap text-sm">Selanjutnya →</a>}
      </nav>
    )}
  </main>

  <Footer />
</BaseLayout>
