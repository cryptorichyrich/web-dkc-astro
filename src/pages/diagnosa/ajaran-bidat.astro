  let currentQuestion = 0;
  let detectedHeresies = [];
  let selectedQuestions = [];
  let userAnswers = [];

  let questionText = document.getElementById("question-text");
  let progressBar = document.getElementById("progress-bar");
  let progressText = document.getElementById("progress-text");
  let btnYes = document.getElementById("btn-Iya");
  let btnNo = document.getElementById("btn-Tidak");
  let quizContainer = document.getElementById("quiz-container");

  function initializeQuestions() {
    selectedQuestions = [];
    questionPairs.forEach(function(pair) {
      const variations = pair.variations.slice();
      const numToSelect = Math.min(Math.floor(Math.random() * 2) + 2, variations.length);
      for (let i = 0; i < numToSelect; i++) {
        const randomIndex = Math.floor(Math.random() * variations.length);
        const selectedVariation = variations.splice(randomIndex, 1)[0];
        selectedQuestions.push({
          text: selectedVariation.text,
          correctAnswer: selectedVariation.correctAnswer,
          correctExplanation: selectedVariation.correctExplanation,
          heresy: pair.heresy,
          century: pair.century,
          detail: pair.detail
        });
      }
    });
    selectedQuestions.sort(function() { return Math.random() - 0.5; });
  }

  function progressBarUpdate() {
    const progress = Math.round((currentQuestion / selectedQuestions.length) * 100);
    progressBar = document.getElementById("progress-bar");
    progressText = document.getElementById("progress-text");
    if (progressBar && progressText) {
      progressBar.style.width = progress + "%";
      progressText.textContent = progress + "%";
      if (progress < 5) {
        progressText.style.left = "4px";
        progressText.style.color = "#000";
      } else {
        progressText.style.left = (progress - 4.5) + "%";
        progressText.style.color = "#fff";
      }
    }
  }

  function nextQuestion(answer) {
    const currentQ = selectedQuestions[currentQuestion];
    userAnswers.push({
      question: currentQ.text,
      userAnswer: answer,
      correctExplanation: currentQ.correctExplanation,
      correctAnswer: currentQ.correctAnswer
    });
    if ((currentQ.correctAnswer === "Iya" && answer === "Tidak") || (currentQ.correctAnswer === "Tidak" && answer === "Iya")) {
      detectedHeresies.push(currentQ);
    }
    currentQuestion++;
    progressBarUpdate();
    if (currentQuestion < selectedQuestions.length) {
      questionText.textContent = selectedQuestions[currentQuestion].text;
    } else {
      showResults();
    }
  }

  function combineHeresies(heresies) {
    const combined = {};
    heresies.forEach(function(heresy) {
      if (!combined[heresy.heresy]) {
        combined[heresy.heresy] = { heresy: heresy.heresy, century: heresy.century, details: [heresy.detail] };
      } else if (combined[heresy.heresy].details.indexOf(heresy.detail) === -1) {
        combined[heresy.heresy].details.push(heresy.detail);
      }
    });
    return Object.values(combined).sort(function(a, b) {
      const centuryA = parseInt(a.century.match(/\d+/)[0], 10);
      const centuryB = parseInt(b.century.match(/\d+/)[0], 10);
      return centuryA - centuryB;
    });
  }

  function esc(s) { const d = document.createElement("div"); d.textContent = s; return d.innerHTML; }

  function showResults() {
    let html = "<div class=\"results-container\">";

    if (detectedHeresies.length > 1) {
      html += "<div class=\"alert-box danger\"><p>Kemungkinan besar Anda beragama Protestan yang sejati.</p></div>";
    }

    if (detectedHeresies.length === 0) {
      html += "<div class=\"alert-box success\"><h2>Selamat! Anda memiliki iman yang sehat, sesuai dengan ajaran Gereja Katolik.</h2></div>";
    } else {
      const combined = combineHeresies(detectedHeresies);
      html += "<div class=\"alert-box danger\"><h2>Berjaga-jagalah!<br>Anda terjangkit bidaah:</h2></div>";
      html += "<div class=\"mb-6\">";
      combined.forEach(function(h) {
        html += "<div class=\"heresy-card\">";
        html += "<div class=\"heresy-card-header\"><h3>" + esc(h.heresy) + "</h3><span class=\"century-badge\">" + esc(h.century) + "</span></div>";
        html += "<div class=\"heresy-card-body\">" + esc(h.details.join(" Selain itu, ")) + "</div>";
        html += "</div>";
      });
      html += "</div>";
    }

    html += "<h3 class=\"text-center mb-4 font-bold text-dkc-gold\">Hasil Jawaban Anda</h3>";
    html += "<div class=\"mb-6\">";

    userAnswers.forEach(function(qa, index) {
      const isCorrect = qa.userAnswer === qa.correctAnswer;
      const cls = isCorrect ? "correct" : "wrong";
      const label = isCorrect ? "Benar" : "Salah";
      html += "<div class=\"answer-card " + cls + "\">";
      html += "<div class=\"answer-card-header\"><span>Pertanyaan " + (index + 1) + "</span><span class=\"badge\">" + label + "</span></div>";
      html += "<div class=\"answer-card-body\">";
      html += "<h5 class=\"mb-3 font-semibold\">" + esc(qa.question) + "</h5>";
      html += "<div class=\"grid grid-cols-2 gap-2 mb-3\">";
      html += "<div class=\"user-answer\"><div class=\"answer-label\">Jawaban Anda:</div><div class=\"answer-value\">" + esc(qa.userAnswer) + "</div></div>";
      html += "<div class=\"correct-answer\"><div class=\"answer-label\">Jawaban Benar:</div><div class=\"answer-value\" style=\"color:#4caf50\">" + esc(qa.correctAnswer) + "</div></div>";
      html += "</div>";
      html += "<div class=\"explanation\"><strong>Penjelasan:</strong> " + qa.correctExplanation + "</div>";
      html += "</div></div>";
    });

    html += "</div>";

    // Reading materials
    html += "<div class=\"reading-list\">";
    html += "<div class=\"reading-list-header\">📚 Bacaan Lebih Lanjut</div>";
    html += "<a href=\"/blog/ajaran-ajaran-sesat-dari-abad-pertama-hingga-abad-tujuh-belas\" target=\"_blank\"><span>📚</span><span>Ajaran-ajaran Sesat dari Abad Pertama hingga Abad Tujuh Belas</span></a>";
    html += "<a href=\"/blog/bidat-gereja-katolik-dari-abad-pertama-hingga-abad-limabelas\" target=\"_blank\"><span>📚</span><span>Bidat Gereja Katolik dari Abad Pertama hingga Abad Lima Belas</span></a>";
    html += "</div>";

    // Retry button
    html += "<button class=\"retry-btn\" id=\"retry-button\">🔄 Diagnosa Ulang</button>";
    html += "</div>";

    // Link KGK references
    html = html.replace(/KGK (\d+)/g, function(match, id) {
      return "<a href=\"/katekismus?q=" + id + "\" target=\"_blank\">KGK " + id + "</a>";
    });

    quizContainer.innerHTML = html;
    document.getElementById("retry-button").addEventListener("click", resetQuiz);
  }

  function resetQuiz() {
    currentQuestion = 0;
    detectedHeresies = [];
    userAnswers = [];
    initializeQuestions();

    quizContainer.innerHTML = 
      "<h1 class=\"text-center text-2xl md:text-3xl font-bold text-dkc-gold mb-4\">DIAGNOSA AJARAN BIDAT</h1>" +
      "<h4 class=\"text-center text-dkc-muted mb-6 text-sm md:text-base leading-relaxed\">Harap baca dengan seksama dan jawab dengan jujur sesuai keyakinan iman kekristenan anda.</h4>" +
      "<div class=\"relative h-8 bg-dkc-surface rounded-full mb-6 overflow-hidden border border-dkc-border\">" +
      "<div id=\"progress-bar\" class=\"h-full rounded-full transition-all duration-300 ease-in-out\" style=\"width: 0%; background: linear-gradient(90deg, #c9a84c, #a88630);\"></div>" +
      "<div id=\"progress-text\" class=\"absolute top-1/2 -translate-y-1/2 text-sm font-bold transition-all duration-300\" style=\"left: 4px; color: #000;\">0%</div>" +
      "</div>" +
      "<div id=\"question-text\" class=\"text-center text-dkc-text text-base md:text-lg leading-relaxed mb-8 min-h-[80px] flex items-center justify-center\"></div>" +
      "<div class=\"grid grid-cols-2 gap-4 max-w-md mx-auto\">" +
      "<button id=\"btn-Iya\" class=\"py-4 rounded-xl text-lg font-bold transition-all active:scale-95 hover:brightness-110\" style=\"background: linear-gradient(135deg, #2d7d46, #1a5c2e); color: white;\">Iya [1]</button>" +
      "<button id=\"btn-Tidak\" class=\"py-4 rounded-xl text-lg font-bold transition-all active:scale-95 hover:brightness-110\" style=\"background: linear-gradient(135deg, #c0392b, #962d22); color: white;\">Tidak [2]</button>" +
      "</div>";

    questionText = document.getElementById("question-text");
    progressBar = document.getElementById("progress-bar");
    progressText = document.getElementById("progress-text");
    btnYes = document.getElementById("btn-Iya");
    btnNo = document.getElementById("btn-Tidak");

    btnYes.addEventListener("click", function() { nextQuestion("Iya"); });
    btnNo.addEventListener("click", function() { nextQuestion("Tidak"); });
    questionText.textContent = selectedQuestions[0].text;
    progressBarUpdate();
  }

  // Init
  initializeQuestions();
  btnYes.addEventListener("click", function() { nextQuestion("Iya"); });
  btnNo.addEventListener("click", function() { nextQuestion("Tidak"); });
  questionText.textContent = selectedQuestions[0].text;
  progressBarUpdate();

  document.addEventListener("keydown", function(event) {
    if (event.key === "1") { nextQuestion("Iya"); }
    else if (event.key === "2") { nextQuestion("Tidak"); }
  });
</script>
