---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Fragment slot="head">
    <title>Diagnosa Ajaran Bidat dalam Perspektif Katolik — Damai Kasih Channel</title>
    <meta name="description" content="Pelajari cara mengenali ajaran yang menyimpang dari iman Katolik berdasarkan Kitab Suci, Tradisi Suci, Magisterium, dan Katekismus Gereja Katolik." />
  </Fragment>
  <Navbar />
  
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <div class="glass-card p-6 md:p-8" id="quiz-container">
      <h1 class="text-center text-2xl md:text-3xl font-bold text-dkc-gold mb-4">DIAGNOSA AJARAN BIDAT</h1>
      <h4 class="text-center text-dkc-muted mb-6 text-sm md:text-base leading-relaxed">Harap baca dengan seksama dan jawab dengan jujur sesuai keyakinan iman kekristenen anda.</h4>
      
      <!-- Loading skeleton - shown instantly while data loads -->
      <div id="quiz-loading" class="text-center py-8">
        <div class="inline-block w-8 h-8 border-3 border-dkc-gold border-t-transparent rounded-full animate-spin"></div>
        <p class="text-dkc-muted mt-3 text-sm">Memuat pertanyaan...</p>
      </div>

      <!-- Quiz UI - hidden until data loads -->
      <div id="quiz-ui" style="display:none">
        <div class="relative h-8 bg-dkc-surface rounded-full mb-6 overflow-hidden border border-dkc-border">
          <div id="progress-bar" class="h-full rounded-full transition-all duration-300 ease-in-out" style="width: 0%; background: linear-gradient(90deg, #c9a84c, #a88630);"></div>
          <div id="progress-text" class="absolute top-1/2 -translate-y-1/2 text-sm font-bold transition-all duration-300" style="left: 4px; color: #000;">0%</div>
        </div>
        
        <div id="question-text" class="text-center text-dkc-text text-base md:text-lg leading-relaxed mb-8 min-h-[80px] flex items-center justify-center"></div>
        
        <div class="grid grid-cols-2 gap-4 max-w-md mx-auto">
          <button id="btn-Iya" class="py-4 rounded-xl text-lg font-bold transition-all active:scale-95 hover:brightness-110" style="background: linear-gradient(135deg, #2d7d46, #1a5c2e); color: white;">Iya [1]</button>
          <button id="btn-Tidak" class="py-4 rounded-xl text-lg font-bold transition-all active:scale-95 hover:brightness-110" style="background: linear-gradient(135deg, #c0392b, #962d22); color: white;">Tidak [2]</button>
        </div>
      </div>
    </div>
  </main>

  <!-- SEO content section -->
  <section class="max-w-4xl mx-auto px-4 pb-16">
    <div class="glass-card p-6 md:p-8 space-y-6 text-dkc-text text-sm md:text-base leading-relaxed">
      <h2 class="text-xl font-bold text-dkc-gold">Apa yang Dimaksud Ajaran Bidat?</h2>
      <p>Dalam ajaran Gereja Katolik, bidat (heresi) adalah penolakan atau distorsi yang disengaja terhadap kebenaran iman yang telah ditetapkan oleh Gereja. Gereja membedakan antara bidat formal (penolakan sadar) dan bidat material (kesalahan tanpa kesadaran penuh).</p>

      <h2 class="text-xl font-bold text-dkc-gold">Ukuran Ajaran Gereja Katolik</h2>
      <p>Gereja Katolik menggunakan tiga sumber utama untuk menilai kebenaran ajaran: <strong>Kitab Suci</strong> (Firman Allah yang tertulis), <strong>Tradisi Suci</strong> (warisan iman dari para Rasul), dan <strong>Magisterium</strong> (otoritas mengajar Gereja). Segala ajaran yang bertentangan dengan ketiga sumber ini patut diperiksa secara kritis.</p>

      <h2 class="text-xl font-bold text-dkc-gold">Peran Kitab Suci, Tradisi Suci, dan Magisterium</h2>
      <p>Kitab Suci, Tradisi Suci, dan Magisterium merupakan tiga pilar yang tidak dapat dipisahkan dalam iman Katolik. <a href="/katekismus" class="text-dkc-gold underline">Katekismus Gereja Katolik</a> menjelaskan bahwa ketiganya saling melengkapi dalam menafsirkan dan menyampaikan wahyu ilahi.</p>

      <h2 class="text-xl font-bold text-dkc-gold">Halaman Terkait</h2>
      <ul class="list-disc list-inside space-y-1">
        <li><a href="/katekismus" class="text-dkc-gold underline">Katekismus Gereja Katolik</a></li>
        <li><a href="/kv2" class="text-dkc-gold underline">Dokumen Konsili Vatikan II</a></li>
        <li><a href="/diagnosa/sedevacantisme" class="text-dkc-gold underline">Diagnosa Sedevacantisme</a></li>
        <li><a href="/suksesi-kepausan" class="text-dkc-gold underline">Suksesi Kepausan</a></li>
        <li><a href="/timeline-kanon-kitabsuci" class="text-dkc-gold underline">Timeline Kanon Kitab Suci</a></li>
      </ul>
    </div>
  </section>

  <Footer />
</BaseLayout>
<style is:global>
  .heresy-card { background: var(--color-dkc-surface); border: 1px solid #ef5350; border-radius: 0.75rem; margin-bottom: 1rem; overflow: hidden; }
  .heresy-card-header { background: linear-gradient(135deg, #c0392b, #962d22); padding: 0.75rem 1rem; display: flex; justify-content: space-between; align-items: center; }
  .heresy-card-header h3 { color: white; font-weight: bold; margin: 0; font-size: 1.1rem; }
  .century-badge { background: rgba(255,255,255,0.2); padding: 0.25rem 0.75rem; border-radius: 9999px; color: white; font-size: 0.8rem; }
  .heresy-card-body { padding: 1rem; color: var(--color-dkc-text); line-height: 1.7; }
  .alert-box { padding: 1.5rem; border-radius: 0.75rem; margin-bottom: 1.5rem; text-align: center; }
  .alert-box.success { background: linear-gradient(135deg, #1a5c2e, #2d7d46); color: white; border: 1px solid #4caf50; }
  .alert-box.success h2 { color: white; }
  .alert-box.danger { background: linear-gradient(135deg, #7f1d1d, #991b1b); color: white; border: 1px solid #ef5350; }
  .alert-box.danger h2 { color: white; }
  .answer-card { border-radius: 0.75rem; margin-bottom: 1rem; overflow: hidden; border: 1px solid var(--color-dkc-border); }
  .answer-card.correct { border-color: #4caf50; }
  .answer-card.wrong { border-color: #ef5350; }
  .answer-card-header { padding: 0.75rem 1rem; display: flex; justify-content: space-between; align-items: center; font-size: 0.9rem; }
  .answer-card.correct .answer-card-header { background: rgba(76, 175, 80, 0.15); color: #4caf50; }
  .answer-card.wrong .answer-card-header { background: rgba(239, 83, 80, 0.15); color: #ef5350; }
  .answer-card-header .badge { padding: 0.2rem 0.6rem; border-radius: 9999px; font-size: 0.75rem; font-weight: bold; }
  .answer-card.correct .badge { background: #4caf50; color: white; }
  .answer-card.wrong .badge { background: #ef5350; color: white; }
  .answer-card-body { padding: 1rem; background: var(--color-dkc-surface); }
  .answer-label { font-size: 0.75rem; color: var(--color-dkc-muted); margin-bottom: 0.25rem; }
  .answer-value { font-weight: bold; color: var(--color-dkc-text); }
  .explanation { background: rgba(201, 168, 76, 0.1); border-left: 3px solid var(--color-dkc-gold); padding: 0.75rem 1rem; border-radius: 0 0.5rem 0.5rem 0; margin-top: 0.75rem; line-height: 1.7; color: var(--color-dkc-text); font-size: 0.9rem; }
  .reading-list { margin-top: 1.5rem; padding: 1.5rem; background: var(--color-dkc-surface); border-radius: 0.75rem; border: 1px solid var(--color-dkc-border); }
  .reading-list-header { font-weight: bold; font-size: 1.1rem; margin-bottom: 1rem; color: var(--color-dkc-gold); }
  .reading-list a { display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem; border-radius: 0.5rem; margin-bottom: 0.5rem; background: rgba(201, 168, 76, 0.05); transition: background 0.2s; text-decoration: none; color: var(--color-dkc-text); }
  .reading-list a:hover { background: rgba(201, 168, 76, 0.15); }
  .retry-btn { display: block; width: 100%; max-width: 300px; margin: 2rem auto 0; padding: 1rem; border: none; border-radius: 0.75rem; font-size: 1.1rem; font-weight: bold; cursor: pointer; background: linear-gradient(135deg, #c9a84c, #a88630); color: #000; transition: transform 0.2s, box-shadow 0.2s; }
  .retry-btn:hover { transform: scale(1.02); box-shadow: 0 4px 15px rgba(201, 168, 76, 0.3); }
  .retry-btn:active { transform: scale(0.98); }
  .results-container a { color: var(--color-dkc-gold); text-decoration: underline; }
  .results-container a:hover { opacity: 0.8; }
</style>

<script is:inline>
  // Quiz data loaded async from external JSON — saves ~42KB from initial HTML
  let questionPairs = null;
  let currentQuestion = 0;
  let detectedHeresies = [];
  let selectedQuestions = [];
  let userAnswers = [];

  let questionText, progressBar, progressText, btnYes, btnNo, quizContainer;

  function esc(s) { const d = document.createElement("div"); d.textContent = s; return d.innerHTML; }

  function initializeQuestions() {
    selectedQuestions = [];
    questionPairs.forEach(function(pair) {
      const variations = pair.variations.slice();
      const numToSelect = Math.min(Math.floor(Math.random() * 2) + 2, variations.length);
      for (let i = 0; i < numToSelect; i++) {
        const randomIndex = Math.floor(Math.random() * variations.length);
        const selectedVariation = variations.splice(randomIndex, 1)[0];
        selectedQuestions.push({
          text: selectedVariation.text,
          correctAnswer: selectedVariation.correctAnswer,
          correctExplanation: selectedVariation.correctExplanation,
          heresy: pair.heresy,
          century: pair.century,
          detail: pair.detail
        });
      }
    });
    selectedQuestions.sort(function() { return Math.random() - 0.5; });
  }

  function progressBarUpdate() {
    const progress = Math.round((currentQuestion / selectedQuestions.length) * 100);
    progressBar = document.getElementById("progress-bar");
    progressText = document.getElementById("progress-text");
    if (progressBar && progressText) {
      progressBar.style.width = progress + "%";
      progressText.textContent = progress + "%";
      if (progress < 5) {
        progressText.style.left = "4px";
        progressText.style.color = "#000";
      } else {
        progressText.style.left = (progress - 4.5) + "%";
        progressText.style.color = "#fff";
      }
    }
  }

  function nextQuestion(answer) {
    const currentQ = selectedQuestions[currentQuestion];
    userAnswers.push({
      question: currentQ.text,
      userAnswer: answer,
      correctExplanation: currentQ.correctExplanation,
      correctAnswer: currentQ.correctAnswer
    });
    if ((currentQ.correctAnswer === "Iya" && answer === "Tidak") || (currentQ.correctAnswer === "Tidak" && answer === "Iya")) {
      detectedHeresies.push(currentQ);
    }
    currentQuestion++;
    progressBarUpdate();
    if (currentQuestion < selectedQuestions.length) {
      questionText.textContent = selectedQuestions[currentQuestion].text;
    } else {
      showResults();
    }
  }

  function combineHeresies(heresies) {
    const combined = {};
    heresies.forEach(function(heresy) {
      if (!combined[heresy.heresy]) {
        combined[heresy.heresy] = { heresy: heresy.heresy, century: heresy.century, details: [heresy.detail] };
      } else if (combined[heresy.heresy].details.indexOf(heresy.detail) === -1) {
        combined[heresy.heresy].details.push(heresy.detail);
      }
    });
    return Object.values(combined).sort(function(a, b) {
      const centuryA = parseInt(a.century.match(/\d+/)[0], 10);
      const centuryB = parseInt(b.century.match(/\d+/)[0], 10);
      return centuryA - centuryB;
    });
  }

  function showResults() {
    let html = "<div class=\"results-container\">";

    if (detectedHeresies.length > 1) {
      html += "<div class=\"alert-box danger\"><p>Kemungkinan besar Anda beragama Protestan yang sejati.</p></div>";
    }

    if (detectedHeresies.length === 0) {
      html += "<div class=\"alert-box success\"><h2>Selamat! Anda memiliki iman yang sehat, sesuai dengan ajaran Gereja Katolik.</h2></div>";
    } else {
      const combined = combineHeresies(detectedHeresies);
      html += "<div class=\"alert-box danger\"><h2>Berjaga-jagalah!<br>Anda terjangkit bidaah:</h2></div>";
      html += "<div class=\"mb-6\">";
      combined.forEach(function(h) {
        html += "<div class=\"heresy-card\">";
        html += "<div class=\"heresy-card-header\"><h3>" + esc(h.heresy) + "</h3><span class=\"century-badge\">" + esc(h.century) + "</span></div>";
        html += "<div class=\"heresy-card-body\">" + esc(h.details.join(" Selain itu, ")) + "</div>";
        html += "</div>";
      });
      html += "</div>";
    }

    html += "<h3 class=\"text-center mb-4 font-bold text-dkc-gold\">Hasil Jawaban Anda</h3>";
    html += "<div class=\"mb-6\">";

    userAnswers.forEach(function(qa, index) {
      const isCorrect = qa.userAnswer === qa.correctAnswer;
      const cls = isCorrect ? "correct" : "wrong";
      const label = isCorrect ? "Benar" : "Salah";
      html += "<div class=\"answer-card " + cls + "\">";
      html += "<div class=\"answer-card-header\"><span>Pertanyaan " + (index + 1) + "</span><span class=\"badge\">" + label + "</span></div>";
      html += "<div class=\"answer-card-body\">";
      html += "<h5 class=\"mb-3 font-semibold\">" + esc(qa.question) + "</h5>";
      html += "<div class=\"grid grid-cols-2 gap-2 mb-3\">";
      html += "<div class=\"user-answer\"><div class=\"answer-label\">Jawaban Anda:</div><div class=\"answer-value\">" + esc(qa.userAnswer) + "</div></div>";
      html += "<div class=\"correct-answer\"><div class=\"answer-label\">Jawaban Benar:</div><div class=\"answer-value\" style=\"color:#4caf50\">" + esc(qa.correctAnswer) + "</div></div>";
      html += "</div>";
      html += "<div class=\"explanation\"><strong>Penjelasan:</strong> " + qa.correctExplanation + "</div>";
      html += "</div></div>";
    });

    html += "</div>";

    // Reading materials
    html += "<div class=\"reading-list\">";
    html += "<div class=\"reading-list-header\">📚 Bacaan Lebih Lanjut</div>";
    html += "<a href=\"/blog/kumpulan-inspirasi-ajaran-ajaran-bidat-yang-merasuki-protestantisme\" target=\"_blank\"><span>📚</span><span>Kumpulan Inspirasi: Ajaran-ajaran Bidat yang Merasuki Protestantisme</span></a>";
    html += "<a href=\"/blog/ajaran-ajaran-sesat-dari-abad-pertama-hingga-abad-tujuh-belas\" target=\"_blank\"><span>📚</span><span>Ajaran-ajaran Sesat dari Abad Pertama hingga Abad Tujuh Belas</span></a>";
    html += "<a href=\"/blog/aliran-sesat\" target=\"_blank\"><span>📚</span><span>Aliran Sesat: Mengenal Ajaran-ajaran yang Menyimpang</span></a>";
    html += "</div>";

    // Retry button
    html += "<button class=\"retry-btn\" id=\"retry-button\">🔄 Diagnosa Ulang</button>";
    html += "</div>";

    // Link KGK references
    html = html.replace(/KGK (\d+)/g, function(match, id) {
      return "<a href=\"/katekismus?q=" + id + "\" target=\"_blank\">KGK " + id + "</a>";
    });

    quizContainer.innerHTML = html;
    document.getElementById("retry-button").addEventListener("click", resetQuiz);
  }

  function resetQuiz() {
    currentQuestion = 0;
    detectedHeresies = [];
    userAnswers = [];
    initializeQuestions();

    quizContainer.innerHTML = 
      "<h1 class=\"text-center text-2xl md:text-3xl font-bold text-dkc-gold mb-4\">DIAGNOSA AJARAN BIDAT</h1>" +
      "<h4 class=\"text-center text-dkc-muted mb-6 text-sm md:text-base leading-relaxed\">Harap baca dengan seksama dan jawab dengan jujur sesuai keyakinan iman kekristenen anda.</h4>" +
      "<div class=\"relative h-8 bg-dkc-surface rounded-full mb-6 overflow-hidden border border-dkc-border\">" +
      "<div id=\"progress-bar\" class=\"h-full rounded-full transition-all duration-300 ease-in-out\" style=\"width: 0%; background: linear-gradient(90deg, #c9a84c, #a88630);\"></div>" +
      "<div id=\"progress-text\" class=\"absolute top-1/2 -translate-y-1/2 text-sm font-bold transition-all duration-300\" style=\"left: 4px; color: #000;\">0%</div>" +
      "</div>" +
      "<div id=\"question-text\" class=\"text-center text-dkc-text text-base md:text-lg leading-relaxed mb-8 min-h-[80px] flex items-center justify-center\"></div>" +
      "<div class=\"grid grid-cols-2 gap-4 max-w-md mx-auto\">" +
      "<button id=\"btn-Iya\" class=\"py-4 rounded-xl text-lg font-bold transition-all active:scale-95 hover:brightness-110\" style=\"background: linear-gradient(135deg, #2d7d46, #1a5c2e); color: white;\">Iya [1]</button>" +
      "<button id=\"btn-Tidak\" class=\"py-4 rounded-xl text-lg font-bold transition-all active:scale-95 hover:brightness-110\" style=\"background: linear-gradient(135deg, #c0392b, #962d22); color: white;\">Tidak [2]</button>" +
      "</div>";

    questionText = document.getElementById("question-text");
    progressBar = document.getElementById("progress-bar");
    progressText = document.getElementById("progress-text");
    btnYes = document.getElementById("btn-Iya");
    btnNo = document.getElementById("btn-Tidak");

    btnYes.addEventListener("click", function() { nextQuestion("Iya"); });
    btnNo.addEventListener("click", function() { nextQuestion("Tidak"); });
    questionText.textContent = selectedQuestions[0].text;
    progressBarUpdate();
  }

  function initQuiz(data) {
    questionPairs = data;
    quizContainer = document.getElementById("quiz-container");

    // Show quiz UI, hide loading
    const loading = document.getElementById("quiz-loading");
    const quizUI = document.getElementById("quiz-ui");
    if (loading) loading.style.display = "none";
    if (quizUI) quizUI.style.display = "block";

    questionText = document.getElementById("question-text");
    progressBar = document.getElementById("progress-bar");
    progressText = document.getElementById("progress-text");
    btnYes = document.getElementById("btn-Iya");
    btnNo = document.getElementById("btn-Tidak");

    initializeQuestions();
    btnYes.addEventListener("click", function() { nextQuestion("Iya"); });
    btnNo.addEventListener("click", function() { nextQuestion("Tidak"); });
    questionText.textContent = selectedQuestions[0].text;
    progressBarUpdate();

    document.addEventListener("keydown", function(event) {
      if (event.key === "1" || event.key === "NumPad1") { nextQuestion("Iya"); }
      else if (event.key === "2" || event.key === "NumPad2") { nextQuestion("Tidak"); }
    });
  }

  // Async load quiz data — non-blocking, cacheable by CDN
  fetch("/assets/data/diagnosa-quiz.json")
    .then(function(r) { return r.json(); })
    .then(initQuiz)
    .catch(function(err) {
      console.error("Failed to load quiz data:", err);
      var loading = document.getElementById("quiz-loading");
      if (loading) loading.innerHTML = '<p class="text-red-400">Gagal memuat data quiz. Silakan refresh halaman.</p>';
    });
</script>
</BaseLayout>
