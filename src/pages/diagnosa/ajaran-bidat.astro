---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />
  
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <div class="glass-card p-6 md:p-8" id="quiz-container">
      <h1 class="text-center text-2xl md:text-3xl font-bold text-dkc-gold mb-4">DIAGNOSA AJARAN BIDAT</h1>
      <h4 class="text-center text-dkc-muted mb-6 text-sm md:text-base leading-relaxed">Harap baca dengan seksama dan jawab dengan jujur sesuai keyakinan iman kekristenan anda.</h4>
      
      <div class="relative h-8 bg-dkc-surface rounded-full mb-6 overflow-hidden border border-dkc-border">
        <div id="progress-bar" class="h-full rounded-full transition-all duration-300 ease-in-out" style="width: 0%; background: linear-gradient(90deg, #c9a84c, #a88630);"></div>
        <div id="progress-text" class="absolute top-1/2 -translate-y-1/2 text-sm font-bold transition-all duration-300" style="left: 4px; color: #000;">0%</div>
      </div>
      
      <div id="question-text" class="text-center text-dkc-text text-base md:text-lg leading-relaxed mb-8 min-h-[80px] flex items-center justify-center"></div>
      
      <div class="grid grid-cols-2 gap-4 max-w-md mx-auto">
        <button id="btn-Iya" class="py-4 rounded-xl text-lg font-bold transition-all active:scale-95 hover:brightness-110" style="background: linear-gradient(135deg, #2d7d46, #1a5c2e); color: white;">Iya [1]</button>
        <button id="btn-Tidak" class="py-4 rounded-xl text-lg font-bold transition-all active:scale-95 hover:brightness-110" style="background: linear-gradient(135deg, #c0392b, #962d22); color: white;">Tidak [2]</button>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<slot name="head">
  <title>Diagnosa Ajaran Bidat — Damai Kasih Channel</title>
  <meta name="description" content="Uji ajaran berdasarkan Katekismus Gereja Katolik." />
</slot>

<style is:global>
  .heresy-card { background: var(--color-dkc-surface); border: 1px solid #ef5350; border-radius: 0.75rem; margin-bottom: 1rem; overflow: hidden; }
  .heresy-card-header { background: linear-gradient(135deg, #c0392b, #962d22); padding: 0.75rem 1rem; display: flex; justify-content: space-between; align-items: center; }
  .heresy-card-header h3 { color: white; font-weight: 700; font-size: 1rem; margin: 0; }
  .century-badge { background: white; color: #c0392b; padding: 0.15rem 0.5rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
  .heresy-card-body { padding: 1rem; color: var(--color-dkc-text); font-size: 0.875rem; line-height: 1.6; }
  .answer-card { background: var(--color-dkc-surface); border-radius: 0.75rem; margin-bottom: 1rem; overflow: hidden; }
  .answer-card.correct { border: 1px solid #2d7d46; }
  .answer-card.wrong { border: 1px solid #c0392b; }
  .answer-card-header { padding: 0.6rem 1rem; display: flex; justify-content: space-between; align-items: center; font-weight: 600; font-size: 0.875rem; }
  .answer-card.correct .answer-card-header { background: linear-gradient(135deg, #2d7d46, #1a5c2e); color: white; }
  .answer-card.wrong .answer-card-header { background: linear-gradient(135deg, #c0392b, #962d22); color: white; }
  .answer-card-header .badge { background: white; padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.7rem; font-weight: 600; }
  .answer-card.correct .badge { color: #2d7d46; }
  .answer-card.wrong .badge { color: #c0392b; }
  .answer-card-body { padding: 1rem; font-size: 0.85rem; line-height: 1.6; color: var(--color-dkc-text); }
  .answer-card-body .user-answer, .answer-card-body .correct-answer { background: rgba(0,0,0,0.3); border-radius: 0.5rem; padding: 0.75rem; margin-bottom: 0.5rem; }
  .answer-card-body .answer-label { font-size: 0.75rem; color: var(--color-dkc-muted); margin-bottom: 0.25rem; }
  .answer-card-body .answer-value { font-weight: 700; }
  .answer-card.correct .answer-value { color: #4caf50; }
  .answer-card.wrong .answer-value { color: #ef5350; }
  .answer-card-body .explanation { color: var(--color-dkc-muted); margin-top: 0.75rem; }
  .answer-card-body .explanation strong { color: var(--color-dkc-text); }
  .alert-box { border-radius: 0.75rem; padding: 1.25rem; margin-bottom: 1.5rem; text-align: center; }
  .alert-box.danger { background: rgba(192,57,43,0.15); border: 1px solid rgba(192,57,43,0.3); color: #ef5350; }
  .alert-box.success { background: rgba(45,125,70,0.15); border: 1px solid rgba(45,125,70,0.3); color: #4caf50; }
  .alert-box.warning { background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.3); color: #c9a84c; }
  .alert-box h2, .alert-box p { margin: 0; font-weight: 700; }
  .reading-list { background: var(--color-dkc-surface); border: 1px solid var(--color-dkc-border); border-radius: 0.75rem; overflow: hidden; margin-bottom: 1.5rem; }
  .reading-list-header { background: linear-gradient(135deg, #c9a84c, #a88630); padding: 0.75rem 1rem; color: #000; font-weight: 700; }
  .reading-list a { display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1rem; color: var(--color-dkc-text); text-decoration: none; border-bottom: 1px solid var(--color-dkc-border); font-size: 0.85rem; transition: all 0.15s; }
  .reading-list a:last-child { border-bottom: none; }
  .reading-list a:hover { background: rgba(201,168,76,0.1); color: var(--color-dkc-gold); }
  .retry-btn { width: 100%; padding: 1rem; border-radius: 0.75rem; font-size: 1rem; font-weight: 700; background: linear-gradient(135deg, #c9a84c, #a88630); color: #000; border: none; cursor: pointer; transition: all 0.2s; }
  .retry-btn:hover { filter: brightness(1.1); }
  .retry-btn:active { transform: scale(0.98); }
  .results-container a { color: var(--color-dkc-gold); text-decoration: underline; }
  .results-container a:hover { opacity: 0.8; }
</style>

