---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Fragment slot="head">
    <title>Doa Malaikat Tuhan (Angelus) — Damai Kasih Channel</title>
    <meta name="description" content="Doa Malaikat Tuhan atau Angelus, doa tradisi Katolik yang didaraskan pagi, siang, dan sore untuk mengenang Inkarnasi Kristus." />
  </Fragment>
  <Navbar />

  <main class="max-w-2xl mx-auto px-4 pt-8 pb-24">
    <!-- Header -->
    <div class="text-center mb-8">
      <span class="text-4xl">🪽</span>
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mt-3">Doa Malaikat Tuhan</h1>
      <p class="text-dkc-muted text-sm mt-1">Angelus — Mengenang Inkarnasi Kristus</p>
    </div>

    <!-- Prayer Card -->
    <div class="glass-card p-6 md:p-8 mb-6">
      <div class="space-y-6 text-dkc-text leading-relaxed text-base">

        <!-- Verse 1 -->
        <div class="space-y-3">
          <p class="text-dkc-gold/80 text-sm font-semibold uppercase tracking-wider">
            V — Kabar Sukacita
          </p>
          <p class="italic text-dkc-muted text-sm">
            Maria diberi kabar oleh malaikat Tuhan, bahwa ia akan mengandung dari Roh Kudus.
          </p>
          <p>
            Salam Maria, penuh rahmat, Tuhan sertamu.
            Terpujilah engkau di antara wanita dan terpujilah buah tubuhmu, Yesus.
            Santa Maria, Bunda Allah, doakanlah kami yang berdosa ini sekarang dan pada waktu kami mati.
            <span class="text-dkc-gold font-semibold">Amin.</span>
          </p>
        </div>

        <!-- Verse 2 -->
        <div class="space-y-3">
          <p class="text-dkc-gold/80 text-sm font-semibold uppercase tracking-wider">
            V — Jawaban Maria
          </p>
          <p class="italic text-dkc-muted text-sm">
            Aku ini hamba Tuhan, terjadilah padaku menurut perkataanmu.
          </p>
          <p>
            Salam Maria, penuh rahmat, Tuhan sertamu.
            Terpujilah engkau di antara wanita dan terpujilah buah tubuhmu, Yesus.
            Santa Maria, Bunda Allah, doakanlah kami yang berdosa ini sekarang dan pada waktu kami mati.
            <span class="text-dkc-gold font-semibold">Amin.</span>
          </p>
        </div>

        <!-- Verse 3 -->
        <div class="space-y-3">
          <p class="text-dkc-gold/80 text-sm font-semibold uppercase tracking-wider">
            V — Sabda Menjadi Daging
          </p>
          <p class="italic text-dkc-muted text-sm">
            Sabda sudah menjadi daging, dan tinggal di antara kita.
          </p>
          <p>
            Salam Maria, penuh rahmat, Tuhan sertamu.
            Terpujilah engkau di antara wanita dan terpujilah buah tubuhmu, Yesus.
            Santa Maria, Bunda Allah, doakanlah kami yang berdosa ini sekarang dan pada waktu kami mati.
            <span class="text-dkc-gold font-semibold">Amin.</span>
          </p>
        </div>

        <!-- Collect -->
        <div class="space-y-3 border-t border-dkc-border/50 pt-5">
          <p class="text-dkc-gold/80 text-sm font-semibold uppercase tracking-wider">
            V — Doa Penutup
          </p>
          <p class="italic text-dkc-muted text-sm">
            Doakanlah kami, ya Santa Bunda Allah, supaya kami dapat menikmati janji Kristus.
          </p>
          <p>
            Ya Allah, karena kabar malaikat kami mengetahui bahwa Yesus Kristus Putra-Mu
            menjadi manusia; curahkanlah rahmat-Mu ke dalam hati kami, supaya karena
            sengsara dan salib-Nya, kami dibawa kepada kebangkitan yang mulia.
            Sebab Dialah Tuhan, pengantara kami.
            <span class="text-dkc-gold font-semibold">Amin.</span>
          </p>
        </div>
      </div>
    </div>

    <!-- About Card -->
    <div class="glass-card p-5 md:p-6 mb-6">
      <h2 class="text-sm font-semibold text-dkc-gold uppercase tracking-wider mb-3">
        📖 Tentang Doa Malaikat Tuhan
      </h2>
      <p class="text-dkc-muted text-sm leading-relaxed">
        Doa Malaikat Tuhan (Angelus) adalah doa Katolik yang dipanjatkan untuk mengenang
        peristiwa Inkarnasi, ketika Sabda menjadi daging dalam rahim Bunda Maria. Doa ini
        mengingatkan kita akan kerendahan hati Maria yang menerima kehendak Allah.
      </p>
      <div class="mt-3 bg-dkc-surface/50 rounded-lg p-3">
        <p class="text-dkc-muted text-xs">
          <span class="text-dkc-gold font-semibold">⏰ Waktu:</span>
          Tradisional dipanjatkan tiga kali sehari — pagi (6:00), siang (12:00), dan sore (18:00).
          Selama Masa Paskah (50 hari setelah Paskah), doa ini digantikan dengan
          <a href="/doa-ratu-surga" class="text-dkc-gold hover:underline">Doa Ratu Surga (Regina Caeli)</a>.
        </p>
      </div>
    </div>

    <!-- Share Button -->
    <div class="text-center">
      <button
        id="btn-share"
        class="px-5 py-2.5 rounded-full border border-dkc-border text-dkc-muted text-sm transition-all active:scale-95 hover:border-dkc-gold/40 hover:text-dkc-gold"
      >
        📤 Bagikan Doa
      </button>
    </div>
  </main>

  <Footer />
</BaseLayout>




<script>
  const btnShare = document.getElementById("btn-share");
  btnShare?.addEventListener("click", () => {
    const text = `🪽 Doa Malaikat Tuhan (Angelus)\n\nMaria diberi kabar oleh malaikat Tuhan, bahwa ia akan mengandung dari Roh Kudus.\n— Salam Maria...\n\nAku ini hamba Tuhan, terjadilah padaku menurut perkataanmu.\n— Salam Maria...\n\nSabda sudah menjadi daging, dan tinggal di antara kita.\n— Salam Maria...\n\nYa Allah, karena kabar malaikat kami mengetahui bahwa Yesus Kristus Putra-Mu menjadi manusia; curahkanlah rahmat-Mu ke dalam hati kami. Amin.\n\n#Angelus #DoaMalaikatTuhan #DamaiKasihChannel`;

    if (navigator.share) {
      navigator.share({ title: "Doa Malaikat Tuhan", text }).catch(() => {});
    } else {
      navigator.clipboard.writeText(text).then(() => {
        const orig = btnShare.textContent;
        btnShare.textContent = "✅ Tersalin!";
        setTimeout(() => { btnShare.textContent = orig; }, 1500);
      }).catch(() => {});
    }
  });
</script>
