---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />

  <main class="max-w-2xl mx-auto px-4 pt-8 pb-24">
    <!-- Header -->
    <div class="text-center mb-8">
      <span class="text-4xl">👑</span>
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mt-3">Doa Ratu Surga</h1>
      <p class="text-dkc-muted text-sm mt-1">Regina Caeli — Doa Masa Paskah</p>
    </div>

    <!-- Prayer Card -->
    <div class="glass-card p-6 md:p-8 mb-6">
      <div class="space-y-6 text-dkc-text leading-relaxed text-base">

        <!-- Main Prayer -->
        <div class="space-y-4 text-center">
          <p>
            Ratu Surga bersukacitalah, <span class="text-dkc-gold font-semibold">alleluya,</span><br />
            sebab Ia yang sudi kau kandung, <span class="text-dkc-gold font-semibold">alleluya,</span><br />
            telah bangkit seperti disabdakan-Nya, <span class="text-dkc-gold font-semibold">alleluya!</span><br />
            Doakanlah kami pada Allah, <span class="text-dkc-gold font-semibold">alleluya!</span>
          </p>

          <div class="border-t border-dkc-border/40 my-4"></div>

          <p>
            Bersukacita dan bergembiralah, Perawan Maria, <span class="text-dkc-gold font-semibold">alleluya,</span><br />
            sebab Tuhan sungguh telah bangkit, <span class="text-dkc-gold font-semibold">Alleluya!</span>
          </p>
        </div>

        <!-- Collect -->
        <div class="space-y-3 border-t border-dkc-border/50 pt-5">
          <p class="text-dkc-gold/80 text-sm font-semibold uppercase tracking-wider text-center">
            Doa Penutup
          </p>
          <p>
            Ya Allah, Engkau telah menggembirakan dunia dengan kebangkitan Putra-Mu,
            Tuhan kami Yesus Kristus. Kami mohon, perkenankanlah kami bersukacita
            dalam kehidupan kekal bersama Bunda-Nya, Perawan Maria.
            Demi Kristus, pengantara kami.
            <span class="text-dkc-gold font-semibold">Amin.</span>
          </p>
        </div>
      </div>
    </div>

    <!-- About Card -->
    <div class="glass-card p-5 md:p-6 mb-6">
      <h2 class="text-sm font-semibold text-dkc-gold uppercase tracking-wider mb-3">
        📖 Tentang Doa Ratu Surga
      </h2>
      <p class="text-dkc-muted text-sm leading-relaxed">
        Doa Ratu Surga (Regina Caeli) adalah doa Katolik yang dipanjatkan kepada Bunda Maria
        selama Masa Paskah (50 hari setelah Paskah). Doa ini menekankan sukacita atas
        kebangkitan Kristus dan menggantikan Doa Malaikat Tuhan (Angelus) selama periode ini.
      </p>
      <div class="mt-3 bg-dkc-surface/50 rounded-lg p-3">
        <p class="text-dkc-muted text-xs">
          <span class="text-dkc-gold font-semibold">⏰ Waktu:</span>
          Dipanjatkan tiga kali sehari selama Masa Paskah — pagi (6:00), siang (12:00), dan sore (18:00).
          Di luar Masa Paskah, gunakan
          <a href="/doa-malaikat-tuhan" class="text-dkc-gold hover:underline">Doa Malaikat Tuhan (Angelus)</a>.
        </p>
      </div>
    </div>

    <!-- Share Button -->
    <div class="text-center">
      <button
        id="btn-share"
        class="px-5 py-2.5 rounded-full border border-dkc-border text-dkc-muted text-sm transition-all active:scale-95 hover:border-dkc-gold/40 hover:text-dkc-gold"
      >
        📤 Bagikan Doa
      </button>
    </div>
  </main>

  <Footer />
</BaseLayout>

<title>Doa Ratu Surga (Regina Caeli) — Damai Kasih Channel</title>
<meta name="description" content="Doa Ratu Surga atau Regina Caeli, doa Maria dalam masa Paskah yang menggantikan Doa Malaikat Tuhan menurut tradisi Katolik." />

<script>
  const btnShare = document.getElementById("btn-share");
  btnShare?.addEventListener("click", () => {
    const text = `👑 Doa Ratu Surga (Regina Caeli)\n\nRatu Surga bersukacitalah, alleluya,\nsebab Ia yang sudi kau kandung, alleluya,\ntelah bangkit seperti disabdakan-Nya, alleluya!\nDoakanlah kami pada Allah, alleluya!\n\nBersukacita dan bergembiralah, Perawan Maria, alleluya,\nsebab Tuhan sungguh telah bangkit, Alleluya!\n\nYa Allah, Engkau telah menggembirakan dunia dengan kebangkitan Putra-Mu. Amin.\n\n#ReginaCaeli #DoaRatuSurga #DamaiKasihChannel`;

    if (navigator.share) {
      navigator.share({ title: "Doa Ratu Surga", text }).catch(() => {});
    } else {
      navigator.clipboard.writeText(text).then(() => {
        const orig = btnShare.textContent;
        btnShare.textContent = "✅ Tersalin!";
        setTimeout(() => { btnShare.textContent = orig; }, 1500);
      }).catch(() => {});
    }
  });
</script>
