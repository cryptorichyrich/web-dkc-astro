---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import fs from "fs";
import path from "path";

const allPosts = await getCollection("blog");
const sorted = allPosts
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());
const latestPosts = sorted.slice(0, 8);
const featuredPosts = sorted.filter(p => p.data.tags?.some(t => ["Apologetika", "Dogma", "Teologi"].includes(t))).slice(0, 3);

// Tag cloud: extract all tags, count occurrences, sort by count, take top 20
const tagCounts: Record<string, number> = {};
allPosts.forEach(post => {
  (post.data.tags || []).forEach((tag: string) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 20);
const maxCount = topTags.length > 0 ? topTags[0][1] : 1;
const minCount = topTags.length > 0 ? topTags[topTags.length - 1][1] : 1;

// Load rosary data for today's mystery widget
const rosaryData = JSON.parse(
  fs.readFileSync(path.resolve("public/assets/data/rosario.json"), "utf-8")
);
const dailyMysteries = rosaryData.daily_mysteries;
const days = ["sunday","monday","tuesday","wednesday","thursday","friday","saturday"];
const today = new Date();
const todayKey = days[today.getDay()];
const todayMystery = dailyMysteries[todayKey];
const mysteryData = rosaryData.mysteries[todayMystery];
const mysteryIcon = { gembira: "🌟", terang: "☀️", sedih: "💔", mulia: "👑" };
---

<BaseLayout>
  <Navbar />

  <main class="max-w-6xl mx-auto px-4 pt-8 pb-24">
    <!-- Hero -->
    <section class="text-center py-12 md:py-16">
      <img
        src="/assets/img/channels4_profile.webp"
        alt="Damai Kasih Channel"
        class="w-20 h-20 md:w-24 md:h-24 rounded-full border-2 border-dkc-gold/40 mx-auto mb-6"
      />
      <h1 class="text-3xl md:text-5xl font-bold text-dkc-gold mb-4">Damai Kasih Channel</h1>
      <p class="text-dkc-muted text-lg md:text-xl max-w-xl mx-auto">
        Sumber belajar iman Katolik — Kitab Suci, Katekismus, Doa, Apologetika
      </p>
    </section>

    <!-- Quick Access -->
    <section class="mb-10">
      <h2 class="section-title">Akses Cepat</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {[
          { href: "/kitabsuci", label: "Kitab Suci", icon: "📖", desc: "Baca & cari Alkitab" },
          { href: "/katekismus", label: "Katekismus", icon: "📜", desc: "Ajaran resmi Gereja" },
          { href: "/renungan", label: "Renungan", icon: "🙏", desc: "Renungan harian" },
          { href: "/rosario", label: "Doa Rosario", icon: "📿", desc: "Doa interaktif" },
          { href: "/kalender-liturgi", label: "Kalender Liturgi", icon: "📅", desc: "Kalender Gereja" },
          { href: "/diagnosa/ajaran-bidat", label: "Diagnosa Bidat", icon: "⚔️", desc: "Uji ajaran" },
          { href: "/jalan-salib", label: "Jalan Salib", icon: "✝️", desc: "14 perhentian" },
          { href: "/khk", label: "Hukum Kanonik", icon: "⚖️", desc: "Kitab Hukum Gereja" },
        ].map(item => (
          <a href={item.href} class="glass-card p-4 text-center transition-all active:scale-95 hover:border-dkc-gold/40">
            <span class="text-2xl">{item.icon}</span>
            <h3 class="text-dkc-gold font-semibold mt-2 text-sm">{item.label}</h3>
            <p class="text-dkc-muted text-xs mt-1">{item.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- 2-column layout: Widgets + Articles -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Main: Articles -->
      <div class="lg:col-span-2">
        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class="section-title mb-0">Artikel Terbaru</h2>
            <a href="/blog" class="text-dkc-gold text-sm hover:underline">Lihat semua →</a>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            {latestPosts.map(post => {
              const img = post.data.coverImage || post.data.thumbnailImage || post.data.heroImage;
              const date = post.data.publishedAt
                ? new Date(post.data.publishedAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })
                : '';
              return (
                <a href={`/blog/${post.id}`} class="glass-card overflow-hidden group transition-all hover:border-dkc-gold/40">
                  {img && (
                    <div class="aspect-video bg-dkc-card overflow-hidden">
                      <img
                        src={img}
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                        onerror="this.parentElement.style.display='none'"
                      />
                    </div>
                  )}
                  <div class="p-4">
                    <h3 class="text-dkc-text font-semibold text-sm leading-snug line-clamp-2 group-hover:text-dkc-gold transition-colors">
                      {post.data.title}
                    </h3>
                    <div class="flex items-center gap-2 mt-2 text-xs text-dkc-muted">
                      <span>{post.data.author}</span>
                      {date && <><span>·</span><time>{date}</time></>}
                    </div>
                    {post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1 mt-2">
                        {post.data.tags.slice(0, 3).map(tag => (
                          <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      </div>

      <!-- Sidebar: Widgets -->
      <aside class="space-y-4">

        <!-- Widget: Doa Berdasarkan Waktu -->
        <div class="glass-card p-4" id="widget-doa">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>🙏</span> Doa Berdasarkan Waktu
          </h3>
          <div id="prayer-time-display">
            <div class="text-center py-3">
              <span id="current-time" class="text-2xl font-bold text-dkc-gold"></span>
              <p id="current-period" class="text-dkc-text text-sm mt-1"></p>
              <p id="current-prayer" class="text-dkc-muted text-xs mt-1"></p>
            </div>
          </div>
          <a href="/renungan" class="block text-center text-xs text-dkc-gold hover:underline mt-2">Buka Ibadat →</a>
        </div>

        <!-- Widget: Misteri Doa Rosario (Hari Ini) -->
        <div class="glass-card p-4">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>📿</span> Misteri Rosario Hari Ini
          </h3>
          <div class="bg-dkc-surface rounded-lg p-3 mb-3">
            <div class="flex items-center gap-2">
              <span class="text-xl">{mysteryIcon[todayMystery]}</span>
              <div>
                <p class="text-dkc-gold font-semibold text-sm">{mysteryData?.title || todayMystery}</p>
                <p class="text-dkc-muted text-xs">{mysteryData?.subtitle || ''}</p>
              </div>
            </div>
          </div>
          <div class="space-y-2">
            {(mysteryData?.mysteries || []).slice(0, 5).map((m, i) => (
              <div class="flex items-start gap-2 text-xs">
                <span class="text-dkc-gold font-bold shrink-0">{m.number || i + 1}.</span>
                <p class="text-dkc-text leading-relaxed line-clamp-2">{m.title}</p>
              </div>
            ))}
          </div>
          <a href="/rosario" class="block text-center text-xs text-dkc-gold hover:underline mt-3">Doa Rosario Lengkap →</a>
        </div>

        <!-- Widget: YouTube Channel -->
        <div class="glass-card p-4">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            Damai Kasih Channel
          </h3>
          <div class="bg-dkc-surface rounded-lg p-3 flex items-center gap-3 mb-3">
            <img
              src="/assets/img/channels4_profile.webp"
              alt="DKC"
              class="w-10 h-10 rounded-full border border-dkc-border"
            />
            <div class="min-w-0 flex-1">
              <p class="text-dkc-text text-xs font-medium truncate">Damai Kasih Channel</p>
              <p class="text-dkc-muted text-[10px]">Katekese &amp; Apologetika Katolik</p>
            </div>
          </div>
          <div class="space-y-2 mb-3">
            {[
              { title: "Katekismus Gereja Katolik", thumb: "KGC" },
              { title: "Apologetika Katolik", thumb: "APO" },
              { title: "Kitab Suci & Tradisi", thumb: "KS" },
            ].map(v => (
              <a
                href="https://www.youtube.com/@DamaiKasihChannel"
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-2 bg-dkc-surface rounded-lg p-2 hover:border-dkc-gold/40 border border-dkc-border transition-colors group"
              >
                <div class="w-14 h-9 rounded bg-dkc-card flex items-center justify-center text-dkc-gold text-xs font-bold shrink-0">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                </div>
                <span class="text-dkc-text text-[11px] leading-tight line-clamp-2 group-hover:text-dkc-gold transition-colors">{v.title}</span>
              </a>
            ))}
          </div>
          <a
            href="https://www.youtube.com/@DamaiKasihChannel?sub_confirmation=1"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white text-xs font-semibold transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20H14V4H10V20ZM4 20H8V12H4V20ZM16 9V20H20V9H16Z"/></svg>
            Subscribe
          </a>
        </div>

        <!-- Widget: Tag Cloud -->
        {topTags.length > 0 && (
          <div class="glass-card p-4">
            <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
              <span>🏷️</span> Topik Populer
            </h3>
            <div class="flex flex-wrap gap-1.5">
              {topTags.map(([tag, count]) => {
                const ratio = maxCount === minCount ? 0.5 : (count - minCount) / (maxCount - minCount);
                const sizeClass = ratio > 0.75 ? 'text-base' : ratio > 0.5 ? 'text-sm' : ratio > 0.25 ? 'text-xs' : 'text-[11px]';
                const opacity = ratio > 0.5 ? 'text-dkc-gold' : 'text-dkc-muted';
                return (
                  <a
                    href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                    class={`${sizeClass} ${opacity} px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border hover:border-dkc-gold/40 hover:text-dkc-gold transition-colors`}
                  >
                    {tag}
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Widget: Social Links -->
        <div class="glass-card p-4">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>🔗</span> Ikuti Kami
          </h3>
          <div class="flex gap-3">
            <a
              href="https://t.me/DamaiKasihChannel"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 flex items-center justify-center gap-2 py-2.5 rounded-lg bg-blue-500/10 border border-blue-500/20 text-blue-400 text-xs font-medium hover:bg-blue-500/20 hover:border-blue-500/40 transition-all"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              Telegram
            </a>
            <a
              href="https://www.youtube.com/@DamaiKasihChannel"
              target="_blank"
              rel="noopener noreferrer"
              class="flex-1 flex items-center justify-center gap-2 py-2.5 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-xs font-medium hover:bg-red-500/20 hover:border-red-500/40 transition-all"
            >
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              YouTube
            </a>
          </div>
        </div>

        <!-- Widget: Artikel Pilihan -->
        <div class="glass-card p-4">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>⭐</span> Artikel Pilihan
          </h3>
          <div class="space-y-3">
            {featuredPosts.map(post => (
              <a href={`/blog/${post.id}`} class="flex gap-3 group">
                <div class="w-16 h-16 rounded-lg bg-dkc-card overflow-hidden shrink-0">
                  {(() => {
                    const img = post.data.coverImage || post.data.thumbnailImage || post.data.heroImage;
                    return img ? <img src={img} alt="" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" /> : <div class="w-full h-full flex items-center justify-center text-lg">📄</div>;
                  })()}
                </div>
                <div class="min-w-0">
                  <h4 class="text-dkc-text text-xs font-medium leading-snug line-clamp-2 group-hover:text-dkc-gold transition-colors">{post.data.title}</h4>
                  <p class="text-dkc-muted text-[10px] mt-1">{post.data.author}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Widget: Diagnosa Bidat -->
        <a href="/diagnosa/ajaran-bidat" class="glass-card p-4 block group">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-2">
            <span>⚔️</span> Diagnosa Ajaran Bidat
          </h3>
          <p class="text-dkc-muted text-xs leading-relaxed">Uji dan identifikasi apakah suatu ajaran sesuai dengan iman Katolik atau termasuk ajaran sesat.</p>
          <span class="text-dkc-gold text-xs mt-2 block group-hover:underline">Mulai diagnosa →</span>
        </a>

        <!-- Widget: Kalender Liturgi -->
        <div class="glass-card p-4" id="widget-liturgi">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>📅</span> Kalender Liturgi
          </h3>
          <div id="liturgi-today" class="text-center py-2">
            <p id="liturgi-date" class="text-dkc-gold font-semibold"></p>
            <p id="liturgi-season" class="text-dkc-text text-sm mt-1"></p>
            <p id="liturgi-color" class="text-dkc-muted text-xs mt-1"></p>
          </div>
          <a href="/kalender-liturgi" class="block text-center text-xs text-dkc-gold hover:underline mt-2">Kalender Lengkap →</a>
        </div>

      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>

<slot name="head">
  <title>Damai Kasih channel — Belajar Iman Katolik</title>
  <meta name="description" content="Sumber belajar iman Katolik Indonesia. Kitab Suci, Katekismus, Doa, Apologetika." />
</slot>

<script>
  // === DOA BERDASARKAN WAKTU ===
  const periods = [
    { name: "Laudes (Pagi)", range: [5, 8], prayer: "Ibadat Pagi — pujian pagi kepada Tuhan", icon: "🌅" },
    { name: "Tertia (Jam 9)", range: [8, 11], prayer: "Ibadat Jam Ketiga — doa tengah pagi", icon: "☀️" },
    { name: "Sexta (Siang)", range: [11, 14], prayer: "Ibadat Jam Keenam — doa tengah hari", icon: "🌞" },
    { name: "Nona (Jam 3)", range: [14, 17], prayer: "Ibadat Jam Kesembilan — doa sore", icon: "🌤" },
    { name: "Vesper (Petang)", range: [17, 20], prayer: "Ibadat Sore — pujian petang", icon: "🌇" },
    { name: "Kompletorium (Malam)", range: [20, 23], prayer: "Ibadat Penutup — doa sebelum tidur", icon: "🌙" },
    { name: "Matutinum (Tengah Malam)", range: [23, 5], prayer: "Ibadat Bacaan — doa malam hari", icon: "🌑" },
  ];

  function updatePrayerTime() {
    const now = new Date();
    const h = now.getHours();
    const m = now.getMinutes();
    const timeStr = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
    const el = document.getElementById("current-time");
    const periodEl = document.getElementById("current-period");
    const prayerEl = document.getElementById("current-prayer");
    if (el) el.textContent = timeStr;

    const period = periods.find(p => {
      if (p.range[0] < p.range[1]) return h >= p.range[0] && h < p.range[1];
      return h >= p.range[0] || h < p.range[1];
    });
    if (periodEl && period) periodEl.textContent = `${period.icon} ${period.name}`;
    if (prayerEl && period) prayerEl.textContent = period.prayer;
  }
  updatePrayerTime();
  setInterval(updatePrayerTime, 60000);

  // === KALENDER LITURGI ===
  function computeLiturgi() {
    const now = new Date();
    const months = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
    const dayNames = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
    document.getElementById("liturgi-date").textContent =
      `${dayNames[now.getDay()]}, ${now.getDate()} ${months[now.getMonth()]} ${now.getFullYear()}`;

    // Compute liturgical season based on Easter
    const year = now.getFullYear();
    function computeEaster(y) {
      const a = y % 19, b = Math.floor(y / 100), c = y % 100;
      const d = Math.floor(b / 4), e = b % 4, f = Math.floor((b + 8) / 25);
      const g = Math.floor((b - f + 1) / 3), h = (19 * a + b - d - g + 15) % 30;
      const i = Math.floor(c / 4), k = c % 4, l = (32 + 2 * e + 2 * i - h - k) % 7;
      const m = Math.floor((a + 11 * h + 22 * l) / 451);
      const month = Math.floor((h + l - 7 * m + 114) / 31);
      const day = ((h + l - 7 * m + 114) % 31) + 1;
      return new Date(y, month - 1, day);
    }
    const easter = computeEaster(year);
    const ashWednesday = new Date(easter); ashWednesday.setDate(easter.getDate() - 46);
    const christmas = new Date(year, 11, 25);
    const adventStart = new Date(christmas); adventStart.setDate(christmas.getDate() - (christmas.getDay() === 0 ? 28 : 21 + christmas.getDay()));

    let season = "Waktu Biasa";
    let color = "Hijau";
    if (now >= ashWednesday && now < easter) {
      season = "Prapaskah"; color = "Ungu";
    } else if (now >= easter && now < new Date(easter.getTime() + 50 * 86400000)) {
      season = "Paskah"; color = "Putih";
    } else if (now >= adventStart && now < christmas) {
      season = "Adven"; color = "Ungu";
    } else if (now >= christmas && now < new Date(year, 0, 6)) {
      season = "Natal"; color = "Putih";
    }
    // Christmas to Epiphany
    if (now.getMonth() === 11 && now.getDate() >= 25 || (now.getMonth() === 0 && now.getDate() <= 6)) {
      season = "Natal"; color = "Putih";
    }

    document.getElementById("liturgi-season").textContent = season;
    document.getElementById("liturgi-color").textContent = `Warna liturgi: ${color}`;
  }
  computeLiturgi();
</script>
