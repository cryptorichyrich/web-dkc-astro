---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import fs from "fs";
import path from "path";

const allPosts = await getCollection("blog");
const sorted = allPosts
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());
const latestPosts = sorted.slice(0, 8);
const featuredPosts = sorted.filter(p => p.data.featured).slice(0, 5);
const fallbackFeatured = featuredPosts.length > 0 ? featuredPosts : sorted.filter(p => p.data.tags?.some(t => ["Apologetika", "Dogma", "Teologi"].includes(t))).slice(0, 5);

// Tag cloud: extract all tags, count occurrences, sort by count, take top 20
const tagCounts: Record<string, number> = {};
allPosts.forEach(post => {
  (post.data.tags || []).forEach((tag: string) => {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  });
});
const topTags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 20);
const maxCount = topTags.length > 0 ? topTags[0][1] : 1;
const minCount = topTags.length > 0 ? topTags[topTags.length - 1][1] : 1;

// Load rosary data for today's mystery widget
const rosaryData = JSON.parse(
  fs.readFileSync(path.resolve("public/assets/data/rosario.json"), "utf-8")
);
const dailyMysteries = rosaryData.daily_mysteries;
const days = ["sunday","monday","tuesday","wednesday","thursday","friday","saturday"];
const today = new Date();
const todayKey = days[today.getDay()];
const todayMystery = dailyMysteries[todayKey];
const mysteryData = rosaryData.mysteries[todayMystery];
const mysteryIcon = { gembira: "🌟", terang: "☀️", sedih: "💔", mulia: "👑" };
---

<BaseLayout>
  <Navbar />

  <main class="max-w-6xl mx-auto px-4 pb-24">
    <!-- Hero -->
    <section class="text-center py-6 md:py-12 pt-4 md:pt-8">
      <p class="text-dkc-gold/80 font-serif text-lg md:text-2xl italic tracking-wide">Ad Maiorem Dei Gloriam</p>
      <p class="text-dkc-muted text-xs mt-2 tracking-[0.15em] uppercase">Untuk Kemuliaan yang Lebih Besar Allah</p>
    </section>

    <!-- Quick Access -->
    <section class="mb-10">
      <h2 class="section-title">Akses Cepat</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {[
          { href: "/kitabsuci", label: "Kitab Suci", icon: "📖", desc: "Baca & cari Alkitab" },
          { href: "/katekismus", label: "Katekismus", icon: "📜", desc: "Ajaran resmi Gereja" },
          { href: "/renungan", label: "Renungan", icon: "🙏", desc: "Renungan harian" },
          { href: "/rosario", label: "Doa Rosario", icon: "📿", desc: "Doa interaktif" },
          { href: "/kalender-liturgi", label: "Kalender Liturgi", icon: "📅", desc: "Kalender Gereja" },
          { href: "/diagnosa/ajaran-bidat", label: "Diagnosa Bidat", icon: "⚔️", desc: "Uji ajaran" },
          { href: "/jalan-salib", label: "Jalan Salib", icon: "✝️", desc: "14 perhentian" },
          { href: "/khk", label: "Hukum Kanonik", icon: "⚖️", desc: "Kitab Hukum Gereja" },
        ].map(item => (
          <a href={item.href} class="glass-card p-4 text-center transition-all active:scale-95 hover:border-dkc-gold/40">
            <span class="text-2xl">{item.icon}</span>
            <h3 class="text-dkc-gold font-semibold mt-2 text-sm">{item.label}</h3>
            <p class="text-dkc-muted text-xs mt-1">{item.desc}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- 2-column layout: Widgets + Articles -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <!-- Main: Articles -->
      <div class="lg:col-span-2">
        <section>
          <div class="flex items-center justify-between mb-4">
            <h2 class="section-title mb-0">Artikel Terbaru</h2>
            <a href="/blog" class="text-dkc-gold text-sm hover:underline">Lihat semua →</a>
          </div>
          <div class="grid gap-4 md:grid-cols-2">
            {latestPosts.map(post => {
              const img = post.data.coverImage || post.data.thumbnailImage || post.data.heroImage;
              const date = post.data.publishedAt
                ? new Date(post.data.publishedAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })
                : '';
              return (
                <a href={`/blog/${post.id}`} class="glass-card overflow-hidden group transition-all hover:border-dkc-gold/40">
                  {img && (
                    <div class="aspect-video bg-dkc-card overflow-hidden">
                      <img
                        src={img}
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                        onerror="this.parentElement.style.display='none'"
                      />
                    </div>
                  )}
                  <div class="p-4">
                    <h3 class="text-dkc-text font-semibold text-sm leading-snug line-clamp-2 group-hover:text-dkc-gold transition-colors">
                      {post.data.title}
                    </h3>
                    <div class="flex items-center gap-2 mt-2 text-xs text-dkc-muted">
                      <span>{post.data.author}</span>
                      {date && <><span>·</span><time>{date}</time></>}
                    </div>
                    {post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-1 mt-2">
                        {post.data.tags.slice(0, 3).map(tag => (
                          <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      </div>

      <!-- Sidebar: Widgets -->
      <aside class="space-y-4">

        <!-- Widget: Doa Berdasarkan Waktu -->
        <div class="glass-card p-4" id="widget-doa">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>🕊️</span> Doa Berdasarkan Waktu
          </h3>
          <div id="prayer-time-display">
            <!-- Current WIB time -->
            <div class="text-center mb-3">
              <span id="wib-time" class="text-2xl font-bold text-dkc-gold font-mono tracking-wider"></span>
              <p class="text-dkc-muted text-[10px] mt-0.5">WIB (GMT+7)</p>
            </div>
            <!-- Current prayer status -->
            <div id="prayer-status" class="bg-dkc-surface rounded-lg p-3 mb-3">
              <div id="prayer-active" class="hidden">
                <p id="prayer-label" class="text-dkc-gold font-semibold text-sm"></p>
                <p id="prayer-time-range" class="text-dkc-muted text-[10px] mt-0.5"></p>
                <a id="prayer-link" href="#" class="inline-block mt-2 px-3 py-1 rounded-full bg-dkc-gold/10 border border-dkc-gold/30 text-dkc-gold text-xs font-medium hover:bg-dkc-gold/20 transition-colors">📖 Baca Doa</a>
              </div>
              <div id="prayer-countdown" class="hidden text-center">
                <p id="countdown-label" class="text-dkc-text text-xs"></p>
                <p id="countdown-timer" class="text-dkc-gold text-lg font-bold mt-1"></p>
              </div>
            </div>
            <!-- Next prayer -->
            <div class="text-center py-2 border-t border-dkc-border/40 mt-2">
              <p class="text-dkc-muted text-[9px] uppercase tracking-wider">Doa Berikutnya</p>
              <p id="next-prayer-name" class="text-dkc-gold text-xs font-medium mt-0.5"></p>
              <p id="next-prayer-time" class="text-dkc-text text-[11px] mt-0.5"></p>
            </div>
            <!-- All prayer times for today -->
            <div class="grid grid-cols-2 gap-2 text-center" id="prayer-schedule">
              <a href="/doa-malaikat-tuhan/" class="prayer-slot bg-dkc-surface/60 rounded-lg p-2 hover:bg-dkc-gold/10 transition-colors" data-hour="6">
                <span class="text-xs">06:00</span>
                <p class="text-[10px] text-dkc-muted mt-0.5 prayer-slot-name">Angelus</p>
              </a>
              <a href="/doa-malaikat-tuhan/" class="prayer-slot bg-dkc-surface/60 rounded-lg p-2 hover:bg-dkc-gold/10 transition-colors" data-hour="12">
                <span class="text-xs">12:00</span>
                <p class="text-[10px] text-dkc-muted mt-0.5 prayer-slot-name">Angelus</p>
              </a>
              <a href="/koronka-kerahiman-ilahi/" class="prayer-slot bg-dkc-surface/60 rounded-lg p-2 hover:bg-dkc-gold/10 transition-colors" data-hour="15">
                <span class="text-xs">15:00</span>
                <p class="text-[10px] text-dkc-muted mt-0.5 prayer-slot-name">Koronka</p>
              </a>
              <a href="/doa-malaikat-tuhan/" class="prayer-slot bg-dkc-surface/60 rounded-lg p-2 hover:bg-dkc-gold/10 transition-colors" data-hour="18">
                <span class="text-xs">18:00</span>
                <p class="text-[10px] text-dkc-muted mt-0.5 prayer-slot-name">Angelus</p>
              </a>
            </div>
          </div>
        </div>

        <!-- Widget: Misteri Doa Rosario (Hari Ini) -->
        <div class="glass-card p-4">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>📿</span> Misteri Rosario Hari Ini
          </h3>
          <div class="bg-dkc-surface rounded-lg p-3 mb-3">
            <div class="flex items-center gap-2">
              <span class="text-xl">{mysteryIcon[todayMystery]}</span>
              <div>
                <p class="text-dkc-gold font-semibold text-sm">{mysteryData?.title || todayMystery}</p>
                <p class="text-dkc-muted text-xs">{mysteryData?.subtitle || ''}</p>
              </div>
            </div>
          </div>
          <div class="space-y-2">
            {(mysteryData?.mysteries || []).slice(0, 5).map((m, i) => (
              <div class="flex items-start gap-2 text-xs">
                <span class="text-dkc-gold font-bold shrink-0">{m.number || i + 1}.</span>
                <p class="text-dkc-text leading-relaxed line-clamp-2">{m.title}</p>
              </div>
            ))}
          </div>
          <a href="/rosario" class="block text-center text-xs text-dkc-gold hover:underline mt-3">Doa Rosario Lengkap →</a>
        </div>


        <!-- Widget: Kalender Liturgi -->
        <div class="glass-card p-4" id="widget-liturgi">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>📅</span> Kalender Liturgi
          </h3>
          <div id="liturgi-today">
            <p id="liturgi-date" class="text-dkc-gold font-semibold text-sm mb-2"></p>
            <div class="space-y-1.5 text-xs">
              <div id="liturgi-perayaan-wrap" class="hidden">
                <span class="text-dkc-muted">Perayaan</span>
                <p id="liturgi-perayaan" class="text-dkc-text font-medium"></p>
              </div>
              <div id="liturgi-bacaan-wrap" class="hidden">
                <span class="text-dkc-muted">Bacaan</span>
                <p id="liturgi-bacaan" class="text-dkc-text leading-relaxed"></p>
              </div>
              <div id="liturgi-bco-wrap" class="hidden">
                <span class="text-dkc-muted">BcO</span>
                <p id="liturgi-bco" class="text-dkc-text"></p>
              </div>
              <div>
                <span class="text-dkc-muted">Warna Liturgi</span>
                <p id="liturgi-color" class="text-dkc-text font-medium flex items-center gap-1.5">
                  <span id="liturgi-color-dot" class="w-2.5 h-2.5 rounded-full inline-block"></span>
                  <span id="liturgi-color-text"></span>
                </p>
              </div>
            </div>
          </div>
          <a href="/kalender-liturgi" class="block text-center text-xs text-dkc-gold hover:underline mt-3 pt-2 border-t border-dkc-border/30">📅 Kalender Lengkap →</a>
          <div class="text-center mt-1">
            <a id="liturgi-renungan-link" href="#" target="_blank" class="hidden text-xs text-dkc-gold hover:underline">📿 Baca Renungan Hari Ini →</a>
          </div>
        </div>


        <!-- Widget: YouTube Channel -->
        <div class="glass-card p-4">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            Damai Kasih Channel
          </h3>
          <div class="bg-dkc-surface rounded-lg p-3 flex items-center gap-3 mb-3">
            <img
              src="/assets/img/channels4_profile.webp"
              alt="DKC"
              class="w-10 h-10 rounded-full border border-dkc-border"
            />
            <div class="min-w-0 flex-1">
              <p class="text-dkc-text text-xs font-medium truncate">Damai Kasih Channel</p>
              <p class="text-dkc-muted text-[10px]">Katekese &amp; Apologetika Katolik</p>
            </div>
          </div>
          <a
            href="https://www.youtube.com/@DamaiKasihChannel?sub_confirmation=1"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full py-2 rounded-lg bg-red-600 hover:bg-red-700 text-white text-xs font-semibold transition-colors"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M10 20H14V4H10V20ZM4 20H8V12H4V20ZM16 9V20H20V9H16Z"/></svg>
            Subscribe
          </a>
          <a
            href="https://www.youtube.com/@DamaiKasihChannel"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full py-2 mt-2 rounded-lg bg-dkc-surface border border-dkc-border hover:border-dkc-gold/40 text-dkc-gold text-xs font-semibold transition-colors"
          >
            Kunjungi Channel →
          </a>
        </div>

        <!-- Widget: Tag Cloud -->
        {topTags.length > 0 && (
          <div class="glass-card p-4">
            <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
              <span>🏷️</span> Topik Populer
            </h3>
            <div class="flex flex-wrap gap-1.5">
              {topTags.map(([tag, count]) => {
                const ratio = maxCount === minCount ? 0.5 : (count - minCount) / (maxCount - minCount);
                const sizeClass = ratio > 0.75 ? 'text-base' : ratio > 0.5 ? 'text-sm' : ratio > 0.25 ? 'text-xs' : 'text-[11px]';
                const opacity = ratio > 0.5 ? 'text-dkc-gold' : 'text-dkc-muted';
                return (
                  <a
                    href={`/blog/tag/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                    class={`${sizeClass} ${opacity} px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border hover:border-dkc-gold/40 hover:text-dkc-gold transition-colors`}
                  >
                    {tag}
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <!-- Widget: Social Links -->
        <div class="glass-card p-4">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>🔗</span> Ikuti Kami
          </h3>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
            <!-- YouTube -->
            <a
              href="https://www.youtube.com/@damaikasihchannel9153"
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center justify-center gap-1.5 py-3 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 hover:bg-red-500/20 hover:border-red-500/40 transition-all group"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              <span class="text-[10px] font-medium">YouTube</span>
            </a>
            <!-- Instagram -->
            <a
              href="https://www.instagram.com/damaikasihchannel"
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center justify-center gap-1.5 py-3 rounded-lg bg-pink-500/10 border border-pink-500/20 text-pink-400 hover:bg-pink-500/20 hover:border-pink-500/40 transition-all group"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
              <span class="text-[10px] font-medium">Instagram</span>
            </a>
            <!-- TikTok -->
            <a
              href="https://www.tiktok.com/@dkc_team.apologetik"
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-col items-center justify-center gap-1.5 py-3 rounded-lg bg-white/5 border border-white/10 text-white/70 hover:bg-white/10 hover:border-white/20 transition-all group"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
              <span class="text-[10px] font-medium">TikTok</span>
            </a>
            <!-- Email -->
            <a
              href="mailto:damaikasihchannel@gmail.com"
              class="flex flex-col items-center justify-center gap-1.5 py-3 rounded-lg bg-amber-500/10 border border-amber-500/20 text-amber-400 hover:bg-amber-500/20 hover:border-amber-500/40 transition-all group"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              <span class="text-[10px] font-medium">Email</span>
            </a>
          </div>
        </div>

        <!-- Widget: Artikel Pilihan -->
        <div class="glass-card p-4">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-3">
            <span>⭐</span> Artikel Pilihan
          </h3>
          <div class="space-y-3">
            {fallbackFeatured.map(post => (
              <a href={`/blog/${post.id}`} class="flex gap-3 group">
                <div class="w-16 h-16 rounded-lg bg-dkc-card overflow-hidden shrink-0">
                  {(() => {
                    const img = post.data.coverImage || post.data.thumbnailImage || post.data.heroImage;
                    return img ? <img src={img} alt="" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" /> : <div class="w-full h-full flex items-center justify-center text-lg">📄</div>;
                  })()}
                </div>
                <div class="min-w-0">
                  <h4 class="text-dkc-text text-xs font-medium leading-snug line-clamp-2 group-hover:text-dkc-gold transition-colors">{post.data.title}</h4>
                  <p class="text-dkc-muted text-[10px] mt-1">{post.data.author}</p>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Widget: Diagnosa Bidat -->
        <a href="/diagnosa/ajaran-bidat" class="glass-card p-4 block group">
          <h3 class="text-dkc-gold font-semibold text-sm flex items-center gap-2 mb-2">
            <span>⚔️</span> Diagnosa Ajaran Bidat
          </h3>
          <p class="text-dkc-muted text-xs leading-relaxed">Uji dan identifikasi apakah suatu ajaran sesuai dengan iman Katolik atau termasuk ajaran sesat.</p>
          <span class="text-dkc-gold text-xs mt-2 block group-hover:underline">Mulai diagnosa →</span>
        </a>


      </aside>
    </div>
  </main>

  <Footer />
</BaseLayout>

<slot name="head">
  <title>Damai Kasih channel — Belajar Iman Katolik</title>
  <meta name="description" content="Sumber belajar iman Katolik Indonesia. Kitab Suci, Katekismus, Doa, Apologetika." />
</slot>

<script>
  // === DOA BERDASARKAN WAKTU (GMT+7 / WIB) ===
  // Computus: calculate Easter Sunday for a given year
  function computeEasterForPrayer(y) {
    const a = y % 19, b = Math.floor(y / 100), c = y % 100;
    const d = Math.floor(b / 4), e = b % 4, f = Math.floor((b + 8) / 25);
    const g = Math.floor((b - f + 1) / 3), h = (19 * a + b - d - g + 15) % 30;
    const i = Math.floor(c / 4), k = c % 4, l = (32 + 2 * e + 2 * i - h - k) % 7;
    const m = Math.floor((a + 11 * h + 22 * l) / 451);
    const month = Math.floor((h + l - 7 * m + 114) / 31);
    const day = ((h + l - 7 * m + 114) % 31) + 1;
    return new Date(y, month - 1, day);
  }

  function isEasterSeason(now) {
    const year = now.getFullYear();
    const easter = computeEasterForPrayer(year);
    const easterEnd = new Date(easter.getTime() + 50 * 86400000); // Easter + 50 days = Pentecost
    return now >= easter && now <= easterEnd;
  }

  function updatePrayerTime() {
    const now = new Date();
    // Convert to WIB (GMT+7)
    const utc = now.getTime() + (now.getTimezoneOffset() * 60000);
    const wib = new Date(utc + (7 * 3600000));
    const h = wib.getHours();
    const m = wib.getMinutes();
    const s = wib.getSeconds();
    const timeStr = `${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;

    // Display current WIB time
    const timeEl = document.getElementById("wib-time");
    if (timeEl) timeEl.textContent = timeStr;

    const easter = isEasterSeason(wib);

    // Define prayer times (hour in WIB)
    const prayers = [
      { hour: 6,  name: easter ? "Regina Caeli (Ratu Surga)" : "Doa Malaikat Tuhan (Angelus)",
        shortName: easter ? "Regina Caeli" : "Angelus",
        link: easter ? "/doa-ratu-surga/" : "/doa-malaikat-tuhan/",
        icon: "🕊️" },
      { hour: 12, name: easter ? "Regina Caeli (Ratu Surga)" : "Doa Malaikat Tuhan (Angelus)",
        shortName: easter ? "Regina Caeli" : "Angelus",
        link: easter ? "/doa-ratu-surga/" : "/doa-malaikat-tuhan/",
        icon: "☀️" },
      { hour: 15, name: "Koronka Kerahiman Ilahi",
        shortName: "Koronka",
        link: "/koronka-kerahiman-ilahi/",
        icon: "💙" },
      { hour: 18, name: easter ? "Regina Caeli (Ratu Surga)" : "Doa Malaikat Tuhan (Angelus)",
        shortName: easter ? "Regina Caeli" : "Angelus",
        link: easter ? "/doa-ratu-surga/" : "/doa-malaikat-tuhan/",
        icon: "🌅" },
    ];

    // Current time in minutes since midnight (WIB)
    const currentMinutes = h * 60 + m;

    // Check if we're at an active prayer time (±10 minute window, with 5 min grace after)
    let activePrayer = null;
    for (const p of prayers) {
      const prayerMinutes = p.hour * 60;
      const diff = currentMinutes - prayerMinutes;
      if (diff >= 0 && diff <= 10) {
        activePrayer = p;
        break;
      }
    }

    // Find the next upcoming prayer
    let nextPrayer = null;
    for (const p of prayers) {
      const prayerMinutes = p.hour * 60;
      if (prayerMinutes > currentMinutes) {
        nextPrayer = p;
        break;
      }
    }
    if (!nextPrayer) {
      // Wrap to first prayer of tomorrow
      nextPrayer = { ...prayers[0], hour: prayers[0].hour + 24 };
    }

    // Update UI
    const activeDiv = document.getElementById("prayer-active");
    const countdownDiv = document.getElementById("prayer-countdown");
    const nextNameEl = document.getElementById("next-prayer-name");
    const nextTimeEl = document.getElementById("next-prayer-time");

    if (activePrayer) {
      // Show active prayer with "Baca Doa" link
      if (activeDiv) activeDiv.classList.remove("hidden");
      if (countdownDiv) countdownDiv.classList.add("hidden");
      const labelEl = document.getElementById("prayer-label");
      const rangeEl = document.getElementById("prayer-time-range");
      const linkEl = document.getElementById("prayer-link");
      if (labelEl) labelEl.innerHTML = `${activePrayer.icon} <a href="${activePrayer.link}" class="underline hover:text-dkc-gold/80">${activePrayer.shortName}</a>`;
      if (rangeEl) rangeEl.innerHTML = `Sekarang waktunya doa <a href="${activePrayer.link}" class="underline hover:text-dkc-gold/80">${activePrayer.shortName}</a>`;
      if (linkEl) linkEl.href = activePrayer.link;
    } else {
      // Show countdown to next prayer
      if (activeDiv) activeDiv.classList.add("hidden");
      if (countdownDiv) countdownDiv.classList.remove("hidden");
      const countLabel = document.getElementById("countdown-label");
      const countTimer = document.getElementById("countdown-timer");
      if (countLabel) countLabel.innerHTML = `Menuju <a href="${nextPrayer.link}" class="text-dkc-gold underline hover:text-dkc-gold/80">${nextPrayer.shortName}</a>`;
      const nextMinutes = nextPrayer.hour * 60;
      const remainingMinutes = nextMinutes - currentMinutes;
      if (remainingMinutes <= 0) {
        if (countTimer) countTimer.textContent = "Sebentar lagi";
      } else {
        const remH = Math.floor(remainingMinutes / 60);
        const remM = remainingMinutes % 60;
        if (countTimer) {
          if (remH > 0) {
            countTimer.textContent = `${remH}j ${remM}m lagi`;
          } else {
            countTimer.textContent = `${remM} menit lagi`;
          }
        }
      }
    }

    // Always show the next prayer
    if (nextNameEl) nextNameEl.innerHTML = `${nextPrayer.icon} <a href="${nextPrayer.link}" class="underline hover:text-dkc-gold/80">${nextPrayer.shortName}</a>`;
    if (nextTimeEl) {
      const displayHour = nextPrayer.hour % 24;
      nextTimeEl.textContent = `Pukul ${String(displayHour).padStart(2,'0')}:00 WIB`;
    }

    // --- Highlight active prayer slot ---
    const allSlots = document.querySelectorAll('.prayer-slot');
    allSlots.forEach(slot => {
      slot.classList.remove('border', 'border-dkc-gold/50', 'bg-dkc-gold/10');
    });
    if (activePrayer) {
      const activeSlot = document.querySelector(`.prayer-slot[data-hour="${activePrayer.hour}"]`);
      if (activeSlot) {
        activeSlot.classList.add('border', 'border-dkc-gold/50', 'bg-dkc-gold/10');
      }
    }

    // --- Update Angelus slots for Easter season ---
    const angelusHours = [6, 12, 18];
    angelusHours.forEach(hr => {
      const slot = document.querySelector(`.prayer-slot[data-hour="${hr}"]`);
      if (!slot) return;
      const nameEl = slot.querySelector('.prayer-slot-name');
      if (easter) {
        if (nameEl) nameEl.textContent = 'Regina Caeli';
        slot.setAttribute('href', '/doa-ratu-surga/');
      } else {
        if (nameEl) nameEl.textContent = 'Angelus';
        slot.setAttribute('href', '/doa-malaikat-tuhan/');
      }
    });
  }
  updatePrayerTime();
  setInterval(updatePrayerTime, 1000);

  // === KALENDER LITURGI ===
  const MONTHS_ID = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
  const DAYS_ID = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
  const WARNA_DOT = {
    'Putih':'bg-white/80','Hijau':'bg-green-500','Ungu':'bg-purple-500',
    'Merah':'bg-red-500','Merah Muda':'bg-rose-300','Hitam':'bg-gray-700','Emas':'bg-yellow-400',
  };

  // --- Bacaan-to-links parser (shared with kalender-liturgi page) ---
  function processVerseRange(book, chapter, verseRange) {
    var crossMatch = verseRange.match(/^(\d+[a-z]?)-(\d+):(\d+[a-z]?)$/i);
    if (crossMatch) {
      return { parts: [book+chapter+':'+crossMatch[1]+'-999', book+crossMatch[2]+':1-'+crossMatch[3]], newChapter: crossMatch[2] };
    }
    var newChMatch = verseRange.match(/^(\d+):(\S+)$/i);
    if (newChMatch) {
      var newCh = newChMatch[1], vs = newChMatch[2];
      var innerCross = vs.match(/^(\d+[a-z]?)-(\d+):(\d+[a-z]?)$/i);
      if (innerCross) {
        return { parts: [book+newCh+':'+innerCross[1]+'-999', book+innerCross[2]+':1-'+innerCross[3]], newChapter: innerCross[2] };
      }
      return { parts: [book+newCh+':'+vs], newChapter: newCh };
    }
    return { parts: [book+chapter+':'+verseRange], newChapter: null };
  }

  function parseBacaanToLinks(bacaan) {
    if (!bacaan) return '';
    var parts = bacaan.split(';');
    var linked = [];
    var lastBook = null;
    for (var i = 0; i < parts.length; i++) {
      var trimmed = parts[i].trim();
      if (!trimmed || trimmed === '.') continue;
      var match = trimmed.match(/^([a-z]+\.?)\s*(\d+):(\S+)/i);
      if (match) {
        var book = match[1].replace('.', '').toLowerCase();
        var chapter = match[2];
        var verses = match[3];
        lastBook = book;
        var verseRanges = verses.split(',').map(function(v){return v.trim();});
        var queryParts = [];
        var currentCh = chapter;
        for (var j = 0; j < verseRanges.length; j++) {
          var result = processVerseRange(book, currentCh, verseRanges[j]);
          queryParts = queryParts.concat(result.parts);
          if (result.newChapter) currentCh = result.newChapter;
        }
        linked.push('<a href="/kitabsuci/pbtb2/?q='+encodeURIComponent(queryParts.join(';'))+'" class="text-dkc-gold hover:underline" target="_blank">'+trimmed+'</a>');
      } else {
        var contMatch = trimmed.match(/^(\d+):(\S+)/i);
        if (contMatch && lastBook) {
          var chapter2 = contMatch[1], verses2 = contMatch[2];
          var verseRanges2 = verses2.split(',').map(function(v){return v.trim();});
          var queryParts2 = [];
          var currentCh2 = chapter2;
          for (var k = 0; k < verseRanges2.length; k++) {
            var result2 = processVerseRange(lastBook, currentCh2, verseRanges2[k]);
            queryParts2 = queryParts2.concat(result2.parts);
            if (result2.newChapter) currentCh2 = result2.newChapter;
          }
          linked.push('<a href="/kitabsuci/pbtb2/?q='+encodeURIComponent(queryParts2.join(';'))+'" class="text-dkc-gold hover:underline" target="_blank">'+trimmed+'</a>');
        } else {
          linked.push(trimmed);
        }
      }
    }
    return linked.join('; ');
  }

  // --- Renungan lookup ---
  var renunganIndex = [];
  async function loadRenunganIndex() {
    try {
      var res = await fetch('/assets/data/renungan-index.json');
      if (res.ok) renunganIndex = await res.json();
    } catch(e) { console.warn('Renungan index:', e); }
  }
  loadRenunganIndex();

  function findTodayRenungan() {
    var now = new Date();
    var key = now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(now.getDate()).padStart(2,'0');
    for (var i = 0; i < renunganIndex.length; i++) {
      if (renunganIndex[i].date === key) return renunganIndex[i];
    }
    return null;
  }

  async function loadLiturgiWidget() {
    var now = new Date();
    var key = now.getFullYear()+'-'+String(now.getMonth()+1).padStart(2,'0')+'-'+String(now.getDate()).padStart(2,'0');

    // Date header
    document.getElementById("liturgi-date").textContent =
      DAYS_ID[now.getDay()]+', '+now.getDate()+' '+MONTHS_ID[now.getMonth()]+' '+now.getFullYear();

    // Try loading from JSON
    try {
      const res = await fetch('/assets/data/liturgical-' + now.getFullYear() + '.json');
      if (!res.ok) throw new Error('no data');
      const data = await res.json();
      const info = data[key];

      if (info) {
        // Perayaan
        if (info.perayaan) {
          document.getElementById('liturgi-perayaan-wrap').classList.remove('hidden');
          document.getElementById('liturgi-perayaan').textContent = info.perayaan;
        }
        // Bacaan
        if (info.bacaan) {
          document.getElementById('liturgi-bacaan-wrap').classList.remove('hidden');
          document.getElementById('liturgi-bacaan').innerHTML = parseBacaanToLinks(info.bacaan);
        }
        // BcO
        if (info.bco) {
          document.getElementById('liturgi-bco-wrap').classList.remove('hidden');
          document.getElementById('liturgi-bco').innerHTML = parseBacaanToLinks(info.bco);
        }
        // Warna liturgi
        const warna = info.warna || 'Hijau';
        document.getElementById('liturgi-color-text').textContent = 'Warna Liturgi ' + warna;
        const dot = document.getElementById('liturgi-color-dot');
        dot.className = 'w-2.5 h-2.5 rounded-full inline-block ' + (WARNA_DOT[warna] || 'bg-dkc-muted');

        // Renungan link
        const renungan = findTodayRenungan();
        const renunganEl = document.getElementById('liturgi-renungan-link');
        if (renungan) {
          renunganEl.href = renungan.url;
          renunganEl.classList.remove('hidden');
        } else if (renunganEl) {
          renunganEl.classList.add('hidden');
        }

        return;
      }
    } catch(e) { console.warn('Liturgical data unavailable:', e); }

    // Fallback: computed season
    function computeEaster(y) {
      const a=y%19,b=Math.floor(y/100),c=y%100,d=Math.floor(b/4),e=b%4,f=Math.floor((b+8)/25);
      const g=Math.floor((b-f+1)/3),h=(19*a+b-d-g+15)%30,i=Math.floor(c/4),k=c%4;
      const l=(32+2*e+2*i-h-k)%7,m=Math.floor((a+11*h+22*l)/451);
      return new Date(y,Math.floor((h+l-7*m+114)/31)-1,((h+l-7*m+114)%31)+1);
    }
    const easter=computeEaster(now.getFullYear());
    const ashWed=new Date(easter);ashWed.setDate(easter.getDate()-46);
    const pent=new Date(easter);pent.setDate(easter.getDate()+49);
    const xmas=new Date(now.getFullYear(),11,25);
    const adv1=new Date(xmas);adv1.setDate(xmas.getDate()-(xmas.getDay()===0?28:21+xmas.getDay()));
    let season='Waktu Biasa',warna='Hijau';
    if(now>=ashWed&&now<easter){season='Prapaskah';warna='Ungu';}
    else if(now>=easter&&now<pent){season='Masa Paskah';warna='Putih';}
    else if(now>=adv1&&now<xmas){season='Adven';warna='Ungu';}
    else if((now.getMonth()===11&&now.getDate()>=25)||(now.getMonth()===0&&now.getDate()<=6)){season='Masa Natal';warna='Putih';}
    document.getElementById('liturgi-perayaan-wrap').classList.remove('hidden');
    document.getElementById('liturgi-perayaan').textContent = season;
    document.getElementById('liturgi-color-text').textContent = 'Warna Liturgi ' + warna;
    document.getElementById('liturgi-color-dot').className = 'w-2.5 h-2.5 rounded-full inline-block ' + (WARNA_DOT[warna]||'bg-dkc-muted');
  }
  loadLiturgiWidget();
</script>