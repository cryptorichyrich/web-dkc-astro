---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Fragment slot="head">
    <title>Greek Interlinear NT — Damai Kasih Channel</title>
    <meta name="description" content="Read the Greek New Testament with interlinear English translation and transliteration. Novum Testamentum Graece." />
  </Fragment>
  <Navbar />

  <main class="max-w-5xl mx-auto px-4 pt-6 pb-24">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mb-1">Greek Interlinear New Testament</h1>
        <p class="text-dkc-muted text-sm">Novum Testamentum Graece — Interlinear with English &amp; Transliteration</p>
      </div>
      <div class="hidden md:flex items-center gap-3">
        <!-- Font Size Toggle -->
        <div class="flex items-center gap-1 px-2 py-1 rounded-lg border border-dkc-border">
          <button id="font-dec" class="px-2 py-0.5 rounded text-dkc-muted text-xs hover:text-dkc-gold transition-colors cursor-pointer" title="Decrease font size">A-</button>
          <span id="font-size-label" class="text-dkc-muted text-[10px] min-w-[2rem] text-center">16</span>
          <button id="font-inc" class="px-2 py-0.5 rounded text-dkc-muted text-xs hover:text-dkc-gold transition-colors cursor-pointer" title="Increase font size">A+</button>
        </div>
        <div class="flex items-center gap-2 px-3 py-1.5 rounded-full border border-dkc-border text-xs text-dkc-muted">
          <span class="w-2 h-2 rounded-full bg-dkc-gold animate-pulse"></span>
          <span>Ἑλληνική Κοινή</span>
        </div>
      </div>
    </div>

    <!-- Breadcrumb -->
    <div id="breadcrumb" class="flex items-center gap-1.5 text-xs text-dkc-muted mb-4 flex-wrap">
      <button id="bc-books" class="hover:text-dkc-gold transition-colors cursor-pointer">Books</button>
      <span class="text-dkc-border">›</span>
      <span id="bc-book" class="hidden hover:text-dkc-gold transition-colors cursor-pointer"></span>
      <span id="bc-sep-ch" class="hidden text-dkc-border">›</span>
      <button id="bc-chapter" class="hidden hover:text-dkc-gold transition-colors cursor-pointer"></button>
    </div>

    <!-- ====== SELECTION PANELS ====== -->
    <div id="selection-panel">

      <!-- Book Selector Grid -->
      <div id="book-panel" class="glass-card p-4 mb-5">
        <h2 class="text-dkc-gold font-semibold text-sm mb-3 flex items-center gap-2">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
          Select a Book
        </h2>
        <div id="book-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6 gap-1.5">
          <!-- Filled by JS -->
        </div>
      </div>

      <!-- Chapter Grid -->
      <div id="chapter-panel" class="glass-card p-4 mb-5 hidden">
        <div class="flex items-center justify-between mb-3">
          <h2 id="chapter-panel-title" class="text-dkc-gold font-semibold text-sm flex items-center gap-2">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            Select Chapter
          </h2>
          <button id="back-to-books" class="text-xs text-dkc-muted hover:text-dkc-gold transition-colors cursor-pointer flex items-center gap-1">
            <svg class="w-3 h-3" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            All Books
          </button>
        </div>
        <div id="chapter-grid" class="grid grid-cols-6 sm:grid-cols-8 md:grid-cols-10 lg:grid-cols-12 gap-1">
          <!-- Filled by JS -->
        </div>
      </div>

    </div>

    <!-- ====== READING AREA ====== -->
    <div id="reading-area" class="hidden">
      <div class="glass-card p-5 md:p-6 mb-5">
        <!-- Reading Header -->
        <div class="flex justify-between items-center mb-4 flex-wrap gap-2">
          <div>
            <h2 id="reading-title" class="text-dkc-gold font-bold text-lg">—</h2>
            <p id="reading-subtitle" class="text-dkc-muted text-xs mt-0.5"></p>
          </div>
          <div class="flex gap-2">
            <button id="prev-ch" class="px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer flex items-center gap-1">
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              Prev
            </button>
            <button id="next-ch" class="px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer flex items-center gap-1">
              Next
              <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>

        <!-- Toolbar -->
        <div class="flex gap-2 mb-4 flex-wrap items-center">
          <!-- TTS -->
          <button id="tts-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer" title="Read aloud in English">
            <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14"/><path d="M15.54 8.46a5 5 0 010 7.07"/></svg>
            <span id="tts-label">Read Aloud</span>
          </button>
          <!-- Copy -->
          <button id="copy-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
            <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <span id="copy-label">Copy</span>
          </button>
          <!-- Share -->
          <button id="share-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
            <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            <span id="share-label">Share</span>
          </button>

          <!-- Font size (mobile) -->
          <div class="flex md:hidden items-center gap-1 px-2 py-1 rounded-lg border border-dkc-border">
            <button id="font-dec-m" class="px-1.5 py-0.5 rounded text-dkc-muted text-xs hover:text-dkc-gold transition-colors cursor-pointer">A-</button>
            <button id="font-inc-m" class="px-1.5 py-0.5 rounded text-dkc-muted text-xs hover:text-dkc-gold transition-colors cursor-pointer">A+</button>
          </div>

          <!-- Display mode -->
          <div class="flex gap-1 ml-auto">
            <button id="mode-interlinear" class="px-2.5 py-1.5 rounded-lg border border-dkc-gold/40 text-dkc-gold text-xs transition-colors cursor-pointer">Interlinear</button>
            <button id="mode-greek" class="px-2.5 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 transition-colors cursor-pointer">Greek</button>
            <button id="mode-english" class="px-2.5 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 transition-colors cursor-pointer">English</button>
          </div>
        </div>

        <!-- Loading -->
        <div id="reading-loading" class="text-center py-12 text-dkc-muted">
          <div class="inline-block w-6 h-6 border-2 border-dkc-gold/30 border-t-dkc-gold rounded-full animate-spin mb-3"></div>
          <p class="text-sm">Φορτώνων…</p>
        </div>

        <!-- Verses -->
        <div id="reading-content" class="space-y-3 leading-relaxed hidden">
          <!-- Filled by JS -->
        </div>
      </div>

      <!-- Bottom Nav -->
      <div class="flex justify-center gap-3">
        <button id="prev-ch-bottom" class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
          Previous Chapter
        </button>
        <button id="next-ch-bottom" class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
          Next Chapter
          <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
<style is:global>
  /* Book grid buttons */
  #book-grid .book-btn {
    background: var(--color-dkc-surface);
    border: 1px solid var(--color-dkc-border);
    color: var(--color-dkc-muted);
    border-radius: 0.5rem;
    padding: 0.5rem 0.25rem;
    font-size: 0.7rem;
    transition: all 0.15s;
    cursor: pointer;
    text-align: center;
    line-height: 1.2;
  }
  #book-grid .book-btn:hover {
    border-color: rgba(201, 168, 76, 0.4);
    color: var(--color-dkc-gold);
    background: rgba(201, 168, 76, 0.06);
  }
  #book-grid .book-btn-active {
    background: rgba(201, 168, 76, 0.15);
    color: var(--color-dkc-gold);
    border-color: rgba(201, 168, 76, 0.5);
    font-weight: 600;
  }

  /* Chapter / Verse grid buttons */
  .nav-btn {
    background: var(--color-dkc-surface);
    border: 1px solid var(--color-dkc-border);
    color: var(--color-dkc-muted);
    border-radius: 0.375rem;
    padding: 0.375rem 0;
    font-size: 0.75rem;
    transition: all 0.15s;
    cursor: pointer;
    text-align: center;
    width: 100%;
  }
  .nav-btn:hover {
    border-color: rgba(201, 168, 76, 0.3);
    color: rgba(201, 168, 76, 0.8);
  }
  .nav-btn-active {
    background: rgba(201, 168, 76, 0.2);
    color: var(--color-dkc-gold);
    border-color: rgba(201, 168, 76, 0.4);
    font-weight: 700;
  }

  /* Verse blocks */
  #reading-content .verse-block {
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    margin: 0 -0.5rem;
    transition: background-color 0.15s;
    border-left: 3px solid transparent;
  }
  #reading-content .verse-block:hover {
    background: rgba(201, 168, 76, 0.05);
  }
  #reading-content .verse-block.highlighted {
    background: rgba(201, 168, 76, 0.1);
    border-left-color: rgba(201, 168, 76, 0.5);
  }
  #reading-content .verse-block.flash-highlight {
    background: rgba(201, 168, 76, 0.25);
    border-left-color: rgba(201, 168, 76, 0.7);
    transition: background-color 0.3s, border-color 0.3s;
  }
  #reading-content .verse-num {
    color: rgba(201, 168, 76, 0.7);
    font-weight: bold;
    font-size: 0.7rem;
    margin-right: 0.4rem;
    user-select: none;
  }

  /* Interlinear word layout — flexbox vertical stack */
  #reading-content .word-group {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    margin: 0 3px;
    vertical-align: top;
    text-align: center;
    max-width: 120px;
    overflow-wrap: break-word;
    word-break: break-word;
  }
  #reading-content .word-greek {
    font-family: 'Lora', 'Times New Roman', serif;
    font-weight: 600;
    color: #c9a84c !important;
    font-size: 1.1em;
    line-height: 1.3;
  }
  #reading-content .word-translit {
    color: #888 !important;
    font-size: 0.8em;
    font-style: italic;
    line-height: 1.3;
  }
  #reading-content .word-english {
    color: #aaa !important;
    font-size: 0.85em;
    line-height: 1.3;
  }
  #reading-content .word-strongs {
    color: #666 !important;
    font-size: 0.75em;
    font-family: monospace;
    line-height: 1.3;
  }

  /* Greek-only mode */
  #reading-content .greek-only-text {
    font-family: 'Lora', 'Times New Roman', serif;
    color: #ef5350 !important;
    line-height: 1.9;
  }
  /* English-only mode */
  #reading-content .english-only-text {
    color: #4fc3f7 !important;
    line-height: 1.9;
    font-family: 'Inter', sans-serif;
  }
</style>

<script>
  // ===== Book metadata =====
  const BOOK_NAMES: Record<string, string> = {
    matthew: "Matthew", mark: "Mark", luke: "Luke", john: "John", acts: "Acts",
    romans: "Romans", "1corinthians": "1 Corinthians", "2corinthians": "2 Corinthians",
    galatians: "Galatians", ephesians: "Ephesians", philippians: "Philippians",
    colossians: "Colossians", "1thessalonians": "1 Thessalonians", "2thessalonians": "2 Thessalonians",
    "1timothy": "1 Timothy", "2timothy": "2 Timothy", titus: "Titus", philemon: "Philemon",
    hebrews: "Hebrews", james: "James", "1peter": "1 Peter", "2peter": "2 Peter",
    "1john": "1 John", "2john": "2 John", "3john": "3 John", jude: "Jude", revelation: "Revelation"
  };

  const BOOK_GREEK: Record<string, string> = {
    matthew: "Κατὰ Ματθαῖον", mark: "Κατὰ Μᾶρκον", luke: "Κατὰ Λουκᾶν",
    john: "Κατὰ Ἰωάννην", acts: "Πράξεις", romans: "Πρὸς Ῥωμαίους",
    "1corinthians": "Κορινθίους Αʹ", "2corinthians": "Κορινθίους Βʹ",
    galatians: "Πρὸς Γαλάτας", ephesians: "Πρὸς Ἐφεσίους",
    philippians: "Πρὸς Φιλιππησίους", colossians: "Πρὸς Κολοσσαεῖς",
    "1thessalonians": "Θεσσαλονικεῖς Αʹ", "2thessalonians": "Θεσσαλονικεῖς Βʹ",
    "1timothy": "Τιμόθεον Αʹ", "2timothy": "Τιμόθεον Βʹ", titus: "Πρὸς Τίτον",
    philemon: "Πρὸς Φιλήμονα", hebrews: "Πρὸς Ἑβραίους", james: "Ἰακώβου",
    "1peter": "Πέτρου Αʹ", "2peter": "Πέτρου Βʹ", "1john": "Ἰωάννου Αʹ",
    "2john": "Ἰωάννου Βʹ", "3john": "Ἰωάννου Γʹ", jude: "Ἰούδα",
    revelation: "Ἀποκάλυψις"
  };

  const BOOK_ORDER = [
    "matthew","mark","luke","john","acts","romans","1corinthians","2corinthians",
    "galatians","ephesians","philippians","colossians","1thessalonians","2thessalonians",
    "1timothy","2timothy","titus","philemon","hebrews","james","1peter","2peter",
    "1john","2john","3john","jude","revelation"
  ];

  // ===== State =====
  let bibleData: any = null;
  let currentBook = "";
  let currentChapter = 0;
  let highlightVerses: number[] = [];
  let displayMode: "interlinear" | "greek" | "english" = "interlinear";
  let baseFontSize = 16;
  let ttsPlaying = false;
  let greekChunks: string[] = [];
  let greekChunkIdx = 0;
  let greekResumeTmr: any = null;

  // ===== DOM refs =====
  const $id = (id: string) => document.getElementById(id)!;

  const bookGrid = $id("book-grid");
  const chapterPanel = $id("chapter-panel");
  const chapterPanelTitle = $id("chapter-panel-title") as HTMLElement;
  const chapterGrid = $id("chapter-grid");
  const selectionPanel = $id("selection-panel");
  const readingArea = $id("reading-area");
  const readingTitle = $id("reading-title") as HTMLElement;
  const readingSubtitle = $id("reading-subtitle") as HTMLElement;
  const readingLoading = $id("reading-loading");
  const readingContent = $id("reading-content");
  const breadcrumb = $id("breadcrumb");

  // Breadcrumb
  const bcBooks = $id("bc-books") as HTMLButtonElement;
  const bcBook = $id("bc-book") as HTMLSpanElement;
  const bcSepCh = $id("bc-sep-ch") as HTMLSpanElement;
  const bcChapter = $id("bc-chapter") as HTMLButtonElement;

  // ===== Helpers =====
  function esc(s: string): string {
    return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
  }

  function getBookData(key: string) {
    return bibleData ? bibleData[key] : null;
  }

  function getChapterCount(key: string): number {
    const b = getBookData(key);
    return b ? Object.keys(b).length : 0;
  }

  // ===== Load data =====
  async function loadBible() {
    if (bibleData) return;
    readingLoading?.classList.remove("hidden");
    readingContent?.classList.add("hidden");

    const resp = await fetch("/assets/data/greekInterlinear.json");
    if (!resp.ok) throw new Error("Failed to load Greek interlinear data");
    bibleData = await resp.json();
  }

  // ===== Render book grid =====
  function renderBookGrid() {
    if (!bibleData) return;
    const dataKeys = new Set(Object.keys(bibleData));
    const ordered = BOOK_ORDER.filter(k => dataKeys.has(k));
    // include any extra keys
    for (const k of Object.keys(bibleData)) {
      if (!ordered.includes(k)) ordered.push(k);
    }

    bookGrid.innerHTML = "";
    for (const key of ordered) {
      const btn = document.createElement("button");
      const isActive = key === currentBook;
      btn.className = `book-btn${isActive ? " book-btn-active" : ""}`;
      btn.innerHTML = `<span>${esc(BOOK_NAMES[key] || key)}</span>`;
      btn.addEventListener("click", () => selectBook(key));
      bookGrid.appendChild(btn);
    }
  }

  // ===== Render chapter grid =====
  function renderChapterGrid(bookKey: string) {
    const book = getBookData(bookKey);
    if (!book) return;
    const chapters = Object.keys(book).map(Number).sort((a, b) => a - b);

    chapterGrid.innerHTML = "";
    for (const ch of chapters) {
      const btn = document.createElement("button");
      btn.className = `nav-btn${ch === currentChapter ? " nav-btn-active" : ""}`;
      btn.textContent = String(ch);
      btn.addEventListener("click", () => navigateTo(bookKey, ch));
      chapterGrid.appendChild(btn);
    }
  }

  // ===== Update breadcrumb =====
  function updateBreadcrumb() {
    // Always show Books link
    bcBooks.classList.remove("hidden");

    if (currentBook) {
      bcBook.classList.remove("hidden");
      bcBook.textContent = BOOK_NAMES[currentBook] || currentBook;
    } else {
      bcBook.classList.add("hidden");
    }

    if (currentChapter) {
      bcSepCh.classList.remove("hidden");
      bcChapter.classList.remove("hidden");
      bcChapter.textContent = `Chapter ${currentChapter}`;
    } else {
      bcSepCh.classList.add("hidden");
      bcChapter.classList.add("hidden");
    }
  }

  // ===== Select book (show chapters) =====
  function selectBook(key: string) {
    currentBook = key;
    currentChapter = 0;

    // Show chapter panel
    chapterPanel.classList.remove("hidden");
    chapterPanelTitle.innerHTML = `<span class="text-dkc-gold">${esc(BOOK_NAMES[key])}</span> — Chapters`;
    renderChapterGrid(key);
    renderBookGrid(); // refresh active state
    updateBreadcrumb();

    // Scroll to chapter panel
    setTimeout(() => chapterPanel.scrollIntoView({ behavior: "smooth", block: "start" }), 50);
  }

  // ===== Navigate to chapter =====
  async function navigateTo(book: string, chapter: number, verses?: number[]) {
    await loadBible();

    currentBook = book;
    currentChapter = chapter;
    highlightVerses = verses || [];

    // Show reading, hide selection
    selectionPanel.classList.add("hidden");
    readingArea.classList.remove("hidden");

    renderBookGrid(); // keep grid updated
    updateBreadcrumb();
    renderVerses();

    // Hash
    const hash = verses?.length
      ? `${book}/${chapter}:${verses[0]}${verses.length > 1 ? "-" + verses[verses.length - 1] : ""}`
      : `${book}/${chapter}`;
    window.location.hash = hash;

    readingTitle.scrollIntoView({ behavior: "smooth", block: "start" });

    // Scroll to highlighted verse after content renders
    if (highlightVerses.length > 0) {
      setTimeout(() => {
        const el = readingContent.querySelector(`[data-verse="${highlightVerses[0]}"]`) as HTMLElement;
        if (el) {
          el.classList.add("flash-highlight");
          el.scrollIntoView({ behavior: "smooth", block: "center" });
          setTimeout(() => el.classList.remove("flash-highlight"), 2000);
        }
      }, 200);
    }
  }

  // ===== Render verses =====
  function renderVerses() {
    const book = getBookData(currentBook);
    if (!book) return;
    const chapterData = book[String(currentChapter)];
    if (!chapterData) return;

    const verses = chapterData.verses || [];
    const shortName = BOOK_NAMES[currentBook] || currentBook;
    const totalChapters = Object.keys(book).length;
    readingTitle.textContent = `${shortName} ${currentChapter}`;
    readingSubtitle.textContent = `${totalChapters} chapter${totalChapters > 1 ? "s" : ""} · ${BOOK_GREEK[currentBook] || ""}`;

    // Apply font size
    readingContent.style.fontSize = baseFontSize + "px";

    let html = "";
    for (const v of verses) {
      const vs = v.verse;
      const isHL = highlightVerses.includes(vs);

      html += `<div class="verse-block${isHL ? " highlighted" : ""}" data-verse="${vs}">`;
      html += `<span class="verse-num">${vs}</span>`;

      if (displayMode === "interlinear") {
        const greekArr: string[] = v.greek || [];
        const engArr: string[] = v.english || [];
        const translitArr: string[] = v.translit || [];
        const strongsArr: string[] = v.strongs || [];
        const len = Math.max(greekArr.length, engArr.length, translitArr.length);

        for (let i = 0; i < len; i++) {
          const g = greekArr[i] || "";
          const t = translitArr[i] || "";
          const e = engArr[i] || "";
          const s = strongsArr[i] || "";
          if (!g && !e && !t) continue;
          html += `<span class="word-group">`;
          html += `<span class="word-greek">${esc(g)}</span>`;
          if (t) html += `<span class="word-translit">${esc(t)}</span>`;
          if (e) html += `<span class="word-english">${esc(e)}</span>`;
          if (s) html += `<span class="word-strongs">${esc(s)}</span>`;
          html += `</span>`;
        }

      } else if (displayMode === "greek") {
        html += `<span class="greek-only-text">${esc((v.greek || []).join(" "))}</span>`;
      } else {
        html += `<span class="english-only-text">${esc((v.english || []).join(" "))}</span>`;
      }

      html += `</div>`;
    }

    readingContent.innerHTML = html;
    readingLoading.classList.add("hidden");
    readingContent.classList.remove("hidden");
  }


  // ===== Adjacent chapter =====
  function getAdjacentChapter(delta: number) {
    const book = getBookData(currentBook);
    if (!book) return null;
    const chapters = Object.keys(book).map(Number).sort((a, b) => a - b);
    const idx = chapters.indexOf(currentChapter);
    const newIdx = idx + delta;
    if (newIdx >= 0 && newIdx < chapters.length) {
      return { book: currentBook, chapter: chapters[newIdx] };
    }
    // Cross-book
    const allBooks = BOOK_ORDER.filter((k: string) => bibleData[k]);
    const bookIdx = allBooks.indexOf(currentBook);
    const nextBookIdx = bookIdx + delta;
    if (nextBookIdx >= 0 && nextBookIdx < allBooks.length) {
      const nextBook = allBooks[nextBookIdx];
      const nextChapters = Object.keys(bibleData[nextBook]).map(Number).sort((a, b) => a - b);
      return { book: nextBook, chapter: delta > 0 ? nextChapters[0] : nextChapters[nextChapters.length - 1] };
    }
    return null;
  }

  // ===== TTS (chunked for Android Chrome) =====
  speechSynthesis.getVoices();
  function greekSplit(text: string, maxLen = 180): string[] {
    const ch: string[] = []; let rem = text;
    while (rem.length > 0) {
      if (rem.length <= maxLen) { ch.push(rem); break; }
      let sp = -1;
      for (let i = maxLen; i >= maxLen * 0.4; i--) { if (".!?;,".includes(rem[i])) { sp = i + 1; break; } }
      if (sp === -1) { for (let i = maxLen; i >= maxLen * 0.4; i--) { if (rem[i] === " ") { sp = i + 1; break; } } }
      if (sp === -1) sp = maxLen;
      ch.push(rem.slice(0, sp)); rem = rem.slice(sp);
    }
    return ch;
  }
  function greekSpeakNext() {
    if (greekChunkIdx >= greekChunks.length) { greekTtsStop(); return; }
    speechSynthesis.cancel();
    const u = new SpeechSynthesisUtterance(greekChunks[greekChunkIdx]);
    u.lang = "en-US"; u.rate = 0.9;
    u.onstart = () => { if (greekResumeTmr) clearInterval(greekResumeTmr); greekResumeTmr = setInterval(() => { if (speechSynthesis.speaking && !speechSynthesis.paused) { speechSynthesis.pause(); speechSynthesis.resume(); } }, 10000); };
    u.onend = () => { if (greekResumeTmr) { clearInterval(greekResumeTmr); greekResumeTmr = null; } greekChunkIdx++; greekSpeakNext(); };
    u.onerror = () => { if (greekResumeTmr) { clearInterval(greekResumeTmr); greekResumeTmr = null; } greekChunkIdx++; greekSpeakNext(); };
    speechSynthesis.speak(u);
  }
  function greekTtsStop() {
    if (greekResumeTmr) { clearInterval(greekResumeTmr); greekResumeTmr = null; }
    speechSynthesis.cancel(); greekChunks = []; greekChunkIdx = 0;
    ttsPlaying = false; $id("tts-label").textContent = "Read Aloud";
  }
  function toggleTTS() {
    if (ttsPlaying) { greekTtsStop(); return; }

    const book = getBookData(currentBook);
    if (!book) return;
    const chapterData = book[String(currentChapter)];
    if (!chapterData) return;

    const verses = chapterData.verses || [];
    let text = "";
    for (const v of verses) { text += `Verse ${v.verse}. ${(v.english || []).join(" ")}. `; }
    if (!text) return;

    greekChunks = greekSplit(text);
    greekChunkIdx = 0;
    ttsPlaying = true;
    $id("tts-label").textContent = "Stop";
    greekSpeakNext();
  }

  // ===== Font size =====
  function changeFontSize(delta: number) {
    baseFontSize = Math.min(28, Math.max(10, baseFontSize + delta));
    $id("font-size-label").textContent = String(baseFontSize);
    readingContent.style.fontSize = baseFontSize + "px";
    localStorage.setItem("gnt-fontsize", String(baseFontSize));
  }

  // ===== Get chapter text =====
  function getChapterText(): string {
    const book = getBookData(currentBook);
    if (!book) return "";
    const chapterData = book[String(currentChapter)];
    if (!chapterData) return "";
    const shortName = BOOK_NAMES[currentBook] || currentBook;
    let text = `${shortName} ${currentChapter} (Greek Interlinear NT)\n\n`;
    for (const v of (chapterData.verses || [])) {
      text += `${v.verse}. ${(v.greek || []).join(" ")}\n    [${(v.translit || []).join(" ")}]\n    "${(v.english || []).join(" ")}"\n\n`;
    }
    return text.trim();
  }

  // ===== Copy =====
  function copyChapter() {
    const text = getChapterText();
    const label = $id("copy-label");
    navigator.clipboard.writeText(text).then(() => {
      label.textContent = "Copied!";
      setTimeout(() => { label.textContent = "Copy"; }, 2000);
    }).catch(() => {
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      document.body.removeChild(ta);
      label.textContent = "Copied!";
      setTimeout(() => { label.textContent = "Copy"; }, 2000);
    });
  }

  // ===== Share =====
  function shareChapter() {
    const text = getChapterText();
    const shortName = BOOK_NAMES[currentBook] || currentBook;
    const title = `${shortName} ${currentChapter} — Greek Interlinear NT`;
    const url = window.location.href;
    const label = $id("share-label");

    if (navigator.share) {
      navigator.share({ title, text: text.slice(0, 500) + (text.length > 500 ? "…" : ""), url }).catch(() => {});
    } else {
      navigator.clipboard.writeText(url).then(() => {
        label.textContent = "Link copied!";
        setTimeout(() => { label.textContent = "Share"; }, 2000);
      }).catch(() => {});
    }
  }

  // ===== Display mode =====
  function setMode(mode: "interlinear" | "greek" | "english") {
    displayMode = mode;
    const modes: Record<string, HTMLElement> = {
      interlinear: $id("mode-interlinear"),
      greek: $id("mode-greek"),
      english: $id("mode-english")
    };
    for (const [k, btn] of Object.entries(modes)) {
      if (k === mode) {
        btn.className = "px-2.5 py-1.5 rounded-lg border border-dkc-gold/40 text-dkc-gold text-xs transition-colors cursor-pointer";
      } else {
        btn.className = "px-2.5 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 transition-colors cursor-pointer";
      }
    }
    renderVerses();
    localStorage.setItem("gnt-mode", mode);
  }

  // ===== Go back to book selection =====
  function showBooks() {
    selectionPanel.classList.remove("hidden");
    readingArea.classList.add("hidden");
    chapterPanel.classList.add("hidden");
    currentChapter = 0;
    stopTTS();
    updateBreadcrumb();
    window.location.hash = "";
  }

  function showChapters() {
    if (!currentBook) return;
    selectionPanel.classList.remove("hidden");
    readingArea.classList.add("hidden");
    stopTTS();
    selectBook(currentBook);
    window.location.hash = currentBook;
  }

  function stopTTS() {
    if (ttsPlaying) {
      speechSynthesis.cancel();
      ttsPlaying = false;
      $id("tts-label").textContent = "Read Aloud";
    }
  }

  // ===== Wire events =====
  $id("back-to-books").addEventListener("click", showBooks);
  bcBooks.addEventListener("click", showBooks);
  bcBook.addEventListener("click", showChapters);
  bcChapter.addEventListener("click", () => {
    if (currentBook && currentChapter) navigateTo(currentBook, currentChapter);
  });

  $id("prev-ch").addEventListener("click", () => {
    const adj = getAdjacentChapter(-1);
    if (adj) navigateTo(adj.book, adj.chapter);
  });
  $id("next-ch").addEventListener("click", () => {
    const adj = getAdjacentChapter(1);
    if (adj) navigateTo(adj.book, adj.chapter);
  });
  $id("prev-ch-bottom").addEventListener("click", () => {
    const adj = getAdjacentChapter(-1);
    if (adj) navigateTo(adj.book, adj.chapter);
  });
  $id("next-ch-bottom").addEventListener("click", () => {
    const adj = getAdjacentChapter(1);
    if (adj) navigateTo(adj.book, adj.chapter);
  });

  $id("tts-btn").addEventListener("click", toggleTTS);
  $id("copy-btn").addEventListener("click", copyChapter);
  $id("share-btn").addEventListener("click", shareChapter);

  $id("mode-interlinear").addEventListener("click", () => setMode("interlinear"));
  $id("mode-greek").addEventListener("click", () => setMode("greek"));
  $id("mode-english").addEventListener("click", () => setMode("english"));

  // Font size
  $id("font-inc").addEventListener("click", () => changeFontSize(1));
  $id("font-dec").addEventListener("click", () => changeFontSize(-1));
  $id("font-inc-m").addEventListener("click", () => changeFontSize(1));
  $id("font-dec-m").addEventListener("click", () => changeFontSize(-1));

  // Keyboard nav
  document.addEventListener("keydown", (e) => {
    if (document.activeElement?.tagName === "INPUT" || document.activeElement?.tagName === "SELECT") return;
    if (e.key === "ArrowLeft") $id("prev-ch").click();
    if (e.key === "ArrowRight") $id("next-ch").click();
    if (e.key === "Escape") showBooks();
  });

  // ===== Init =====
  async function init() {
    // Restore prefs
    const savedSize = localStorage.getItem("gnt-fontsize");
    if (savedSize) {
      baseFontSize = parseInt(savedSize) || 16;
      $id("font-size-label").textContent = String(baseFontSize);
    }
    const savedMode = localStorage.getItem("gnt-mode") as "interlinear" | "greek" | "english" | null;
    if (savedMode) setMode(savedMode);

    // Parse hash
    const hash = window.location.hash.slice(1);
    let initBook = "";
    let initChapter = 0;
    let initVerses: number[] = [];

    if (hash) {
      const parsed = hash.match(/^([^/]+)(?:\/(\d+)(?::(\d+(?:-\d+)?))?)?$/);
      if (parsed) {
        initBook = parsed[1];
        if (parsed[2]) initChapter = parseInt(parsed[2]);
        if (parsed[3]) {
          if (parsed[3].includes("-")) {
            const [a, b] = parsed[3].split("-").map(Number);
            for (let i = a; i <= b; i++) initVerses.push(i);
          } else {
            initVerses.push(parseInt(parsed[3]));
          }
        }
      }
    }

    await loadBible();
    renderBookGrid();

    if (initBook && initChapter && bibleData[initBook] && bibleData[initBook][String(initChapter)]) {
      navigateTo(initBook, initChapter, initVerses);
    } else if (initBook && bibleData[initBook]) {
      selectBook(initBook);
      window.location.hash = initBook;
    } else {
      updateBreadcrumb();
    }
  }

  init();
</script>
