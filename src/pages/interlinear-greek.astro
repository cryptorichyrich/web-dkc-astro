---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />

  <main class="max-w-5xl mx-auto px-4 pt-6 pb-24">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mb-1">Greek Interlinear NT</h1>
        <p class="text-dkc-muted text-sm">Novum Testamentum Graece — Interlinear with English &amp; Transliteration</p>
      </div>
      <div class="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-full border border-dkc-border text-xs text-dkc-muted">
        <span class="w-2 h-2 rounded-full bg-dkc-gold animate-pulse"></span>
        <span>Ἑλληνική Κοινή</span>
      </div>
    </div>

    <!-- Search within book/chapter -->
    <div class="glass-card p-3 mb-5 flex items-center gap-2">
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-dkc-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search Greek, English, or transliteration in this chapter…"
          class="w-full bg-dkc-surface border border-dkc-border rounded-lg pl-9 pr-3 py-2.5 text-dkc-text text-sm focus:outline-none focus:border-dkc-gold/40 transition-colors"
        />
      </div>
      <button id="search-clear" class="hidden px-3 py-2.5 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
        Clear
      </button>
    </div>

    <!-- Book Selector -->
    <div class="glass-card p-4 mb-5">
      <div class="flex items-center gap-2 mb-4">
        <label class="text-sm text-dkc-muted shrink-0">Βιβλίον:</label>
        <select id="book-select" class="bg-dkc-surface border border-dkc-border rounded-lg px-3 py-2 text-dkc-text text-sm flex-1 focus:outline-none focus:border-dkc-gold/40">
          <option value="">Loading…</option>
        </select>
      </div>

      <!-- Chapter Grid -->
      <div id="chapter-grid" class="grid grid-cols-8 sm:grid-cols-10 md:grid-cols-12 gap-1">
        <!-- Filled by JS -->
      </div>
    </div>

    <!-- Reading Area -->
    <div class="glass-card p-5 md:p-6 mb-5">
      <div class="flex justify-between items-center mb-5">
        <div>
          <h2 id="reading-title" class="text-dkc-gold font-bold text-lg">—</h2>
          <p id="reading-subtitle" class="text-dkc-muted text-xs mt-0.5"></p>
        </div>
        <div class="flex gap-2">
          <button id="prev-ch" class="px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
            ← Prev
          </button>
          <button id="next-ch" class="px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
            Next →
          </button>
        </div>
      </div>

      <!-- Action buttons row -->
      <div class="flex gap-2 mb-4 flex-wrap">
        <button id="copy-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <span id="copy-label">Copy Chapter</span>
        </button>
        <button id="share-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
          <svg class="w-3.5 h-3.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
          <span>Share</span>
        </button>
        <!-- Display mode toggles -->
        <div class="flex gap-1 ml-auto">
          <button id="mode-interlinear" class="px-2.5 py-1.5 rounded-lg border border-dkc-gold/40 text-dkc-gold text-xs transition-colors cursor-pointer" title="Interlinear view">
            Interlinear
          </button>
          <button id="mode-greek" class="px-2.5 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 transition-colors cursor-pointer" title="Greek only">
            Greek
          </button>
          <button id="mode-english" class="px-2.5 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 transition-colors cursor-pointer" title="English only">
            English
          </button>
        </div>
      </div>

      <!-- Loading state -->
      <div id="reading-loading" class="text-center py-12 text-dkc-muted">
        <div class="inline-block w-6 h-6 border-2 border-dkc-gold/30 border-t-dkc-gold rounded-full animate-spin mb-3"></div>
        <p class="text-sm">Φορτώνων…</p>
      </div>

      <!-- Verses -->
      <div id="reading-content" class="space-y-3 leading-relaxed hidden">
        <!-- Filled by JS -->
      </div>

      <!-- Search results info -->
      <div id="search-info" class="hidden mt-4 pt-3 border-t border-dkc-border text-xs text-dkc-muted text-center"></div>
    </div>

    <!-- Bottom Nav -->
    <div class="flex justify-center gap-3">
      <button id="prev-ch-bottom" class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
        ← Previous Chapter
      </button>
      <button id="next-ch-bottom" class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors cursor-pointer">
        Next Chapter →
      </button>
    </div>
  </main>

  <Footer />
</BaseLayout>

<slot name="head">
  <title>Greek Interlinear NT — Damai Kasih Channel</title>
  <meta name="description" content="Read the Greek New Testament with interlinear English translation and transliteration. Novum Testamentum Graece." />
</slot>

<style>
  #reading-content .verse-block {
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    margin: 0 -0.5rem;
    transition: background-color 0.15s;
    border-left: 3px solid transparent;
  }
  #reading-content .verse-block:hover {
    background: rgba(201, 168, 76, 0.05);
  }
  #reading-content .verse-block.highlighted {
    background: rgba(201, 168, 76, 0.1);
    border-left-color: rgba(201, 168, 76, 0.5);
  }
  #reading-content .verse-block.search-match {
    background: rgba(201, 168, 76, 0.08);
    border-left-color: rgba(201, 168, 76, 0.4);
  }
  #reading-content .verse-num {
    color: rgba(201, 168, 76, 0.7);
    font-weight: bold;
    font-size: 0.7rem;
    margin-right: 0.4rem;
    user-select: none;
  }
  #reading-content .greek-text {
    font-family: 'Lora', 'Times New Roman', serif;
    font-size: 1.05rem;
    color: var(--color-dkc-text);
    line-height: 1.6;
  }
  #reading-content .word-group {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    margin-right: 0.15em;
    vertical-align: top;
  }
  #reading-content .word-greek {
    font-family: 'Lora', 'Times New Roman', serif;
    font-size: 1.05rem;
    color: var(--color-dkc-text);
    line-height: 1.4;
    padding: 0 1px;
  }
  #reading-content .word-translit {
    font-size: 0.6rem;
    color: rgba(201, 168, 76, 0.55);
    line-height: 1.1;
    font-family: 'Inter', sans-serif;
    letter-spacing: -0.01em;
  }
  #reading-content .word-english {
    font-size: 0.65rem;
    color: var(--color-dkc-muted);
    line-height: 1.2;
    font-family: 'Inter', sans-serif;
    font-style: italic;
  }
  #reading-content .greek-only-text {
    font-family: 'Lora', 'Times New Roman', serif;
    font-size: 1.05rem;
    color: var(--color-dkc-text);
    line-height: 1.8;
  }
  #reading-content .english-only-text {
    font-size: 0.95rem;
    color: var(--color-dkc-muted);
    line-height: 1.8;
    font-family: 'Inter', sans-serif;
  }
  #reading-content mark {
    background: rgba(201, 168, 76, 0.3);
    color: var(--color-dkc-text);
    border-radius: 2px;
    padding: 0 2px;
  }
  .chapter-btn-active {
    background: rgba(201, 168, 76, 0.2);
    color: var(--color-dkc-gold);
    border: 1px solid rgba(201, 168, 76, 0.4);
    font-weight: 700;
  }
  .chapter-btn {
    background: var(--color-dkc-surface);
    border: 1px solid var(--color-dkc-border);
    color: var(--color-dkc-muted);
  }
  .chapter-btn:hover {
    border-color: rgba(201, 168, 76, 0.3);
    color: rgba(201, 168, 76, 0.8);
  }
</style>

<script>
  // ===== NT Book names =====
  const BOOK_NAMES: Record<string, string> = {
    matthew: "Matthew (Κατὰ Ματθαῖον)",
    mark: "Mark (Κατὰ Μᾶρκον)",
    luke: "Luke (Κατὰ Λουκᾶν)",
    john: "John (Κατὰ Ἰωάννην)",
    acts: "Acts (Πράξεις Ἀποστόλων)",
    romans: "Romans (Πρὸς Ῥωμαίους)",
    "1corinthians": "1 Corinthians (Πρὸς Κορινθίους Αʹ)",
    "2corinthians": "2 Corinthians (Πρὸς Κορινθίους Βʹ)",
    galatians: "Galatians (Πρὸς Γαλάτας)",
    ephesians: "Ephesians (Πρὸς Ἐφεσίους)",
    philippians: "Philippians (Πρὸς Φιλιππησίους)",
    colossians: "Colossians (Πρὸς Κολοσσαεῖς)",
    "1thessalonians": "1 Thessalonians (Πρὸς Θεσσαλονικεῖς Αʹ)",
    "2thessalonians": "2 Thessalonians (Πρὸς Θεσσαλονικεῖς Βʹ)",
    "1timothy": "1 Timothy (Πρὸς Τιμόθεον Αʹ)",
    "2timothy": "2 Timothy (Πρὸς Τιμόθεον Βʹ)",
    titus: "Titus (Πρὸς Τίτον)",
    philemon: "Philemon (Πρὸς Φιλήμονα)",
    hebrews: "Hebrews (Πρὸς Ἑβραίους)",
    james: "James (Ἰακώβου)",
    "1peter": "1 Peter (Πέτρου Αʹ)",
    "2peter": "2 Peter (Πέτρου Βʹ)",
    "1john": "1 John (Ἰωάννου Αʹ)",
    "2john": "2 John (Ἰωάννου Βʹ)",
    "3john": "3 John (Ἰωάννου Γʹ)",
    jude: "Jude (Ἰούδα)",
    revelation: "Revelation (Ἀποκάλυψις Ἰωάννου)",
  };

  // Canonical NT book order
  const BOOK_ORDER = [
    "matthew", "mark", "luke", "john", "acts",
    "romans", "1corinthians", "2corinthians", "galatians", "ephesians",
    "philippians", "colossians", "1thessalonians", "2thessalonians",
    "1timothy", "2timothy", "titus", "philemon", "hebrews", "james",
    "1peter", "2peter", "1john", "2john", "3john", "jude", "revelation"
  ];

  // Short display names
  const BOOK_SHORT: Record<string, string> = {
    matthew: "Matt", mark: "Mark", luke: "Luke", john: "John", acts: "Acts",
    romans: "Rom", "1corinthians": "1 Cor", "2corinthians": "2 Cor",
    galatians: "Gal", ephesians: "Eph", philippians: "Phil", colossians: "Col",
    "1thessalonians": "1 Thess", "2thessalonians": "2 Thess",
    "1timothy": "1 Tim", "2timothy": "2 Tim", titus: "Titus", philemon: "Phlm",
    hebrews: "Heb", james: "Jas", "1peter": "1 Pet", "2peter": "2 Pet",
    "1john": "1 Jn", "2john": "2 Jn", "3john": "3 Jn", jude: "Jude", revelation: "Rev"
  };

  // ===== State =====
  let bibleData: any = null;
  let currentBook = "matthew";
  let currentChapter = 1;
  let highlightVerses: number[] = [];
  let displayMode: "interlinear" | "greek" | "english" = "interlinear";
  let searchQuery = "";
  let matchedVerses: Set<number> = new Set();

  // ===== DOM refs =====
  const bookSelect = document.getElementById("book-select") as HTMLSelectElement;
  const chapterGrid = document.getElementById("chapter-grid")!;
  const readingTitle = document.getElementById("reading-title")!;
  const readingSubtitle = document.getElementById("reading-subtitle")!;
  const readingLoading = document.getElementById("reading-loading")!;
  const readingContent = document.getElementById("reading-content")!;
  const searchInput = document.getElementById("search-input") as HTMLInputElement;
  const searchClear = document.getElementById("search-clear")!;
  const searchInfo = document.getElementById("search-info")!;
  const copyBtn = document.getElementById("copy-btn")!;
  const copyLabel = document.getElementById("copy-label")!;
  const shareBtn = document.getElementById("share-btn")!;
  const modeInterlinear = document.getElementById("mode-interlinear")!;
  const modeGreek = document.getElementById("mode-greek")!;
  const modeEnglish = document.getElementById("mode-english")!;

  // ===== Load data =====
  async function loadBible() {
    if (bibleData) return;
    readingLoading.classList.remove("hidden");
    readingContent.classList.add("hidden");

    const resp = await fetch("/assets/data/greekInterlinear.json");
    if (!resp.ok) throw new Error("Failed to load Greek interlinear data");
    bibleData = await resp.json();
    populateBookSelect();
  }

  // ===== Populate book dropdown (NT only) =====
  function populateBookSelect() {
    bookSelect.innerHTML = "";
    const dataKeys = new Set(Object.keys(bibleData));

    for (const key of BOOK_ORDER) {
      if (!dataKeys.has(key)) continue;
      const opt = document.createElement("option");
      opt.value = key;
      opt.textContent = BOOK_NAMES[key] || key;
      bookSelect.appendChild(opt);
    }

    // Any extra keys not in our order
    for (const key of Object.keys(bibleData)) {
      if (BOOK_ORDER.includes(key)) continue;
      const opt = document.createElement("option");
      opt.value = key;
      opt.textContent = BOOK_NAMES[key] || key;
      bookSelect.appendChild(opt);
    }

    bookSelect.value = currentBook;
  }

  // ===== Render chapter grid =====
  function renderChapterGrid() {
    const book = bibleData[currentBook];
    if (!book) return;
    const chapters = Object.keys(book).map(Number).sort((a, b) => a - b);

    chapterGrid.innerHTML = "";
    for (const ch of chapters) {
      const btn = document.createElement("button");
      btn.className = `w-full py-1.5 text-xs rounded-lg transition-colors cursor-pointer ${
        ch === currentChapter ? "chapter-btn-active" : "chapter-btn"
      }`;
      btn.textContent = String(ch);
      btn.addEventListener("click", () => navigateTo(currentBook, ch));
      chapterGrid.appendChild(btn);
    }
  }

  // ===== Escape HTML =====
  function esc(s: string): string {
    return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  // ===== Highlight match in text =====
  function highlightText(text: string, query: string): string {
    if (!query) return esc(text);
    const escaped = esc(text);
    const q = esc(query);
    const regex = new RegExp(`(${q.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")})`, "gi");
    return escaped.replace(regex, "<mark>$1</mark>");
  }

  // ===== Search within chapter =====
  function performSearch(query: string) {
    searchQuery = query.trim().toLowerCase();
    matchedVerses = new Set();

    if (!searchQuery) {
      searchClear.classList.add("hidden");
      searchInfo.classList.add("hidden");
      renderVerses();
      return;
    }

    searchClear.classList.remove("hidden");

    const book = bibleData[currentBook];
    if (!book) return;
    const chapterData = book[String(currentChapter)];
    if (!chapterData || !chapterData.verses) return;

    let count = 0;
    for (const v of chapterData.verses) {
      const greekStr = (v.greek || []).join(" ").toLowerCase();
      const engStr = (v.english || []).join(" ").toLowerCase();
      const translitStr = (v.translit || []).join(" ").toLowerCase();

      if (greekStr.includes(searchQuery) || engStr.includes(searchQuery) || translitStr.includes(searchQuery)) {
        matchedVerses.add(v.verse);
        count++;
      }
    }

    searchInfo.classList.remove("hidden");
    searchInfo.textContent = count > 0
      ? `Found in ${count} verse${count > 1 ? "s" : ""}`
      : "No matches found";

    renderVerses();
  }

  // ===== Render verses =====
  function renderVerses() {
    const book = bibleData[currentBook];
    if (!book) return;
    const chapterData = book[String(currentChapter)];
    if (!chapterData) return;

    const shortName = BOOK_SHORT[currentBook] || currentBook;
    const totalChapters = Object.keys(book).length;
    readingTitle.textContent = `${shortName} ${currentChapter}`;
    readingSubtitle.textContent = `${totalChapters} chapter${totalChapters > 1 ? "s" : ""} — Greek Interlinear NT`;

    // Data format: { verses: [{ verse, english[], greek[], translit[] }] }
    const verses = chapterData.verses || [];
    let html = "";

    for (const v of verses) {
      const vs = v.verse;
      const isHighlighted = highlightVerses.includes(vs);
      const isMatch = matchedVerses.has(vs);
      const extraClass = isHighlighted ? " highlighted" : (isMatch ? " search-match" : "");

      html += `<div class="verse-block${extraClass}" data-verse="${vs}">`;
      html += `<span class="verse-num">${vs}</span>`;

      if (displayMode === "interlinear") {
        // Interlinear: each word is a column with greek on top, english below
        const greekArr: string[] = v.greek || [];
        const engArr: string[] = v.english || [];
        const translitArr: string[] = v.translit || [];
        const len = Math.max(greekArr.length, engArr.length, translitArr.length);

        html += `<span class="greek-text">`;
        for (let i = 0; i < len; i++) {
          const g = greekArr[i] || "";
          const e = engArr[i] || "";
          const t = translitArr[i] || "";
          if (!g && !e && !t) continue;

          html += `<span class="word-group">`;
          html += `<span class="word-greek">${searchQuery ? highlightText(g, searchQuery) : esc(g)}</span>`;
          html += `<span class="word-translit">${searchQuery ? highlightText(t, searchQuery) : esc(t)}</span>`;
          html += `<span class="word-english">${searchQuery ? highlightText(e, searchQuery) : esc(e)}</span>`;
          html += `</span>`;
          if (i < len - 1) html += ` `;
        }
        html += `</span>`;

      } else if (displayMode === "greek") {
        const greekStr = (v.greek || []).join(" ");
        html += `<span class="greek-only-text">${searchQuery ? highlightText(greekStr, searchQuery) : esc(greekStr)}</span>`;

      } else {
        const engStr = (v.english || []).join(" ");
        html += `<span class="english-only-text">${searchQuery ? highlightText(engStr, searchQuery) : esc(engStr)}</span>`;
      }

      html += `</div>`;
    }

    readingContent.innerHTML = html;
    readingLoading.classList.add("hidden");
    readingContent.classList.remove("hidden");
  }

  // ===== Navigate =====
  async function navigateTo(book: string, chapter: number, verses?: number[]) {
    currentBook = book;
    currentChapter = chapter;
    highlightVerses = verses || [];
    searchQuery = "";
    matchedVerses = new Set();
    searchInput.value = "";
    searchClear.classList.add("hidden");
    searchInfo.classList.add("hidden");

    bookSelect.value = book;
    renderChapterGrid();
    renderVerses();

    // Update URL hash
    const hash = verses?.length
      ? `${book}/${chapter}:${verses[0]}${verses.length > 1 ? "-" + verses[verses.length - 1] : ""}`
      : `${book}/${chapter}`;
    window.location.hash = hash;

    readingTitle.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  // ===== Get adjacent chapter =====
  function getAdjacentChapter(delta: number) {
    const book = bibleData[currentBook];
    if (!book) return null;
    const chapters = Object.keys(book).map(Number).sort((a, b) => a - b);
    const idx = chapters.indexOf(currentChapter);
    const newIdx = idx + delta;
    if (newIdx >= 0 && newIdx < chapters.length) {
      return { book: currentBook, chapter: chapters[newIdx] };
    }
    // Try adjacent book (NT canonical order)
    const allBooks = BOOK_ORDER.filter((k: string) => bibleData[k]);
    const bookIdx = allBooks.indexOf(currentBook);
    const nextBookIdx = bookIdx + delta;
    if (nextBookIdx >= 0 && nextBookIdx < allBooks.length) {
      const nextBook = allBooks[nextBookIdx];
      const nextChapters = Object.keys(bibleData[nextBook]).map(Number).sort((a, b) => a - b);
      return {
        book: nextBook,
        chapter: delta > 0 ? nextChapters[0] : nextChapters[nextChapters.length - 1]
      };
    }
    return null;
  }

  // ===== Get chapter as plain text =====
  function getChapterText(): string {
    const book = bibleData[currentBook];
    if (!book) return "";
    const chapterData = book[String(currentChapter)];
    if (!chapterData) return "";

    const shortName = BOOK_SHORT[currentBook] || currentBook;
    let text = `${shortName} ${currentChapter} (Greek Interlinear NT)\n\n`;

    const verses = chapterData.verses || [];
    for (const v of verses) {
      const greekStr = (v.greek || []).join(" ");
      const engStr = (v.english || []).join(" ");
      const translitStr = (v.translit || []).join(" ");
      text += `${v.verse}. ${greekStr}\n    [${translitStr}]\n    "${engStr}"\n\n`;
    }
    return text.trim();
  }

  // ===== Copy chapter =====
  function copyChapter() {
    const text = getChapterText();
    navigator.clipboard.writeText(text).then(() => {
      copyLabel.textContent = "Copied!";
      setTimeout(() => { copyLabel.textContent = "Copy Chapter"; }, 2000);
    }).catch(() => {
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.left = "-9999px";
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      document.body.removeChild(ta);
      copyLabel.textContent = "Copied!";
      setTimeout(() => { copyLabel.textContent = "Copy Chapter"; }, 2000);
    });
  }

  // ===== Share =====
  function shareChapter() {
    const text = getChapterText();
    const shortName = BOOK_SHORT[currentBook] || currentBook;
    const title = `${shortName} ${currentChapter} — Greek Interlinear NT`;
    const url = window.location.href;

    if (navigator.share) {
      navigator.share({ title, text: text.slice(0, 500) + (text.length > 500 ? "…" : ""), url }).catch(() => {});
    } else {
      navigator.clipboard.writeText(url).then(() => {
        const sp = shareBtn.querySelector("span");
        if (sp) sp.textContent = "Link copied!";
        setTimeout(() => { if (sp) sp.textContent = "Share"; }, 2000);
      }).catch(() => {});
    }
  }

  // ===== Display mode toggle =====
  function setMode(mode: "interlinear" | "greek" | "english") {
    displayMode = mode;
    const btns = [modeInterlinear, modeGreek, modeEnglish];
    btns.forEach(b => {
      b.className = b.className.replace(/border-dkc-gold\/40/g, "border-dkc-border").replace(/text-dkc-gold/g, "text-dkc-muted");
    });
    const active = mode === "interlinear" ? modeInterlinear : mode === "greek" ? modeGreek : modeEnglish;
    active.className = active.className.replace(/border-dkc-border/g, "border-dkc-gold/40").replace(/text-dkc-muted/g, "text-dkc-gold");
    renderVerses();
  }

  // ===== Event listeners =====
  bookSelect.addEventListener("change", () => {
    navigateTo(bookSelect.value, 1);
  });

  copyBtn.addEventListener("click", copyChapter);
  shareBtn.addEventListener("click", shareChapter);

  modeInterlinear.addEventListener("click", () => setMode("interlinear"));
  modeGreek.addEventListener("click", () => setMode("greek"));
  modeEnglish.addEventListener("click", () => setMode("english"));

  // Search
  let searchTimeout: ReturnType<typeof setTimeout>;
  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => performSearch(searchInput.value), 300);
  });

  searchClear.addEventListener("click", () => {
    searchInput.value = "";
    performSearch("");
  });

  searchInput.addEventListener("keydown", (e) => {
    if (e.key === "Escape") {
      searchInput.value = "";
      performSearch("");
    }
  });

  // Prev/Next buttons
  document.getElementById("prev-ch")!.addEventListener("click", () => {
    const adj = getAdjacentChapter(-1);
    if (adj) navigateTo(adj.book, adj.chapter);
  });
  document.getElementById("next-ch")!.addEventListener("click", () => {
    const adj = getAdjacentChapter(1);
    if (adj) navigateTo(adj.book, adj.chapter);
  });
  document.getElementById("prev-ch-bottom")!.addEventListener("click", () => {
    const adj = getAdjacentChapter(-1);
    if (adj) navigateTo(adj.book, adj.chapter);
  });
  document.getElementById("next-ch-bottom")!.addEventListener("click", () => {
    const adj = getAdjacentChapter(1);
    if (adj) navigateTo(adj.book, adj.chapter);
  });

  // Keyboard nav
  document.addEventListener("keydown", (e) => {
    if (document.activeElement === searchInput || document.activeElement === bookSelect) return;
    if (e.key === "ArrowLeft") document.getElementById("prev-ch")!.click();
    if (e.key === "ArrowRight") document.getElementById("next-ch")!.click();
  });

  // ===== Init =====
  async function init() {
    const hash = window.location.hash.slice(1);
    let initBook = "matthew";
    let initChapter = 1;
    let initVerses: number[] = [];

    if (hash) {
      const parsed = hash.match(/^([^/]+)\/(\d+)(?::(\d+(?:-\d+)?))?$/);
      if (parsed) {
        initBook = parsed[1];
        initChapter = parseInt(parsed[2]);
        if (parsed[3]) {
          if (parsed[3].includes("-")) {
            const [a, b] = parsed[3].split("-").map(Number);
            for (let i = a; i <= b; i++) initVerses.push(i);
          } else {
            initVerses.push(parseInt(parsed[3]));
          }
        }
      }
    }

    await loadBible();

    if (bibleData[initBook] && bibleData[initBook][String(initChapter)]) {
      navigateTo(initBook, initChapter, initVerses);
    } else {
      navigateTo("matthew", 1);
    }
  }

  init();
</script>
