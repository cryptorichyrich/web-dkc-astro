---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <slot name="head">
    <title>Kalender Liturgi 2026 — Damai Kasih Channel</title>
    <meta name="description" content="Kalender liturgi Katolik 2026 lengkap — bacaan harian, warna liturgi, perayaan orang kudus, dan BcO." />
    <meta name="keywords" content="kalender liturgi Katolik 2026, kalender liturgi hari ini, bacaan liturgi Katolik, warna liturgi, pesta orang kudus" />
  </slot>

  <Navbar />
  
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <div class="text-center mb-6">
      <span class="text-4xl">📅</span>
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mt-3">Kalender Liturgi Katolik</h1>
      <p class="text-dkc-muted text-sm mt-1">Lihat <strong class="text-dkc-text">bacaan harian</strong>, warna liturgi, peringatan orang kudus, dan panduan ibadat harian</p>
    </div>

    <!-- Bacaan Hari Ini panel -->
    <div id="cal-today-panel" class="glass-card p-5 mb-6">
      <h2 id="cal-today-title" class="text-dkc-gold font-bold text-lg mb-3">Bacaan Hari Ini</h2>
      <div class="space-y-2.5 text-sm">
        <div>
          <span id="cal-today-perayaan" class="text-dkc-text font-semibold"></span>
        </div>
        <div id="cal-today-bacaan-wrap">
          <span class="text-dkc-muted">Bacaan</span>
          <p id="cal-today-bacaan" class="text-dkc-text mt-0.5 leading-relaxed"></p>
        </div>
        <div id="cal-today-bco-wrap">
          <span class="text-dkc-muted">BcO</span>
          <p id="cal-today-bco" class="text-dkc-text mt-0.5"></p>
        </div>
        <div>
          <span id="cal-today-warna" class="text-dkc-gold font-semibold text-xs"></span>
        </div>
      </div>
    </div>

    <!-- Month navigation -->
    <div class="flex items-center justify-between mb-4">
      <button id="cal-prev" class="glass-card px-3 py-2 text-sm text-dkc-muted hover:text-dkc-gold transition-colors">←</button>
      <h2 id="cal-month-title" class="text-lg font-bold text-dkc-gold"></h2>
      <button id="cal-next" class="glass-card px-3 py-2 text-sm text-dkc-muted hover:text-dkc-gold transition-colors">→</button>
    </div>

    <!-- Detail panel — shows selected date info (hidden by default, appears on click) -->
    <div id="cal-detail" class="glass-card p-5 mb-4 hidden">
      <div class="flex items-start justify-between mb-3">
        <h3 id="cal-detail-date" class="text-dkc-gold font-bold text-lg"></h3>
        <button id="cal-detail-close" class="text-dkc-muted hover:text-dkc-gold text-xl leading-none">&times;</button>
      </div>
      <div class="space-y-2.5 text-sm">
        <div>
          <span id="cal-detail-perayaan" class="text-dkc-text font-semibold"></span>
        </div>
        <div id="cal-detail-bacaan" class="hidden">
          <span class="text-dkc-muted">Bacaan</span>
          <p id="cal-detail-bacaan-text" class="text-dkc-text mt-0.5 leading-relaxed"></p>
        </div>
        <div id="cal-detail-bco" class="hidden">
          <span class="text-dkc-muted">BcO</span>
          <p id="cal-detail-bco-text" class="text-dkc-text mt-0.5"></p>
        </div>
        <div>
          <span id="cal-detail-warna" class="text-dkc-gold font-semibold text-xs"></span>
        </div>
      </div>
    </div>

    <!-- Calendar grid -->
    <div class="glass-card overflow-hidden">
      <div class="grid grid-cols-7 text-center text-xs text-dkc-muted font-semibold border-b border-dkc-border">
        <div class="py-2">Min</div><div class="py-2">Sen</div><div class="py-2">Sel</div>
        <div class="py-2">Rab</div><div class="py-2">Kam</div><div class="py-2">Jum</div><div class="py-2">Sab</div>
      </div>
      <div id="cal-grid" class="grid grid-cols-7"></div>
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap gap-3 mt-4 text-xs text-dkc-muted justify-center">
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-white inline-block"></span> Putih</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-green-600 inline-block"></span> Hijau</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-purple-700 inline-block"></span> Ungu</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-red-600 inline-block"></span> Merah</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-rose-300 inline-block"></span> Merah Muda</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-yellow-400 inline-block"></span> Emas</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-gray-800 inline-block"></span> Hitam</span>
    </div>

    <!-- SEO content -->
    <div class="mt-12 space-y-6 text-sm text-dkc-muted leading-relaxed">
      <div>
        <h2 class="text-dkc-gold font-semibold text-base mb-2">Warna Liturgi dan Masa Liturgi</h2>
        <p>Gereja Katolik menggunakan warna liturgi yang berbeda untuk setiap masa liturgi: putih (Natal dan Paskah), ungu (Adven dan Prapaskah), hijau (waktu biasa), merah (Pesta Salib Suci, para martir), dan merah muda (Gaudete dan Laetare).</p>
      </div>
      <div>
        <h2 class="text-dkc-gold font-semibold text-base mb-2">Peringatan Orang Kudus</h2>
        <p>Kalender liturgi juga mencatat peringatan para santo dan santa sepanjang tahun. Setiap hari dapat memiliki pesta, peringatan wajib, peringatan bebas, atau opsional untuk mengenang kehidupan orang kudus.</p>
      </div>
      <div>
        <h2 class="text-dkc-gold font-semibold text-base mb-2">Halaman Terkait</h2>
        <ul class="space-y-1">
          <li><a href="/renungan" class="text-dkc-gold hover:underline">Renungan Harian Katolik</a></li>
          <li><a href="/kitab-suci" class="text-dkc-gold hover:underline">Kitab Suci Katolik Online</a></li>
          <li><a href="/rosario" class="text-dkc-gold hover:underline">Doa Rosario</a></li>
          <li><a href="/jalan-salib" class="text-dkc-gold hover:underline">Jalan Salib</a></li>
          <li><a href="/katekismus" class="text-dkc-gold hover:underline">Katekismus Gereja Katolik</a></li>
        </ul>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script is:inline>
  const MONTHS_ID = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
  const DAYS_ID = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];
  const MONTHS_SHORT = ['JANUARI','FEBRUARI','MARET','APRIL','MEI','JUNI','JULI','AGUSTUS','SEPTEMBER','OKTOBER','NOVEMBER','DESEMBER'];

  let liturgicalData = {};
  let viewYear, viewMonth;

  async function loadData() {
    try {
      const res = await fetch('/assets/data/liturgical-' + new Date().getFullYear() + '.json');
      if (res.ok) liturgicalData = await res.json();
      else console.warn('Liturgical data not available');
    } catch(e) { console.warn('Error loading liturgical data:', e); }
  }

  function getLiturgicalInfo(date) {
    const key = `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}-${String(date.getDate()).padStart(2,'0')}`;
    return liturgicalData[key] || null;
  }

  // --- Today's panel ---
  function renderTodayPanel() {
    const now = new Date();
    const info = getLiturgicalInfo(now);

    // Title: "Bacaan Hari Ini, 2 JUNI 2026"
    const dateStr = `${now.getDate()} ${MONTHS_SHORT[now.getMonth()]} ${now.getFullYear()}`;
    document.getElementById('cal-today-title').textContent = `Bacaan Hari Ini, ${dateStr}`;

    if (info) {
      document.getElementById('cal-today-perayaan').textContent = info.perayaan || '';

      const bacaanWrap = document.getElementById('cal-today-bacaan-wrap');
      if (info.bacaan) {
        document.getElementById('cal-today-bacaan').textContent = info.bacaan;
      } else {
        bacaanWrap.style.display = 'none';
      }

      const bcoWrap = document.getElementById('cal-today-bco-wrap');
      if (info.bco) {
        document.getElementById('cal-today-bco').textContent = info.bco;
      } else {
        bcoWrap.style.display = 'none';
      }

      document.getElementById('cal-today-warna').textContent = 'Warna Liturgi ' + (info.warna || 'Hijau');
    } else {
      document.getElementById('cal-today-perayaan').textContent = 'Waktu Biasa';
      document.getElementById('cal-today-bacaan-wrap').style.display = 'none';
      document.getElementById('cal-today-bco-wrap').style.display = 'none';
      document.getElementById('cal-today-warna').textContent = 'Warna Liturgi Hijau';
    }
  }

  // --- Detail panel (on date click) ---
  function showDetail(date) {
    const info = getLiturgicalInfo(date);
    const sel = document.getElementById('cal-detail');
    sel.classList.remove('hidden');

    const dateStr = `${DAYS_ID[date.getDay()]}, ${date.getDate()} ${MONTHS_ID[date.getMonth()]} ${date.getFullYear()}`;
    document.getElementById('cal-detail-date').textContent = dateStr;

    document.getElementById('cal-detail-perayaan').textContent = info ? (info.perayaan || '') : 'Hari Biasa';

    const bacaanDiv = document.getElementById('cal-detail-bacaan');
    const bacaanText = document.getElementById('cal-detail-bacaan-text');
    if (info && info.bacaan) {
      bacaanDiv.classList.remove('hidden');
      bacaanText.textContent = info.bacaan;
    } else {
      bacaanDiv.classList.add('hidden');
    }

    const bcoDiv = document.getElementById('cal-detail-bco');
    const bcoText = document.getElementById('cal-detail-bco-text');
    if (info && info.bco) {
      bcoDiv.classList.remove('hidden');
      bcoText.textContent = info.bco;
    } else {
      bcoDiv.classList.add('hidden');
    }

    const warna = info ? (info.warna || 'Hijau') : 'Hijau';
    document.getElementById('cal-detail-warna').textContent = 'Warna Liturgi ' + warna;

    sel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  document.getElementById('cal-detail-close').addEventListener('click', () => {
    document.getElementById('cal-detail').classList.add('hidden');
  });

  // --- Calendar grid ---
  const colorMap = {
    'Putih':'border-white/40 bg-white/5', 'Hijau':'border-green-600/40 bg-green-900/10',
    'Ungu':'border-purple-600/40 bg-purple-900/10', 'Merah':'border-red-600/40 bg-red-900/10',
    'Hitam':'border-gray-600/40 bg-gray-900/10',
  };
  const dotColorMap = {
    'Putih':'bg-white/60', 'Hijau':'bg-green-600/60', 'Ungu':'bg-purple-600/60',
    'Merah':'bg-red-600/60', 'Hitam':'bg-gray-600/60',
  };

  function renderCalendar() {
    const title = document.getElementById('cal-month-title');
    title.textContent = `${MONTHS_ID[viewMonth]} ${viewYear}`;
    const firstDay = new Date(viewYear, viewMonth, 1);
    const lastDay = new Date(viewYear, viewMonth + 1, 0);
    const startDow = firstDay.getDay();
    const daysInMonth = lastDay.getDate();
    const today = new Date();
    const isCurrentMonth = today.getFullYear()===viewYear && today.getMonth()===viewMonth;

    const grid = document.getElementById('cal-grid');
    let html = '';
    for (let i=0; i<startDow; i++) html += '<div class="p-1 min-h-[52px] md:min-h-[68px]"></div>';

    for (let d=1; d<=daysInMonth; d++) {
      const date = new Date(viewYear, viewMonth, d);
      const info = getLiturgicalInfo(date);
      const nama = info ? info.perayaan : 'Hari Biasa';
      const warna = info ? info.warna : 'Hijau';
      const baseWarna = warna.split('/')[0].split(' ')[0];
      const dotClass = dotColorMap[baseWarna] || 'bg-dkc-muted/40';
      const isToday = isCurrentMonth && d===today.getDate();
      const dateKey = `${viewYear}-${String(viewMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;

      html += `<div class="cal-day p-1 min-h-[52px] md:min-h-[68px] border-t border-dkc-border/30 cursor-pointer hover:bg-dkc-surface/30 transition-colors ${isToday?'ring-2 ring-dkc-gold/70':''}" data-date="${dateKey}">
        <div class="text-xs font-semibold ${isToday?'text-dkc-gold':'text-dkc-text'}">${d}</div>
        <div class="text-[8px] md:text-[10px] leading-tight text-dkc-muted mt-0.5 line-clamp-2">${nama}</div>
        <div class="w-2 h-2 rounded-full mt-1 ${dotClass}"></div>
      </div>`;
    }
    grid.innerHTML = html;

    // Click handlers
    grid.querySelectorAll('.cal-day').forEach(el => {
      el.addEventListener('click', () => {
        const dk = el.dataset.date;
        if (dk) {
          const [y,m,d] = dk.split('-').map(Number);
          showDetail(new Date(y, m-1, d));
        }
      });
    });
  }

  // --- Month nav ---
  document.getElementById('cal-prev').addEventListener('click', () => {
    viewMonth--; if(viewMonth<0){viewMonth=11;viewYear--;} renderCalendar();
  });
  document.getElementById('cal-next').addEventListener('click', () => {
    viewMonth++; if(viewMonth>11){viewMonth=0;viewYear++;} renderCalendar();
  });

  // --- Init ---
  const now = new Date();
  viewYear = now.getFullYear();
  viewMonth = now.getMonth();
  loadData().then(() => {
    renderTodayPanel();
    renderCalendar();
  });
</script>
