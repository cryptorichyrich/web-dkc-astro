---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <div class="text-center mb-8">
      <span class="text-4xl">📅</span>
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mt-3">Kalender Liturgi</h1>
      <p class="text-dkc-muted text-sm mt-1">Kalender liturgi Gereja Katolik Ritus Romawi</p>
    </div>

    <!-- Month navigation -->
    <div class="flex items-center justify-between mb-6">
      <button id="cal-prev" class="glass-card px-3 py-2 text-sm text-dkc-muted hover:text-dkc-gold transition-colors">←</button>
      <h2 id="cal-month-title" class="text-lg font-bold text-dkc-gold"></h2>
      <button id="cal-next" class="glass-card px-3 py-2 text-sm text-dkc-muted hover:text-dkc-gold transition-colors">→</button>
    </div>

    <!-- Today info -->
    <div id="cal-today" class="glass-card p-4 mb-6 text-center">
    </div>

    <!-- Calendar grid -->
    <div class="glass-card overflow-hidden">
      <div class="grid grid-cols-7 text-center text-xs text-dkc-muted font-semibold border-b border-dkc-border">
        <div class="py-2">Min</div><div class="py-2">Sen</div><div class="py-2">Sel</div>
        <div class="py-2">Rab</div><div class="py-2">Kam</div><div class="py-2">Jum</div><div class="py-2">Sab</div>
      </div>
      <div id="cal-grid" class="grid grid-cols-7">
      </div>
    </div>

    <!-- Legend -->
    <div class="flex flex-wrap gap-3 mt-4 text-xs text-dkc-muted justify-center">
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-white inline-block"></span> Putih</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-green-600 inline-block"></span> Hijau</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-purple-700 inline-block"></span> Ungu</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-red-600 inline-block"></span> Merah</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-rose-300 inline-block"></span> Merah Muda</span>
      <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-yellow-400 inline-block"></span> Emas</span>
    </div>

    <!-- Liturgical season info -->
    <div id="cal-season-info" class="glass-card p-4 mt-6">
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const MONTHS_ID = ['Januari','Februari','Maret','April','Mei','Juni','Juli','Agustus','September','Oktober','November','Desember'];
  const DAYS_ID = ['Minggu','Senin','Selasa','Rabu','Kamis','Jumat','Sabtu'];

  let viewYear, viewMonth;

  function computeEaster(y) {
    const a=y%19, b=Math.floor(y/100), c=y%100;
    const d=Math.floor(b/4), e=b%4, f=Math.floor((b+8)/25);
    const g=Math.floor((b-f+1)/3), h=(19*a+b-d-g+15)%30;
    const i=Math.floor(c/4), k=c%4, l=(32+2*e+2*i-h-k)%7;
    const m=Math.floor((a+11*h+22*l)/451);
    const month=Math.floor((h+l-7*m+114)/31);
    const day=((h+l-7*m+114)%31)+1;
    return new Date(y, month-1, day);
  }

  function getDayInfo(date) {
    const y = date.getFullYear(), m = date.getMonth(), d = date.getDate();
    const dow = date.getDay();
    const easter = computeEaster(y);
    const ashWed = new Date(easter); ashWed.setDate(easter.getDate()-46);
    const pentecost = new Date(easter); pentecost.setDate(easter.getDate()+49);
    const corpusChristi = new Date(easter); corpusChristi.setDate(easter.getDate()+60);
    const christmas = new Date(y, 11, 25);
    const adventSun1 = new Date(christmas); adventSun1.setDate(christmas.getDate()-(christmas.getDay()===0?28:21+christmas.getDay()));

    const doy = Math.floor((date - new Date(y,0,1)) / 86400000);

    // Major feasts (month-1 based)
    const feasts = {
      '1-1': {name:'Maria Bunda Allah',color:'white',rank:'solemnity'},
      '0-6': {name:'Epifani',color:'white',rank:'solemnity'},
      '2-19': {name:'St. Yosef',color:'white',rank:'solemnity'},
      '2-25': {name:'Pemberitaan Tuhan',color:'white',rank:'solemnity'},
      '5-24': {name:'Kelahiran Yohanes Pembaptis',color:'white',rank:'solemnity'},
      '5-29': {name:'St. Petrus & Paulus',color:'red',rank:'solemnity'},
      '7-15': {name:'Maria Diangkat ke Surga',color:'white',rank:'solemnity'},
      '8-14': {name:'Pesta Salib Suci',color:'red',rank:'feast'},
      '10-1': {name:'Semua Orang Kudus',color:'white',rank:'solemnity'},
      '10-2': {name:'Arwah Semua Orang Beriman',color:'white',rank:'solemnity'},
      '11-8': {name:'Maria Dikandung Tanpa Noda',color:'white',rank:'solemnity'},
      '11-25': {name:'Natal',color:'white',rank:'solemnity'},
    };

    const key = `${m}-${d}`;
    if (feasts[key]) return feasts[key];

    // Easter-based feasts
    const diff = Math.floor((date - easter) / 86400000);
    if (diff === 0) return {name:'Paskah',color:'white',rank:'solemnity'};
    if (diff === -7) return {name:'Minggu Palmarum',color:'red',rank:'solemnity'};
    if (diff === -3) return {name:'Kamis Putih',color:'white',rank:'solemnity'};
    if (diff === -2) return {name:'Jumat Agung',color:'red',rank:'solemnity'};
    if (diff === -1) return {name:'Sabtu Suci',color:'white',rank:'solemnity'};
    if (diff === 39) return {name:'Kenaikan Tuhan',color:'white',rank:'solemnity'};
    if (diff === 49) return {name:'Pentakosta',color:'red',rank:'solemnity'};
    if (diff === 56) return {name:'Trinitas',color:'white',rank:'solemnity'};
    if (diff === 60) return {name:'Corpus Christi',color:'white',rank:'solemnity'};

    // Ash Wednesday
    const ashDiff = Math.floor((date - ashWed) / 86400000);

    // Seasons
    if (date >= ashWed && date < easter) {
      // Lent
      if (dow === 0) return {name:'Minggu Prapaskah',color:'purple',rank:'sunday'};
      return {name:'Prapaskah',color:'purple',rank:'feria'};
    }
    if (date >= easter && date < pentecost) {
      if (dow === 0) return {name:'Minggu Paskah',color:'white',rank:'sunday'};
      return {name:'Masa Paskah',color:'white',rank:'feria'};
    }
    if (date >= adventSun1 && date < new Date(y,11,25)) {
      if (dow === 0) return {name:'Minggu Adven',color:'purple',rank:'sunday'};
      return {name:'Masa Adven',color:'purple',rank:'feria'};
    }
    if ((m === 11 && d >= 25) || (m === 0 && d <= 6)) {
      return {name:'Masa Natal',color:'white',rank:'feria'};
    }

    // Ordinary time
    if (dow === 0) return {name:'Minggu Biasa',color:'green',rank:'sunday'};
    return {name:'Waktu Biasa',color:'green',rank:'feria'};
  }

  function getSeason(date) {
    const y = date.getFullYear();
    const easter = computeEaster(y);
    const ashWed = new Date(easter); ashWed.setDate(easter.getDate()-46);
    const pentecost = new Date(easter); pentecost.setDate(easter.getDate()+49);
    const christmas = new Date(y, 11, 25);
    const adventSun1 = new Date(christmas); adventSun1.setDate(christmas.getDate()-(christmas.getDay()===0?28:21+christmas.getDay()));

    if (date >= ashWed && date < easter) return {name:'Prapaskah',color:'Ungu',icon:'🙏'};
    if (date >= easter && date < new Date(easter.getTime()+50*864e5)) return {name:'Masa Paskah',color:'Putih',icon:'🕊️'};
    if (date >= adventSun1 && date < christmas) return {name:'Adven',color:'Ungu',icon:'🕯️'};
    if ((date.getMonth()===11 && date.getDate()>=25)||(date.getMonth()===0 && date.getDate()<=6)) return {name:'Natal',color:'Putih',icon:'⭐'};
    return {name:'Waktu Biasa',color:'Hijau',icon:'🌿'};
  }

  function renderCalendar() {
    const title = document.getElementById("cal-month-title");
    title.textContent = `${MONTHS_ID[viewMonth]} ${viewYear}`;

    const firstDay = new Date(viewYear, viewMonth, 1);
    const lastDay = new Date(viewYear, viewMonth + 1, 0);
    const startDow = firstDay.getDay();
    const daysInMonth = lastDay.getDate();

    const today = new Date();
    const isCurrentMonth = today.getFullYear() === viewYear && today.getMonth() === viewMonth;

    const grid = document.getElementById("cal-grid");
    let html = '';

    // Empty cells before first day
    for (let i = 0; i < startDow; i++) {
      html += '<div class="p-1 min-h-[48px] md:min-h-[64px]"></div>';
    }

    const colorMap = {
      white: 'border-white/40 bg-white/5',
      green: 'border-green-600/40 bg-green-900/10',
      purple: 'border-purple-600/40 bg-purple-900/10',
      red: 'border-red-600/40 bg-red-900/10',
    };

    for (let d = 1; d <= daysInMonth; d++) {
      const date = new Date(viewYear, viewMonth, d);
      const info = getDayInfo(date);
      const isToday = isCurrentMonth && d === today.getDate();
      const borderClass = colorMap[info.color] || 'border-dkc-border';

      html += `<div class="p-1 min-h-[48px] md:min-h-[64px] border-t border-dkc-border/30 ${isToday ? 'ring-2 ring-dkc-gold/60' : ''}">
        <div class="text-xs font-semibold ${isToday ? 'text-dkc-gold' : 'text-dkc-text'}">${d}</div>
        <div class="text-[9px] md:text-[10px] leading-tight text-dkc-muted mt-0.5 truncate">${info.name}</div>
        <div class="w-2 h-2 rounded-full mt-1 ${info.color === 'white' ? 'bg-white/60' : info.color === 'green' ? 'bg-green-600/60' : info.color === 'purple' ? 'bg-purple-600/60' : info.color === 'red' ? 'bg-red-600/60' : 'bg-dkc-muted/40'}"></div>
      </div>`;
    }

    grid.innerHTML = html;

    // Today info
    const season = getSeason(today);
    document.getElementById("cal-today").innerHTML = `
      <p class="text-dkc-gold font-semibold">${DAYS_ID[today.getDay()]}, ${today.getDate()} ${MONTHS_ID[today.getMonth()]} ${today.getFullYear()}</p>
      <p class="text-dkc-text text-sm mt-1">${season.icon} ${season.name}</p>
      <p class="text-dkc-muted text-xs mt-1">Warna liturgi: ${season.color}</p>
    `;

    // Season info
    const easter = computeEaster(viewYear);
    const ashWed = new Date(easter); ashWed.setDate(easter.getDate()-46);
    document.getElementById("cal-season-info").innerHTML = `
      <h3 class="text-dkc-gold font-semibold text-sm mb-2">📅 Tahun Liturgi ${viewYear}</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-xs text-dkc-text">
        <div>🕯️ Adven: ${adventSun1.toLocaleDateString('id-ID')}</div>
        <div>⭐ Natal: 25 Desember</div>
        <div>🙏 Rabu Abu: ${ashWed.toLocaleDateString('id-ID')}</div>
        <div>🕊️ Paskah: ${easter.toLocaleDateString('id-ID')}</div>
        <div>🔴 Pentakosta: ${new Date(easter.getTime()+49*864e5).toLocaleDateString('id-ID')}</div>
        <div>🌿 Waktu Biasa: sisa tahun</div>
      </div>
    `;
  }

  document.getElementById("cal-prev").addEventListener("click", () => {
    viewMonth--;
    if (viewMonth < 0) { viewMonth = 11; viewYear--; }
    renderCalendar();
  });
  document.getElementById("cal-next").addEventListener("click", () => {
    viewMonth++;
    if (viewMonth > 11) { viewMonth = 0; viewYear++; }
    renderCalendar();
  });

  const now = new Date();
  viewYear = now.getFullYear();
  viewMonth = now.getMonth();
  renderCalendar();
</script>
