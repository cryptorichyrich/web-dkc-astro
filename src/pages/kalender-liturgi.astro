---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />
  
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <h1 class="text-3xl font-bold text-dkc-gold mb-2">Kalender Liturgi</h1>
    <p class="text-dkc-muted mb-8">Kalender liturgi Gereja Katolik — warna, bacaan, pesta</p>

    <!-- Month nav -->
    <div class="flex items-center justify-between mb-4">
      <button class="px-3 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm">← Mei</button>
      <h2 class="text-dkc-gold font-bold">Juni 2026</h2>
      <button class="px-3 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm">Juli →</button>
    </div>

    <!-- Calendar grid -->
    <div class="glass-card p-4 mb-6">
      <div class="grid grid-cols-7 text-center text-xs text-dkc-muted mb-2">
        {["Min", "Sen", "Sel", "Rab", "Kam", "Jum", "Sab"].map(d => <span>{d}</span>)}
      </div>
      <div class="grid grid-cols-7 gap-1 text-center">
        {Array.from({length: 30}, (_, i) => (
          <div class={`p-2 rounded-lg text-xs ${i === 23 ? 'bg-dkc-gold/20 border border-dkc-gold/40' : 'hover:bg-dkc-surface'} ${i === 0 || i === 6 || i === 13 || i === 20 || i === 27 ? 'text-dkc-gold' : 'text-dkc-text'}`}>
            <span>{i + 1}</span>
            {i === 23 && <div class="w-1 h-1 bg-dkc-gold rounded-full mx-auto mt-1"></div>}
          </div>
        ))}
      </div>
    </div>

    <!-- Selected day info -->
    <div class="glass-card glass-card-amber p-5">
      <div class="flex items-center gap-2 mb-3">
        <span class="w-3 h-3 rounded-full bg-dkc-gold inline-block"></span>
        <span class="text-dkc-gold font-semibold text-sm">24 Juni 2026</span>
      </div>
      <h2 class="text-xl text-dkc-gold font-bold mb-1">HR Kelahiran S. Yohanes Pembaptis</h2>
      <p class="text-dkc-muted text-xs mb-3">Warna Liturgi: Putih</p>
      <div class="text-sm text-dkc-text space-y-2">
        <p><strong>Bacaan I:</strong> Yes 49:1-6</p>
        <p><strong>Mazmur:</strong> Mzm 139:1-3.13-15</p>
        <p><strong>Bacaan II:</strong> Kis 13:22-26</p>
        <p><strong>Bacaan Injil:</strong> Luk 1:57-66.80</p>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<slot name="head">
  <title>Kalender Liturgi — Damai Kasih Channel</title>
  <meta name="description" content="Kalender liturgi Gereja Katolik. Cek warna liturgi, bacaan Misa, dan pesta hari ini." />
</slot>
