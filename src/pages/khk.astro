---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />
  
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <h1 class="text-3xl font-bold text-dkc-gold mb-2">Hukum Kanonik (KHK)</h1>
    <p class="text-dkc-muted mb-8">Kitab Hukum Kanonik — hukum resmi Gereja Katolik</p>

    <div class="glass-card p-4 mb-6 flex gap-3">
      <input type="text" placeholder="Cari kanon..." class="bg-dkc-surface border border-dkc-border rounded-lg px-3 py-2 text-dkc-text text-sm flex-1" />
      <button class="bg-dkc-gold text-black font-medium px-4 py-2 rounded-lg text-sm">Cari</button>
    </div>

    <div class="space-y-3">
      {[
        {bk: "Buku I", title: "Norma-Norma Umum", kanon: "1–203"},
        {bk: "Buku II", title: "Umat Allah", kanon: "204–746"},
        {bk: "Buku III", title: "Tugas Gereja Mengajar", kanon: "747–833"},
        {bk: "Buku IV", title: "Tugas Gereja Menguduskan", kanon: "834–1253"},
        {bk: "Buku V", title: "Harta Benda Gereja", kanon: "1254–1310"},
        {bk: "Buku VI", title: "Sanksi dalam Gereja", kanon: "1311–1399"},
        {bk: "Buku VII", title: "Hukum Acara", kanon: "1400–1752"},
      ].map(b => (
        <a href="#" class="glass-card p-4 flex items-center gap-4 transition-all active:scale-[0.98] hover:border-dkc-gold/30">
          <span class="text-2xl">⚖️</span>
          <div class="flex-1">
            <h3 class="text-dkc-gold font-semibold text-sm">{b.bk}</h3>
            <p class="text-white font-medium">{b.title}</p>
            <p class="text-dkc-muted text-xs">Kanon {b.kanon}</p>
          </div>
          <span class="text-dkc-gold">→</span>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>

<slot name="head">
  <title>Hukum Kanonik (KHK) — Damai Kasih Channel</title>
  <meta name="description" content="Kitab Hukum Kanonik lengkap — hukum resmi Gereja Katolik." />
</slot>
