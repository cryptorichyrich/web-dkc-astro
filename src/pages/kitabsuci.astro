---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />

  <!-- Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-0.5 bg-dkc-gold/60 z-[60] transition-all duration-150" style="width:0%"></div>

  <main class="max-w-4xl mx-auto px-4 pt-6 pb-24">
    <!-- Header -->
    <div class="text-center mb-6">
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mb-1">Kitab Suci</h1>
      <p class="text-dkc-muted text-sm">Alkitab Katolik Indonesia — lengkap dengan Deuterokanonika</p>
      <!-- Version Tabs -->
      <div class="flex justify-center gap-2 mt-3">
        <button data-version="tb1" class="version-tab px-3 py-1 rounded-lg border border-dkc-border text-dkc-muted text-xs font-medium hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors">TB</button>
        <button data-version="tb2" class="version-tab px-3 py-1 rounded-lg border border-dkc-border text-dkc-muted text-xs font-medium hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors">TB2</button>
        <button data-version="lds" class="version-tab px-3 py-1 rounded-lg border border-dkc-border text-dkc-muted text-xs font-medium hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors">LDS</button>
      </div>
    </div>

    <!-- Citation Quick Jump -->
    <div class="glass-card p-3 mb-5 flex items-center gap-2">
      <div class="relative flex-1">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-dkc-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input id="citation-input" type="text" placeholder="Langsung ke ayat (cth: yoh 3:16, mzm 23)" class="w-full bg-dkc-surface border border-dkc-border rounded-lg pl-9 pr-3 py-2.5 text-dkc-text text-sm focus:outline-none focus:border-dkc-gold/40" />
      </div>
      <button id="citation-go" class="bg-dkc-gold text-black font-medium px-4 py-2.5 rounded-lg text-sm shrink-0 hover:bg-dkc-gold/90">Buka</button>
    </div>

    <!-- Step 1: Testament Selection -->
    <div id="step-testament" class="glass-card p-5 mb-5">
      <h2 class="text-dkc-gold font-bold text-sm mb-4 uppercase tracking-wider">Pilih Perjanjian</h2>
      <div class="grid grid-cols-2 gap-3">
        <button data-testament="pl" class="testament-btn group relative overflow-hidden rounded-xl border-2 border-amber-700/30 bg-gradient-to-br from-amber-900/20 to-amber-800/10 p-5 text-center transition-all hover:border-amber-600/50 hover:from-amber-900/30">
          <div class="text-3xl mb-2">📖</div>
          <div class="text-dkc-gold font-bold text-sm">PERJANJIAN LAMA</div>
          <div class="text-dkc-muted text-[11px] mt-1">46 Kitab</div>
        </button>
        <button data-testament="pb" class="testament-btn group relative overflow-hidden rounded-xl border-2 border-red-700/30 bg-gradient-to-br from-red-900/20 to-red-800/10 p-5 text-center transition-all hover:border-red-600/50 hover:from-red-900/30">
          <div class="text-3xl mb-2">✝️</div>
          <div class="text-dkc-gold font-bold text-sm">PERJANJIAN BARU</div>
          <div class="text-dkc-muted text-[11px] mt-1">27 Kitab</div>
        </button>
      </div>
    </div>

    <!-- Step 2: Book Selection -->
    <div id="step-books" class="glass-card p-5 mb-5 hidden">
      <div class="flex items-center justify-between mb-4">
        <h2 id="testament-title" class="text-dkc-gold font-bold text-sm uppercase tracking-wider">—</h2>
        <button id="back-testament" class="text-dkc-muted text-xs border border-dkc-border rounded-lg px-3 py-1 hover:text-dkc-gold hover:border-dkc-gold/30">← Kembali</button>
      </div>
      <div id="book-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-2"></div>
    </div>

    <!-- Step 3: Chapter Selection -->
    <div id="step-chapters" class="glass-card p-5 mb-5 hidden">
      <div class="flex items-center justify-between mb-4">
        <h2 id="book-title" class="text-dkc-gold font-bold text-sm uppercase tracking-wider">—</h2>
        <button id="back-books" class="text-dkc-muted text-xs border border-dkc-border rounded-lg px-3 py-1 hover:text-dkc-gold hover:border-dkc-gold/30">← Kembali</button>
      </div>
      <div id="chapter-grid" class="grid grid-cols-8 sm:grid-cols-10 md:grid-cols-12 gap-1.5"></div>
    </div>

    <!-- Step 4: Verse Selection -->
    <div id="step-verses" class="glass-card p-5 mb-5 hidden">
      <div class="flex items-center justify-between mb-4">
        <h2 id="verse-title" class="text-dkc-gold font-bold text-sm uppercase tracking-wider">—</h2>
        <button id="back-chapters" class="text-dkc-muted text-xs border border-dkc-border rounded-lg px-3 py-1 hover:text-dkc-gold hover:border-dkc-gold/30">← Kembali</button>
      </div>
      <div id="verse-grid" class="grid grid-cols-8 sm:grid-cols-10 md:grid-cols-12 gap-1.5"></div>
    </div>

    <!-- Reading Area -->
    <div id="reading-area" class="glass-card p-5 md:p-6 mb-5 hidden">
      <!-- Action Bar -->
      <div class="flex items-center gap-2 mb-4 pb-3 border-b border-dkc-border/40 flex-wrap">
        <button id="tts-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>
          <span>Bacakan</span>
        </button>
        <button id="tts-stop-btn" class="hidden flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-red-500/40 text-red-400 text-xs hover:bg-red-500/10">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
          <span>Berhenti</span>
        </button>
        <span id="tts-timer" class="hidden text-dkc-muted text-[11px] tabular-nums">00:00</span>
        <button id="bookmark-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold transition-colors">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
          <span>Tandai</span>
        </button>
        <div class="flex items-center gap-1 ml-auto">
          <span class="text-dkc-muted text-[10px]">Aa</span>
          <button data-fsize="sm" class="font-size-btn px-2 py-1 rounded border border-dkc-border text-dkc-muted text-[10px] hover:text-dkc-gold">A</button>
          <button data-fsize="md" class="font-size-btn px-2 py-1 rounded border border-dkc-border text-dkc-muted text-xs hover:text-dkc-gold">A</button>
          <button data-fsize="lg" class="font-size-btn px-2 py-1 rounded border border-dkc-border text-dkc-muted text-sm hover:text-dkc-gold">A</button>
        </div>
        <div class="flex items-center gap-1.5">
          <button id="share-wa" class="w-7 h-7 rounded-full border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-green-400 hover:border-green-400/40" title="WhatsApp"><svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg></button>
          <button id="share-tg" class="w-7 h-7 rounded-full border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-blue-400 hover:border-blue-400/40" title="Telegram"><svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0h-.056zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg></button>
          <button id="share-copy" class="w-7 h-7 rounded-full border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-dkc-gold hover:border-dkc-gold/40" title="Salin"><svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg></button>
        </div>
      </div>

      <!-- Reading Header -->
      <div class="flex justify-between items-center mb-5">
        <div>
          <h2 id="reading-title" class="text-dkc-gold font-bold text-lg">—</h2>
          <p id="reading-subtitle" class="text-dkc-muted text-xs mt-0.5"></p>
        </div>
        <div class="flex gap-2">
          <button id="prev-ch" class="px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold">←</button>
          <button id="next-ch" class="px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold">→</button>
        </div>
      </div>

      <!-- Loading -->
      <div id="reading-loading" class="text-center py-12 text-dkc-muted hidden">
        <div class="inline-block w-6 h-6 border-2 border-dkc-gold/30 border-t-dkc-gold rounded-full animate-spin mb-3"></div>
        <p class="text-sm">Memuat ayat...</p>
      </div>

      <!-- Verses -->
      <div id="reading-content" class="space-y-2 leading-relaxed"></div>
    </div>

    <!-- Bottom Nav -->
    <div id="bottom-nav" class="flex justify-center gap-3 hidden">
      <button id="prev-ch-bottom" class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold">← Bab Sebelumnya</button>
      <button id="next-ch-bottom" class="flex items-center gap-1.5 px-4 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold">Bab Selanjutnya →</button>
    </div>
  </main>

  <Footer />
</BaseLayout>

<slot name="head">
  <title>Kitab Suci — Damai Kasih Channel</title>
  <meta name="description" content="Kitab Suci Katolik Indonesia lengkap. Baca, cari, dan bagikan ayat Alkitab." />
</slot>

<style>
  #reading-content sup { color: rgba(201,168,76,0.7); font-weight: bold; font-size: 0.7rem; margin-right: 0.25rem; }
  #reading-content .verse-row { border-radius: 0.5rem; padding: 0.25rem 0.5rem; margin: 0 -0.5rem; transition: background-color 0.15s; cursor: pointer; }
  #reading-content .verse-row:hover { background: rgba(201,168,76,0.05); }
  #reading-content .verse-row.highlighted { background: rgba(201,168,76,0.1); box-shadow: inset 0 0 0 1px rgba(201,168,76,0.3); }
  #reading-content .verse-row.flash { background: rgba(201,168,76,0.25); box-shadow: inset 0 0 0 2px rgba(201,168,76,0.6); }
  .sel-btn { background: var(--color-dkc-surface); border: 1px solid var(--color-dkc-border); color: var(--color-dkc-muted); border-radius: 0.5rem; padding: 0.4rem 0; font-size: 0.75rem; cursor: pointer; transition: all 0.15s; text-align: center; }
  .sel-btn:hover { border-color: rgba(201,168,76,0.3); color: var(--color-dkc-gold); }
  .sel-btn.active { background: rgba(201,168,76,0.15); color: var(--color-dkc-gold); border-color: rgba(201,168,76,0.4); font-weight: 700; }
  .book-btn-pl { border-color: rgba(180,130,50,0.25); }
  .book-btn-pl:hover, .book-btn-pl.active { border-color: rgba(180,130,50,0.6); background: rgba(180,130,50,0.1); }
  .book-btn-pb { border-color: rgba(200,60,60,0.25); }
  .book-btn-pb:hover, .book-btn-pb.active { border-color: rgba(200,60,60,0.6); background: rgba(200,60,60,0.1); }
  .testament-btn-active { transform: scale(0.97); }
  .font-size-active { border-color: rgba(201,168,76,0.5) !important; color: var(--color-dkc-gold) !important; }
  .version-tab-active { border-color: rgba(201,168,76,0.6) !important; color: var(--color-dkc-gold) !important; background: rgba(201,168,76,0.1); font-weight: 700; }
</style>

<script>
  const BOOK_NAMES: Record<string, string> = {
    kej:"Kejadian",kel:"Keluaran",im:"Imamat",bil:"Bilangan",ul:"Ulangan",
    yos:"Yosua",hak:"Hakim-Hakim",rut:"Rut","1sam":"1 Samuel","2sam":"2 Samuel",
    "1raj":"1 Raja-Raja","2raj":"2 Raja-Raja","1taw":"1 Tawarikh","2taw":"2 Tawarikh",
    ezr:"Ezra",neh:"Nehemia",tob:"Tobit",ydt:"Yudit",est:"Ester",
    ayb:"Ayub",mzm:"Mazmur",ams:"Amsal",pkh:"Pengkhotbah",kid:"Kidung Agung",
    keb:"Kebijaksanaan",sir:"Sirakh",yes:"Yesaya",yer:"Yeremia",rat:"Ratapan",
    bar:"Barukh",yeh:"Yehezkiel",dan:"Daniel",hos:"Hosea",yl:"Yoel",am:"Amos",
    ob:"Obaja",yun:"Yunus",mi:"Mikha",nah:"Nahum",hab:"Habakuk",zef:"Zefanya",
    hag:"Hagai",za:"Zakharia",mal:"Maleakhi","1mak":"1 Makabe","2mak":"2 Makabe",
    mat:"Matius",mrk:"Markus",luk:"Lukas",yoh:"Yohanes",kis:"Kisah Para Rasul",
    rm:"Roma","1kor":"1 Korintus","2kor":"2 Korintus",gal:"Galatia",ef:"Efesus",
    flp:"Filipi",kol:"Kolose","1tes":"1 Tesalonika","2tes":"2 Tesalonika",
    "1tim":"1 Timotius","2tim":"2 Timotius",tit:"Titus",flm:"Filemon",
    ibr:"Ibrani",yak:"Yakobus","1ptr":"1 Petrus","2ptr":"2 Petrus",
    "1yoh":"1 Yohanes","2yoh":"2 Yohanes","3yoh":"3 Yohanes",yud:"Yudas",why:"Wahyu"
  };

  const PL_BOOKS = ["kej","kel","im","bil","ul","yos","hak","rut","1sam","2sam","1raj","2raj","1taw","2taw","ezr","neh","tob","ydt","est","ayb","mzm","ams","pkh","kid","keb","sir","yes","yer","rat","bar","yeh","dan","hos","yl","am","ob","yun","mi","nah","hab","zef","hag","za","mal","1mak","2mak"];
  const PB_BOOKS = ["mat","mrk","luk","yoh","kis","rm","1kor","2kor","gal","ef","flp","kol","1tes","2tes","1tim","2tim","tit","flm","ibr","yak","1ptr","2ptr","1yoh","2yoh","3yoh","yud","why"];

  // State
  let bibleData: any = null;
  let currentBook = "";
  let currentChapter = 0;
  let currentTestament = "";
  let highlightedVerses: Set<number> = new Set();
  let ttsTimer: any = null;
  let ttsSeconds = 0;

  // Version switching
  const VERSIONS: Record<string, { file: string; label: string }> = {
    tb1: { file: '/assets/data/ks.json', label: 'TB' },
    tb2: { file: '/assets/data/ks_tb2.json', label: 'TB2' },
    lds: { file: '/assets/data/ks_2.json', label: 'LDS' },
  };
  let currentVersion = localStorage.getItem('dkc-bible-version') || 'tb1';

  // DOM
  const stepTestament = document.getElementById("step-testament")!;
  const stepBooks = document.getElementById("step-books")!;
  const stepChapters = document.getElementById("step-chapters")!;
  const stepVerses = document.getElementById("step-verses")!;
  const readingArea = document.getElementById("reading-area")!;
  const bottomNav = document.getElementById("bottom-nav")!;
  const bookGrid = document.getElementById("book-grid")!;
  const chapterGrid = document.getElementById("chapter-grid")!;
  const verseGrid = document.getElementById("verse-grid")!;
  const readingContent = document.getElementById("reading-content")!;
  const readingTitle = document.getElementById("reading-title")!;
  const readingSubtitle = document.getElementById("reading-subtitle")!;
  const readingLoading = document.getElementById("reading-loading")!;
  const testamentTitle = document.getElementById("testament-title")!;
  const bookTitle = document.getElementById("book-title")!;
  const verseTitle = document.getElementById("verse-title")!;
  const progressBar = document.getElementById("reading-progress")!;
  const citationInput = document.getElementById("citation-input") as HTMLInputElement;

  // Show/hide steps
  function showStep(step: string) {
    stepTestament.classList.toggle("hidden", step !== "testament");
    stepBooks.classList.toggle("hidden", step !== "books");
    stepChapters.classList.toggle("hidden", step !== "chapters");
    stepVerses.classList.toggle("hidden", step !== "verses");
  }

  // Step 1: Testament -> show books
  document.querySelectorAll(".testament-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const t = btn.getAttribute("data-testament")!;
      currentTestament = t;
      const books = t === "pl" ? PL_BOOKS : PB_BOOKS;
      testamentTitle.textContent = t === "pl" ? "PERJANJIAN LAMA" : "PERJANJIAN BARU";
      bookGrid.innerHTML = "";
      for (const abbr of books) {
        if (!bibleData?.[abbr]) continue;
        const b = document.createElement("button");
        b.className = `sel-btn book-btn-${t} py-3 text-xs font-medium`;
        b.textContent = BOOK_NAMES[abbr] || abbr;
        b.setAttribute("data-book", abbr);
        b.addEventListener("click", () => selectBook(abbr));
        bookGrid.appendChild(b);
      }
      showStep("books");
    });
  });

  // Step 2: Book -> show chapters
  function selectBook(abbr: string) {
    currentBook = abbr;
    bookTitle.textContent = (BOOK_NAMES[abbr] || abbr).toUpperCase();
    bookGrid.querySelectorAll(".sel-btn").forEach(b => b.classList.remove("active"));
    bookGrid.querySelector(`[data-book="${abbr}"]`)?.classList.add("active");
    const book = bibleData[abbr];
    if (!book) return;
    const chapters = Object.keys(book).map(Number).sort((a,b) => a-b);
    chapterGrid.innerHTML = "";
    for (const ch of chapters) {
      const b = document.createElement("button");
      b.className = "sel-btn py-2";
      b.textContent = String(ch);
      b.addEventListener("click", () => selectChapter(abbr, ch));
      chapterGrid.appendChild(b);
    }
    showStep("chapters");
    stepBooks.classList.remove("hidden");
    readingArea.classList.add("hidden");
    bottomNav.classList.add("hidden");
    // Scroll to chapter section
    setTimeout(() => {
      stepChapters.scrollIntoView({ behavior: "smooth", block: "start" });
    }, 100);
  }

  // Step 3: Chapter -> highlight chapter + show verse grid (NOT text)
  function selectChapter(book: string, chapter: number) {
    currentBook = book;
    currentChapter = chapter;
    const bookData = bibleData[book];
    if (!bookData) return;
    const chData = bookData[String(chapter)];
    if (!chData) return;

    // Highlight the clicked chapter
    chapterGrid.querySelectorAll(".sel-btn").forEach(b => b.classList.remove("active"));
    for (const btn of Array.from(chapterGrid.children)) {
      if (btn.textContent === String(chapter)) btn.classList.add("active");
    }

    // Show verse grid
    const verses = Object.keys(chData).map(Number).sort((a,b) => a-b);
    verseTitle.textContent = `${BOOK_NAMES[book] || book} ${chapter}`;
    verseGrid.innerHTML = "";
    for (const v of verses) {
      const b = document.createElement("button");
      b.className = "sel-btn py-2";
      b.textContent = String(v);
      b.addEventListener("click", () => loadAndScrollTo(book, chapter, v));
      verseGrid.appendChild(b);
    }
    // Show verses, keep chapters + books visible, hide reading area
    stepVerses.classList.remove("hidden");
    stepChapters.classList.remove("hidden");
    stepBooks.classList.remove("hidden");
    readingArea.classList.add("hidden");
    bottomNav.classList.add("hidden");

    // Update hash
    window.location.hash = `${book}${chapter}`;
  }

  // Load chapter content
  function loadChapter(book: string, chapter: number) {
    const bookData = bibleData[book];
    const chData = bookData?.[String(chapter)];
    if (!chData) return;

    const bookName = BOOK_NAMES[book] || book;
    readingTitle.textContent = `${bookName} ${chapter}`;
    readingSubtitle.textContent = `${Object.keys(bookData).length} bab • ${Object.keys(chData).length} ayat`;

    // Load highlights
    const hlKey = `dkc-hl-${book}-${chapter}`;
    const saved = JSON.parse(localStorage.getItem(hlKey) || "[]");
    highlightedVerses = new Set(saved);

    const verses = Object.keys(chData).map(Number).sort((a,b) => a-b);
    let html = "";
    for (const v of verses) {
      const text = chData[String(v)];
      const isHl = highlightedVerses.has(v);
      html += `<div class="verse-row${isHl ? " highlighted" : ""}" data-verse="${v}"><sup>${v}</sup><span class="verse-text">${text}</span></div>`;
    }
    readingContent.innerHTML = html;
    readingArea.classList.remove("hidden");
    bottomNav.classList.remove("hidden");
    // Keep chapter + verse grids visible as context above the text
    stepChapters.classList.remove("hidden");
    stepVerses.classList.remove("hidden");

    // URL hash
    window.location.hash = `${book}${chapter}`;
    updateBookmarkState();

    // Scroll to reading area
    readingTitle.scrollIntoView({ behavior: "smooth", block: "start" });
  }

  // Load and scroll to specific verse
  function loadAndScrollTo(book: string, chapter: number, verse: number) {
    loadChapter(book, chapter);
    setTimeout(() => {
      const el = readingContent.querySelector(`[data-verse="${verse}"]`) as HTMLElement;
      if (el) {
        el.classList.add("flash");
        el.scrollIntoView({ behavior: "smooth", block: "center" });
        setTimeout(() => el.classList.remove("flash"), 2000);
      }
    }, 100);
  }

  // Back buttons
  document.getElementById("back-testament")!.addEventListener("click", () => { readingArea.classList.add("hidden"); bottomNav.classList.add("hidden"); showStep("testament"); });
  document.getElementById("back-books")!.addEventListener("click", () => { readingArea.classList.add("hidden"); bottomNav.classList.add("hidden"); showStep("books"); stepBooks.classList.remove("hidden"); });
  document.getElementById("back-chapters")!.addEventListener("click", () => { readingArea.classList.add("hidden"); bottomNav.classList.add("hidden"); showStep("chapters"); stepBooks.classList.remove("hidden"); stepChapters.classList.remove("hidden"); });

  // Prev/Next
  function getAdjacent(delta: number) {
    const book = bibleData[currentBook]; if (!book) return null;
    const chapters = Object.keys(book).map(Number).sort((a,b)=>a-b);
    const idx = chapters.indexOf(currentChapter);
    const ni = idx + delta;
    if (ni >= 0 && ni < chapters.length) return { book: currentBook, chapter: chapters[ni] };
    const allBooks = currentTestament === "pl" ? PL_BOOKS : PB_BOOKS;
    const bi = allBooks.indexOf(currentBook) + delta;
    if (bi >= 0 && bi < allBooks.length && bibleData[allBooks[bi]]) {
      const nb = allBooks[bi];
      const nc = Object.keys(bibleData[nb]).map(Number).sort((a,b)=>a-b);
      return { book: nb, chapter: delta > 0 ? nc[0] : nc[nc.length-1] };
    }
    return null;
  }
  function goAdjacent(delta: number) {
    const adj = getAdjacent(delta);
    if (adj) {
      selectChapter(adj.book, adj.chapter);
      loadChapter(adj.book, adj.chapter);
    }
  }
  document.getElementById("prev-ch")!.addEventListener("click", () => goAdjacent(-1));
  document.getElementById("next-ch")!.addEventListener("click", () => goAdjacent(1));
  document.getElementById("prev-ch-bottom")!.addEventListener("click", () => goAdjacent(-1));
  document.getElementById("next-ch-bottom")!.addEventListener("click", () => goAdjacent(1));
  document.addEventListener("keydown", (e) => {
    if (document.activeElement === citationInput) return;
    if (e.key === "ArrowLeft") goAdjacent(-1);
    if (e.key === "ArrowRight") goAdjacent(1);
  });

  // Citation parser
  function parseCitation(input: string) {
    const m = input.trim().toLowerCase().replace(/\s+/g," ").match(/^(\d?\w+)\s*(\d+)\s*(?::\s*([0-9,\-]+))?$/);
    if (!m) return null;
    const abbr = m[1], ch = parseInt(m[2]), vs = m[3];
    let bk: string|null = null;
    for (const k of Object.keys(bibleData)) {
      const n = (BOOK_NAMES[k]||"").toLowerCase();
      if (k === abbr || n.replace(/[^a-z]/g,"").startsWith(abbr.replace(/[^a-z]/g,""))) { bk = k; break; }
    }
    if (!bk) return null;
    let verses: number[]|undefined;
    if (vs) { verses = []; for (const p of vs.split(",")) { if (p.includes("-")) { const [a,b] = p.split("-").map(Number); for (let i=a;i<=b;i++) verses.push(i); } else verses.push(parseInt(p)); } }
    return { book: bk, chapter: ch, verses };
  }
  document.getElementById("citation-go")!.addEventListener("click", () => {
    const r = parseCitation(citationInput.value);
    if (r) { if (r.verses?.length) loadAndScrollTo(r.book, r.chapter, r.verses[0]); else selectChapter(r.book, r.chapter); }
  });
  citationInput.addEventListener("keydown", (e) => { if (e.key === "Enter") document.getElementById("citation-go")!.click(); });

  // TTS
  const ttsBtn = document.getElementById("tts-btn")!;
  const ttsStopBtn = document.getElementById("tts-stop-btn")!;
  const ttsTimerEl = document.getElementById("tts-timer")!;
  ttsBtn.addEventListener("click", () => {
    if (!("speechSynthesis" in window)) return;
    speechSynthesis.cancel();
    const text = Array.from(readingContent.querySelectorAll(".verse-text")).map(el => el.textContent).join(" ");
    if (!text) return;
    const u = new SpeechSynthesisUtterance(text);
    u.lang = "id-ID"; u.rate = 0.9;
    const idV = speechSynthesis.getVoices().find(v => v.lang.startsWith("id"));
    if (idV) u.voice = idV;
    ttsBtn.classList.add("hidden"); ttsStopBtn.classList.remove("hidden"); ttsTimerEl.classList.remove("hidden");
    ttsSeconds = 0;
    ttsTimer = setInterval(() => { ttsSeconds++; const m = String(Math.floor(ttsSeconds/60)).padStart(2,"0"); const s = String(ttsSeconds%60).padStart(2,"0"); ttsTimerEl.textContent = `${m}:${s}`; }, 1000);
    u.onend = () => { ttsBtn.classList.remove("hidden"); ttsStopBtn.classList.add("hidden"); ttsTimerEl.classList.add("hidden"); clearInterval(ttsTimer); };
    speechSynthesis.speak(u);
  });
  ttsStopBtn.addEventListener("click", () => { speechSynthesis.cancel(); ttsBtn.classList.remove("hidden"); ttsStopBtn.classList.add("hidden"); ttsTimerEl.classList.add("hidden"); clearInterval(ttsTimer); });

  // Highlight verses on click
  readingContent.addEventListener("click", (e) => {
    const row = (e.target as HTMLElement).closest(".verse-row") as HTMLElement;
    if (!row) return;
    const v = parseInt(row.getAttribute("data-verse") || "0");
    if (!v) return;
    const hlKey = `dkc-hl-${currentBook}-${currentChapter}`;
    if (highlightedVerses.has(v)) { highlightedVerses.delete(v); row.classList.remove("highlighted"); }
    else { highlightedVerses.add(v); row.classList.add("highlighted"); }
    localStorage.setItem(hlKey, JSON.stringify([...highlightedVerses]));
  });

  // Bookmark
  const BK_KEY = "dkc-bible-bookmarks";
  const bookmarkBtn = document.getElementById("bookmark-btn")!;
  function getBookmarks() { return JSON.parse(localStorage.getItem(BK_KEY)||"[]"); }
  function updateBookmarkState() {
    const ref = `${currentBook} ${currentChapter}`;
    bookmarkBtn.style.borderColor = getBookmarks().includes(ref) ? "rgba(201,168,76,0.6)" : "";
    bookmarkBtn.style.color = getBookmarks().includes(ref) ? "var(--color-dkc-gold)" : "";
  }
  bookmarkBtn.addEventListener("click", () => {
    const ref = `${currentBook} ${currentChapter}`;
    const bms = getBookmarks();
    if (bms.includes(ref)) { localStorage.setItem(BK_KEY, JSON.stringify(bms.filter((b:string)=>b!==ref))); }
    else { bms.push(ref); localStorage.setItem(BK_KEY, JSON.stringify(bms)); }
    updateBookmarkState();
  });

  // Font size
  const FONT_MAP: Record<string,string> = { sm:"13px", md:"15px", lg:"18px" };
  document.querySelectorAll(".font-size-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const s = btn.getAttribute("data-fsize")||"md";
      readingContent.style.fontSize = FONT_MAP[s];
      document.querySelectorAll(".font-size-btn").forEach(b => b.classList.remove("font-size-active"));
      btn.classList.add("font-size-active");
      localStorage.setItem("dkc-bible-fontsize", s);
    });
  });
  const savedFS = localStorage.getItem("dkc-bible-fontsize");
  if (savedFS && FONT_MAP[savedFS]) { readingContent.style.fontSize = FONT_MAP[savedFS]; document.querySelector(`.font-size-btn[data-fsize="${savedFS}"]`)?.classList.add("font-size-active"); }
  else document.querySelector('.font-size-btn[data-fsize="md"]')?.classList.add("font-size-active");

  // Share
  function shareUrl() { return `${location.origin}/kitabsuci#${currentBook}${currentChapter}`; }
  function shareText() { const n=BOOK_NAMES[currentBook]||currentBook; const t=readingContent.querySelector(".verse-text")?.textContent||""; return `${n} ${currentChapter}: "${t.slice(0,100)}..." — DKC`; }
  document.getElementById("share-wa")!.addEventListener("click", () => window.open(`https://wa.me/?text=${encodeURIComponent(shareText()+" "+shareUrl())}`,"_blank"));
  document.getElementById("share-tg")!.addEventListener("click", () => window.open(`https://t.me/share/url?url=${encodeURIComponent(shareUrl())}&text=${encodeURIComponent(shareText())}`,"_blank"));
  document.getElementById("share-copy")!.addEventListener("click", () => { navigator.clipboard.writeText(shareUrl()); const b=document.getElementById("share-copy")!; b.style.borderColor="rgba(201,168,76,0.6)"; setTimeout(()=>b.style.borderColor="",1500); });

  // Progress bar
  window.addEventListener("scroll", () => { const h=document.documentElement; progressBar.style.width = Math.min((h.scrollTop/(h.scrollHeight-h.clientHeight))*100,100)+"%"; });

  // Version tabs
  function updateVersionTabs() {
    document.querySelectorAll('.version-tab').forEach(btn => {
      btn.classList.toggle('version-tab-active', btn.getAttribute('data-version') === currentVersion);
    });
  }
  async function switchVersion(ver: string) {
    if (ver === currentVersion && bibleData) return;
    currentVersion = ver;
    localStorage.setItem('dkc-bible-version', ver);
    updateVersionTabs();
    readingLoading.classList.remove('hidden');
    const resp = await fetch(VERSIONS[ver].file);
    bibleData = await resp.json();
    readingLoading.classList.add('hidden');
    // Rebuild current view if a book is selected
    if (currentBook && bibleData[currentBook]) {
      if (currentChapter && bibleData[currentBook][String(currentChapter)]) {
        selectChapter(currentBook, currentChapter);
        loadChapter(currentBook, currentChapter);
      } else {
        selectBook(currentBook);
      }
    }
  }
  document.querySelectorAll('.version-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const ver = btn.getAttribute('data-version');
      if (ver) switchVersion(ver);
    });
  });
  updateVersionTabs();

  // Init
  async function init() {
    readingLoading.classList.remove("hidden");
    const resp = await fetch(VERSIONS[currentVersion].file);
    bibleData = await resp.json();
    readingLoading.classList.add("hidden");

    // Check hash
    const hash = location.hash.slice(1);
    if (hash) {
      const m = hash.match(/^(\d?\w+?)(\d+)(?::([0-9,\-]+))?$/);
      if (m && bibleData[m[1]]?.[m[2]]) {
        const vs = m[3] ? parseInt(m[3].split(",")[0].split("-")[0]) : 0;
        currentTestament = PL_BOOKS.includes(m[1]) ? "pl" : "pb";
        if (vs) loadAndScrollTo(m[1], parseInt(m[2]), vs);
        else selectChapter(m[1], parseInt(m[2]));
        return;
      }
    }
    // Check ?q= param
    const qp = new URLSearchParams(location.search).get("q");
    if (qp) {
      const r = parseCitation(qp);
      if (r && bibleData[r.book]?.[String(r.chapter)]) {
        currentTestament = PL_BOOKS.includes(r.book) ? "pl" : "pb";
        if (r.verses?.length) loadAndScrollTo(r.book, r.chapter, r.verses[0]);
        else selectChapter(r.book, r.chapter);
        return;
      }
    }
  }
  init();
</script>
