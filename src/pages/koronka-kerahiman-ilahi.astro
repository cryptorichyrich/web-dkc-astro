---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />

  <main class="max-w-2xl mx-auto px-4 pt-8 pb-24">
    <!-- Header -->
    <div class="text-center mb-8">
      <span class="text-4xl">✨</span>
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mt-3">Koronka Kerahiman Ilahi</h1>
      <p class="text-dkc-muted text-sm mt-1">Divine Mercy Chaplet — Devosi kepada Kerahiman Yesus</p>
    </div>

    <!-- Opening Prayer Card -->
    <div class="glass-card p-6 md:p-8 mb-5">
      <h2 class="text-sm font-semibold text-dkc-gold uppercase tracking-wider mb-4">
        🕊️ Doa Pembuka
      </h2>
      <div class="space-y-4 text-dkc-text leading-relaxed text-base">

        <div class="bg-dkc-surface/50 rounded-xl p-4 border-l-4 border-dkc-gold/30">
          <p class="text-xs text-dkc-gold/70 font-semibold uppercase tracking-wider mb-2">Tanda Salib</p>
          <p>Dalam nama Bapa dan Putra dan Roh Kudus. <span class="text-dkc-gold font-semibold">Amin.</span></p>
        </div>

        <div class="space-y-3">
          <p class="text-xs text-dkc-gold/70 font-semibold uppercase tracking-wider">Doa Kerahiman Ilahi</p>
          <p>
            Ya Yesus,<br />
            Engkau telah wafat,<br />
            namun sumber kehidupan telah memancar bagi jiwa-jiwa,<br />
            Dan terbukalah lautan kerahiman bagi seluruh dunia,<br />
            O Sumber kehidupan, Kerahiman ilahi yang tak terselami,<br />
            Naungilah segenap dunia, dan curahkanlah diri-Mu pada kami.<br />
            O, Darah dan Air, yang telah memancar dari Hati Yesus,<br />
            sebagai Sumber Kerahiman bagi kami,<br />
            Engkaulah andalanku!
          </p>
        </div>

        <div class="bg-dkc-gold/5 rounded-xl p-4 border border-dkc-gold/20 text-center">
          <p class="text-dkc-gold font-semibold">
            Allah yang Kudus, Kudus dan berkuasa,<br />
            Kudus dan kekal, kasihanilah kami,<br />
            dan seluruh dunia ….. <span class="text-dkc-muted text-sm">(3×</span>)
          </p>
        </div>

        <p class="text-center">
          Yesus, Raja Kerahiman Ilahi,<br />
          Engkaulah Andalanku.<br />
          <span class="text-dkc-gold font-semibold">Amin.</span>
        </p>
      </div>
    </div>

    <!-- Rosary Beads Section -->
    <div class="glass-card p-6 md:p-8 mb-5">
      <h2 class="text-sm font-semibold text-dkc-gold uppercase tracking-wider mb-4">
        📿 Pada Manik-manik Rosario
      </h2>
      <div class="space-y-5 text-dkc-text leading-relaxed text-base">

        <!-- Our Father beads -->
        <div class="bg-dkc-surface/50 rounded-xl p-4 border-l-4 border-dkc-gold/40">
          <p class="text-xs text-dkc-gold/70 font-semibold uppercase tracking-wider mb-2">
            Pada Manik Bapa Kami (manik besar) — 5×
          </p>
          <p>
            Bapa yang kekal, aku persembahkan kepada-Mu Tubuh dan Darah, Jiwa dan Ke-Allahan
            Putra-Mu yang terkasih, Tuhan kami Yesus Kristus, sebagai penebus dosa-dosa kami
            dan dosa-dosa seluruh dunia.
          </p>
        </div>

        <!-- Hail Mary beads -->
        <div class="bg-dkc-surface/50 rounded-xl p-4 border-l-4 border-dkc-gold/20">
          <p class="text-xs text-dkc-gold/70 font-semibold uppercase tracking-wider mb-2">
            Pada Manik Salam Maria (10 manik kecil) — setiap dekade
          </p>
          <p>
            Demi sengsara-Nya yang pedih, kasihanilah kami dan seluruh dunia.
          </p>
          <p class="text-dkc-muted text-xs mt-2 italic">
            Ulangi 10 kali pada setiap dekade (5 dekade total).
          </p>
        </div>

      </div>
    </div>

    <!-- Closing Prayer Card -->
    <div class="glass-card p-6 md:p-8 mb-6">
      <h2 class="text-sm font-semibold text-dkc-gold uppercase tracking-wider mb-4">
        🙏 Doa Penutup
      </h2>
      <div class="space-y-5 text-dkc-text leading-relaxed text-base">

        <div class="bg-dkc-gold/5 rounded-xl p-4 border border-dkc-gold/20 text-center">
          <p class="text-dkc-gold font-semibold">
            Maha Kudus Allah, Maha Kudus yang Perkasa, Maha Kudus yang Kekal,<br />
            kasihanilah kami dan seluruh dunia.
          </p>
          <p class="text-dkc-muted text-xs mt-2 italic">
            Ulangi 3 kali.
          </p>
        </div>

        <div class="border-t border-dkc-border/50 pt-4 space-y-3">
          <p class="text-xs text-dkc-gold/70 font-semibold uppercase tracking-wider">
            Doa Penutup Opsional
          </p>
          <p>
            Ya Tuhan Yesus yang kekal, Raja penuh kerahiman, pada saat kerahiman-Mu yang agung,
            kasihanilah kami dan seluruh dunia.
            <span class="text-dkc-gold font-semibold">Amin.</span>
          </p>
        </div>
      </div>
    </div>

    <!-- About Card -->
    <div class="glass-card p-5 md:p-6 mb-6">
      <h2 class="text-sm font-semibold text-dkc-gold uppercase tracking-wider mb-3">
        📖 Tentang Koronka Kerahiman Ilahi
      </h2>
      <p class="text-dkc-muted text-sm leading-relaxed">
        Koronka Kerahiman Ilahi adalah doa yang diajarkan oleh Yesus kepada Santa Faustina Kowalska
        pada tahun 1935. Doa ini dipanjatkan menggunakan rosario biasa dan memohon kerahiman Allah
        bagi kita dan seluruh dunia.
      </p>
      <div class="mt-3 space-y-2">
        <div class="bg-dkc-surface/50 rounded-lg p-3">
          <p class="text-dkc-muted text-xs">
            <span class="text-dkc-gold font-semibold">⏰ Waktu Istimewa:</span>
            Pukul 15:00 (3 sore) setiap hari — jam kematian Yesus di kayu salib.
            Yesus berjanji bahwa pada jam ini, Dia tidak akan menolak apapun yang dimohonkan
            dalam nama kerahiman-Nya.
          </p>
        </div>
        <div class="bg-dkc-surface/50 rounded-lg p-3">
          <p class="text-dkc-muted text-xs">
            <span class="text-dkc-gold font-semibold">📿 Cara Berdoa:</span>
            Gunakan rosario biasa. Mulai dengan Tanda Salib dan doa pembuka, lalu pada manik besar
            ucapkan doa "Bapa yang kekal...", dan pada 10 manik kecil ucapkan "Demi sengsara-Nya...".
            Ulangi untuk 5 dekade, lalu akhiri dengan doa penutup 3 kali.
          </p>
        </div>
      </div>
    </div>

    <!-- Share Button -->
    <div class="text-center">
      <button
        id="btn-share"
        class="px-5 py-2.5 rounded-full border border-dkc-border text-dkc-muted text-sm transition-all active:scale-95 hover:border-dkc-gold/40 hover:text-dkc-gold"
      >
        📤 Bagikan Doa
      </button>
    </div>
  </main>

  <Footer />
</BaseLayout>

<title>Koronka Kerahiman Ilahi — Damai Kasih Channel</title>
<meta name="description" content="Koronka Kerahiman Ilahi, doa devosi Katolik kepada Kerahiman Yesus, termasuk makna Jam Kerahiman dan cara mendoakannya." />

<script>
  const btnShare = document.getElementById("btn-share");
  btnShare?.addEventListener("click", () => {
    const text = `✨ Koronka Kerahiman Ilahi\n\nPembuka:\nYa Yesus, Engkau telah wafat, namun sumber kehidupan telah memancar bagi jiwa-jiwa...\n\nAllah yang Kudus, Kudus dan berkuasa, Kudus dan kekal, kasihanilah kami dan seluruh dunia. (3×)\n\nPada manik besar:\nBapa yang kekal, aku persembahkan kepada-Mu Tubuh dan Darah, Jiwa dan Ke-Allahan Putra-Mu... sebagai penebus dosa-dosa kami dan dosa-dosa seluruh dunia.\n\nPada manik kecil (10×):\nDemi sengsara-Nya yang pedih, kasihanilah kami dan seluruh dunia.\n\nPenutup (3×):\nMaha Kudus Allah, Maha Kudus yang Perkasa, Maha Kudus yang Kekal, kasihanilah kami dan seluruh dunia.\n\n#KerahimanIlahi #DivineMercy #DamaiKasihChannel`;

    if (navigator.share) {
      navigator.share({ title: "Koronka Kerahiman Ilahi", text }).catch(() => {});
    } else {
      navigator.clipboard.writeText(text).then(() => {
        const orig = btnShare.textContent;
        btnShare.textContent = "✅ Tersalin!";
        setTimeout(() => { btnShare.textContent = orig; }, 1500);
      }).catch(() => {});
    }
  });
</script>
