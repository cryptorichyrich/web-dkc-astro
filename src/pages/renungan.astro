---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";

const allPosts = await getCollection("blog");
const renunganPosts = allPosts
  .filter(p => p.data.tags?.some(t => t === "Renungan"))
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const POSTS_PER_PAGE = 10;
const totalPages = Math.ceil(renunganPosts.length / POSTS_PER_PAGE);
---

<BaseLayout>
  <Navbar />
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <div class="text-center mb-8">
      <span class="text-4xl">🙏</span>
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mt-3">Renungan Harian Katolik</h1>
      <p class="text-dkc-muted text-sm mt-1">{renunganPosts.length} renungan · Diperbarui setiap hari</p>
    </div>

    <!-- Ibadat waktu indicator -->
    <div class="glass-card p-4 mb-6 text-center">
      <p id="ibadat-period" class="text-dkc-gold font-semibold text-sm"></p>
      <p id="ibadat-desc" class="text-dkc-muted text-xs mt-1"></p>
    </div>

    <div id="renungan-list" class="space-y-4">
    </div>

    <!-- Pagination -->
    <div id="pagination" class="flex justify-center gap-2 mt-8 flex-wrap">
    </div>
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ posts: renunganPosts.map(p => ({
  id: p.id,
  title: p.data.title,
  date: p.data.publishedAt,
  author: p.data.author,
  tags: p.data.tags,
  image: p.data.coverImage || p.data.thumbnailImage || p.data.heroImage || null,
  excerpt: p.data.excerpt || null
})), perPage: POSTS_PER_PAGE, totalPages }}>
  let currentPage = 1;

  const periods = [
    { name: "Laudes (Ibadat Pagi)", range: [5, 8], desc: "Waktu ibadat pagi — pujian pagi kepada Tuhan", icon: "🌅" },
    { name: "Tertia (Ibadat Jam 9)", range: [8, 11], desc: "Waktu ibadat tengah pagi", icon: "☀️" },
    { name: "Sexta (Ibadat Siang)", range: [11, 14], desc: "Waktu ibadat tengah hari", icon: "🌞" },
    { name: "Nona (Ibadat Jam 3)", range: [14, 17], desc: "Waktu ibadat sore", icon: "🌤" },
    { name: "Vesper (Ibadat Petang)", range: [17, 20], desc: "Waktu ibadat sore — pujian petang", icon: "🌇" },
    { name: "Kompletorium (Ibadat Malam)", range: [20, 23], desc: "Waktu ibadat penutup sebelum tidur", icon: "🌙" },
    { name: "Matutinum (Ibadat Tengah Malam)", range: [23, 5], desc: "Waktu ibadat bacaan malam", icon: "🌑" },
  ];

  function updateIbadat() {
    const h = new Date().getHours();
    const period = periods.find(p => {
      if (p.range[0] < p.range[1]) return h >= p.range[0] && h < p.range[1];
      return h >= p.range[0] || h < p.range[1];
    });
    const el = document.getElementById("ibadat-period");
    const desc = document.getElementById("ibadat-desc");
    if (el && period) el.textContent = `${period.icon} ${period.name}`;
    if (desc && period) desc.textContent = period.desc;
  }
  updateIbadat();

  function formatDate(dateStr) {
    if (!dateStr) return "";
    const d = new Date(dateStr);
    return d.toLocaleDateString("id-ID", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
  }

  function renderPage(page) {
    currentPage = page;
    const start = (page - 1) * perPage;
    const end = start + perPage;
    const slice = posts.slice(start, end);

    const container = document.getElementById("renungan-list");
    if (!slice.length) {
      container.innerHTML = '<div class="text-center text-dkc-muted py-12"><span class="text-4xl block mb-3">🙏</span><p>Belum ada renungan.</p></div>';
      return;
    }

    container.innerHTML = slice.map(post => {
      const dateStr = formatDate(post.date);
      return `
        <a href="/blog/${post.id}" class="glass-card p-4 flex gap-4 group transition-all hover:border-dkc-gold/40">
          ${post.image ? `<div class="w-20 h-20 md:w-24 md:h-24 rounded-lg bg-dkc-card overflow-hidden shrink-0"><img src="${post.image}" alt="" class="w-full h-full object-cover" loading="lazy" onerror="this.style.display='none'" /></div>` : '<div class="w-20 h-20 md:w-24 md:h-24 rounded-lg bg-dkc-surface flex items-center justify-center shrink-0 text-2xl">🙏</div>'}
          <div class="min-w-0 flex-1">
            <h3 class="text-dkc-text font-semibold text-sm leading-snug line-clamp-2 group-hover:text-dkc-gold transition-colors">${post.title}</h3>
            <div class="flex items-center gap-2 mt-1.5 text-xs text-dkc-muted flex-wrap">
              <span>${post.author || "DKC Team"}</span>
              <span>·</span>
              <time>${dateStr}</time>
            </div>
            ${post.tags?.length ? `<div class="flex flex-wrap gap-1 mt-2">${post.tags.slice(0,3).map(t => `<span class="text-[10px] px-1.5 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">${t}</span>`).join("")}</div>` : ""}
          </div>
        </a>
      `;
    }).join("");

    // Pagination
    const pag = document.getElementById("pagination");
    if (totalPages <= 1) { pag.innerHTML = ""; return; }

    let btns = [];
    btns.push(`<button data-page="${page-1}" class="px-3 py-1.5 rounded-lg text-xs ${page <= 1 ? 'opacity-30 cursor-not-allowed' : 'glass-card text-dkc-muted hover:text-dkc-gold'}" ${page <= 1 ? 'disabled' : ''}>←</button>`);

    for (let i = 1; i <= totalPages; i++) {
      if (i === page) {
        btns.push(`<button class="px-3 py-1.5 rounded-lg text-xs bg-dkc-gold/20 text-dkc-gold border border-dkc-gold/30 font-semibold">${i}</button>`);
      } else if (Math.abs(i - page) <= 2 || i === 1 || i === totalPages) {
        btns.push(`<button data-page="${i}" class="px-3 py-1.5 rounded-lg text-xs glass-card text-dkc-muted hover:text-dkc-gold">${i}</button>`);
      } else if (Math.abs(i - page) === 3) {
        btns.push(`<span class="text-dkc-muted text-xs">...</span>`);
      }
    }

    btns.push(`<button data-page="${page+1}" class="px-3 py-1.5 rounded-lg text-xs ${page >= totalPages ? 'opacity-30 cursor-not-allowed' : 'glass-card text-dkc-muted hover:text-dkc-gold'}" ${page >= totalPages ? 'disabled' : ''}>→</button>`);

    pag.innerHTML = btns.join("");
    pag.querySelectorAll("button[data-page]").forEach(btn => {
      btn.addEventListener("click", () => {
        const p = parseInt(btn.dataset.page);
        if (p >= 1 && p <= totalPages) {
          renderPage(p);
          window.scrollTo({ top: 0, behavior: "smooth" });
        }
      });
    });

    history.replaceState(null, "", `#${page}`);
  }

  // Init from hash
  const hashPage = parseInt(location.hash.slice(1));
  renderPage((hashPage >= 1 && hashPage <= totalPages) ? hashPage : 1);
</script>
