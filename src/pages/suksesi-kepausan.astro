---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
import { popes } from "@/data/popes";

const currentPope = popes[popes.length - 1];
const previousPopes = popes.slice(0, -1).reverse();
const recentPopes = previousPopes.slice(0, 9);
const olderPopes = previousPopes.slice(9);
---

<BaseLayout>
  <Navbar />
  
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <h1 class="section-title text-3xl">Suksesi Kepausan</h1>
    <p class="text-dkc-muted mb-8">Daftar {popes.length} Paus Gereja Katolik dari Santo Petrus hingga sekarang</p>

    <!-- Intro: Apa itu Suksesi Kepausan -->
    <div class="glass-card p-5 mb-6">
      <h2 class="text-dkc-gold font-semibold mb-3">Apa itu Suksesi Kepausan?</h2>
      <p class="text-dkc-text text-sm leading-relaxed">
        Suksesi kepausan adalah rantai penerus Santo Petrus yang diangkat menjadi Paus sepanjang sejarah Gereja Katolik.
        Gereja meyakini bahwa Santo Petrus menerima mandat langsung dari Kristus
        (<em class="text-dkc-gold">"Engkau adalah Petrus dan di atas batu karang ini Aku akan mendirikan Gereja-Ku"</em> — Mat 16:18-19)
        dan bahwa kesinambungan jabatan ini dijamin oleh Roh Kudus.
      </p>
    </div>

    <!-- Current Pope Card -->
    <div class="glass-card p-5 mb-8 border-dkc-gold/30">
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-full bg-dkc-gold/10 border-2 border-dkc-gold/40 flex items-center justify-center text-dkc-gold text-2xl font-bold shrink-0">
          Ⲡ
        </div>
        <div>
          <span class="text-[10px] font-medium bg-dkc-gold/20 text-dkc-gold px-2 py-0.5 rounded-full uppercase tracking-wider">Paus ke-{currentPope[0]}</span>
          <h2 class="text-xl text-dkc-gold font-bold mt-1">Paus {currentPope[1]}</h2>
          <p class="text-dkc-muted text-xs mt-0.5">{currentPope[2]}</p>
        </div>
      </div>
      <p class="text-dkc-text text-sm mt-4 leading-relaxed">
        Dalam ajaran Katolik, Paus merupakan penerus Santo Petrus yang melayani sebagai pengganti Kristus di bumi
        (<em>Vikaris Kristus</em>), gembala umum Gereja, dan tonggak kesatuan iman umat beriman.
      </p>
    </div>

    <!-- Recent Popes (expanded cards) -->
    <h2 class="text-dkc-gold font-semibold text-sm uppercase tracking-wider mb-3">Paus-Paus Terkini</h2>
    <div class="space-y-2 mb-8">
      {recentPopes.map(([num, name, years]) => (
        <div class="glass-card p-3 flex items-center gap-3">
          <span class="w-9 h-9 rounded-full bg-dkc-surface border border-dkc-border flex items-center justify-center text-dkc-gold text-xs font-bold shrink-0">
            {num}
          </span>
          <span class="text-dkc-text font-medium text-sm flex-1">{name}</span>
          <span class="text-dkc-muted text-xs shrink-0">{years}</span>
        </div>
      ))}
    </div>

    <!-- Full List: Collapsible -->
    <details class="group">
      <summary class="glass-card p-4 flex items-center justify-between cursor-pointer hover:border-dkc-gold/30 transition-colors list-none">
        <span class="text-dkc-gold font-semibold text-sm">Daftar Lengkap {popes.length} Paus</span>
        <svg class="w-4 h-4 text-dkc-muted group-open:rotate-180 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </summary>
      <div class="space-y-1 mt-2 max-h-[70vh] overflow-y-auto pr-1">
        {olderPopes.map(([num, name, years]) => (
          <div class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-dkc-card/50 transition-colors">
            <span class="w-7 h-7 rounded-full bg-dkc-surface/50 border border-dkc-border/50 flex items-center justify-center text-dkc-gold/70 text-[10px] font-bold shrink-0">
              {num}
            </span>
            <span class="text-dkc-text text-sm flex-1">{name}</span>
            <span class="text-dkc-muted text-xs shrink-0">{years}</span>
          </div>
        ))}
      </div>
    </details>
  </main>

  <Footer />

  <slot name="head">
    <title>Suksesi Kepausan — Damai Kasih Channel</title>
    <meta name="description" content="Daftar lengkap 267 Paus Gereja Katolik dari Santo Petrus hingga Paus Leo XIV. Suksesi kepausan dan makna teologis." />
  </slot>
</BaseLayout>
