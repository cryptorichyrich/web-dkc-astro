---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <div class="text-center mb-8">
      <span class="text-4xl">📗</span>
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mt-3">Summa Theologiae</h1>
      <p class="text-dkc-muted text-sm mt-1">Karya magnum Santo Thomas Aquinas, O.P. (1225–1274)</p>
    </div>

    <div class="glass-card p-6 mb-6">
      <p class="text-dkc-text text-sm leading-relaxed mb-4">
        <em>Summa Theologiae</em> (1265–1274) adalah salah satu karya paling berpengaruh dalam sejarah teologi dan filsafat Barat.
        Ditulis oleh Santo Thomas Aquinas sebagai panduan bagi pemula dalam teologi, karya ini terdiri dari tiga bagian utama
        yang membahas segala aspek iman Kristiani secara sistematis.
      </p>
      <div class="flex flex-wrap gap-3 justify-center text-xs text-dkc-muted">
        <span class="px-3 py-1 rounded-full bg-dkc-surface border border-dkc-border">3 Bagian Utama</span>
        <span class="px-3 py-1 rounded-full bg-dkc-surface border border-dkc-border">512 Pertanyaan</span>
        <span class="px-3 py-1 rounded-full bg-dkc-surface border border-dkc-border">2.669 Artikel</span>
      </div>
    </div>

    <!-- Parts -->
    <div class="space-y-4">
      <div class="glass-card p-5">
        <div class="flex items-start gap-3">
          <span class="text-dkc-gold font-bold text-lg bg-dkc-gold/10 w-10 h-10 rounded-lg flex items-center justify-center shrink-0">I</span>
          <div>
            <h2 class="text-dkc-gold font-semibold">Prima Pars — Tentang Allah</h2>
            <p class="text-dkc-text text-sm leading-relaxed mt-1">Membahas keberadaan dan sifat Allah, Tritunggal Mahakudus, penciptaan, malaikat, dan alam materi. 119 pertanyaan.</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Keberadaan Allah</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Tritunggal</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Penciptaan</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Malaikat</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Manusia</span>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-card p-5">
        <div class="flex items-start gap-3">
          <span class="text-dkc-gold font-bold text-lg bg-dkc-gold/10 w-10 h-10 rounded-lg flex items-center justify-center shrink-0">II</span>
          <div>
            <h2 class="text-dkc-gold font-semibold">Prima Secundae — Kebajikan & Moral</h2>
            <p class="text-dkc-text text-sm leading-relaxed mt-1">Membahas tindakan manusia, kebajikan, dosa, hukum ilahi, rahmat, dan kebebasan kehendak. 114 pertanyaan.</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Kebajikan</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Dosa</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Hukum</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Rahmat</span>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-card p-5">
        <div class="flex items-start gap-3">
          <span class="text-dkc-gold font-bold text-lg bg-dkc-gold/10 w-10 h-10 rounded-lg flex items-center justify-center shrink-0">III</span>
          <div>
            <h2 class="text-dkc-gold font-semibold">Secunda Secundae — Teologi Kebajikan</h2>
            <p class="text-dkc-text text-sm leading-relaxed mt-1">Penerapan kebajikan secara rinci: iman, harapan, kasih, keadilan, kebijaksanaan, dan karunia Roh Kudus. 189 pertanyaan.</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Iman</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Harapan</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Kasih</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Prudence</span>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-card p-5">
        <div class="flex items-start gap-3">
          <span class="text-dkc-gold font-bold text-lg bg-dkc-gold/10 w-10 h-10 rounded-lg flex items-center justify-center shrink-0">IV</span>
          <div>
            <h2 class="text-dkc-gold font-semibold">Tertia Pars — Kristus & Sakramen</h2>
            <p class="text-dkc-text text-sm leading-relaxed mt-1">Membahas Inkarnasi, kehidupan Kristus, dan tujuh sakramen. 90 pertanyaan (tidak diselesaikan — dilanjutkan oleh muridnya).</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Inkarnasi</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Sakramen</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Ekaristi</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- External resources -->
    <div class="glass-card p-5 mt-6">
      <h3 class="text-dkc-gold font-semibold text-sm mb-3">🔗 Sumber Bacaan</h3>
      <div class="space-y-2">
        <a href="https://www.newadvent.org/summa/" target="_blank" rel="noopener" class="flex items-center gap-2 text-dkc-text text-sm hover:text-dkc-gold transition-colors">
          <span>🌐</span> New Advent — Teks lengkap bahasa Inggris
        </a>
        <a href="https://www.corpusthomisticum.org/iopera.html" target="_blank" rel="noopener" class="flex items-center gap-2 text-dkc-text text-sm hover:text-dkc-gold transition-colors">
          <span>🌐</span> Corpus Thomisticum — Teks asli Latin
        </a>
        <a href="https://aquinas101.thomisticinstitute.org/" target="_blank" rel="noopener" class="flex items-center gap-2 text-dkc-text text-sm hover:text-dkc-gold transition-colors">
          <span>🌐</span> Aquinas 101 — Pengantar interaktif
        </a>
      </div>
    </div>

    <div class="text-center mt-8">
      <p class="text-dkc-muted text-xs">📝 Fitur pencarian lengkap akan segera tersedia</p>
    </div>
  </main>
  <Footer />
</BaseLayout>
