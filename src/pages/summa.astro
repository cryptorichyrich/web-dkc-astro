---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Fragment slot="head">
    <title>Summa Theologiae — Damai Kasih Channel</title>
    <meta name="description" content="Summa Theologiae oleh Santo Thomas Aquinas — teks lengkap 611 pertanyaan dalam 5 bagian. Baca, cari, dan pelajari." />
  </Fragment>
  <Navbar />
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <div class="text-center mb-8">
      <span class="text-4xl">📗</span>
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mt-3">Summa Theologiae</h1>
      <p class="text-dkc-muted text-sm mt-1">Karya magnum Santo Thomas Aquinas, O.P. (1225–1274)</p>
    </div>

    <div class="glass-card p-6 mb-6">
      <p class="text-dkc-text text-sm leading-relaxed mb-4">
        <em>Summa Theologiae</em> (1265–1274) adalah salah satu karya paling berpengaruh dalam sejarah teologi dan filsafat Barat.
        Ditulis oleh Santo Thomas Aquinas sebagai panduan bagi pemula dalam teologi, karya ini terdiri dari tiga bagian utama
        yang membahas segala aspek iman Kristiani secara sistematis.
      </p>
      <div class="flex flex-wrap gap-3 justify-center text-xs text-dkc-muted">
        <span class="px-3 py-1 rounded-full bg-dkc-surface border border-dkc-border">5 Bagian</span>
        <span class="px-3 py-1 rounded-full bg-dkc-surface border border-dkc-border">611 Pertanyaan</span>
        <span class="px-3 py-1 rounded-full bg-dkc-surface border border-dkc-border">Teks Lengkap</span>
      </div>
    </div>

    <!-- Parts -->
    <div class="space-y-4">
      <a href="/summa/part1/" class="glass-card p-5 block hover:border-dkc-gold hover:bg-dkc-surface transition-all group">
        <div class="flex items-start gap-3">
          <span class="text-dkc-gold font-bold text-lg bg-dkc-gold/10 w-10 h-10 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-dkc-gold/20 transition-colors">I</span>
          <div>
            <h2 class="text-dkc-gold font-semibold group-hover:text-dkc-gold transition-colors">Prima Pars — Tentang Allah</h2>
            <p class="text-dkc-text text-sm leading-relaxed mt-1">Membahas keberadaan dan sifat Allah, Tritunggal Mahakudus, penciptaan, malaikat, dan alam materi. 119 pertanyaan.</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Keberadaan Allah</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Tritunggal</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Penciptaan</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Malaikat</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Manusia</span>
            </div>
          </div>
        </div>
      </a>

      <a href="/summa/part2/" class="glass-card p-5 block hover:border-dkc-gold hover:bg-dkc-surface transition-all group">
        <div class="flex items-start gap-3">
          <span class="text-dkc-gold font-bold text-lg bg-dkc-gold/10 w-10 h-10 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-dkc-gold/20 transition-colors">II</span>
          <div>
            <h2 class="text-dkc-gold font-semibold">Prima Secundae — Kebajikan &amp; Moral</h2>
            <p class="text-dkc-text text-sm leading-relaxed mt-1">Membahas tindakan manusia, kebajikan, dosa, hukum ilahi, rahmat, dan kebebasan kehendak. 114 pertanyaan.</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Kebajikan</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Dosa</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Hukum</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Rahmat</span>
            </div>
          </div>
        </div>
      </a>

      <a href="/summa/part3/" class="glass-card p-5 block hover:border-dkc-gold hover:bg-dkc-surface transition-all group">
        <div class="flex items-start gap-3">
          <span class="text-dkc-gold font-bold text-lg bg-dkc-gold/10 w-10 h-10 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-dkc-gold/20 transition-colors">III</span>
          <div>
            <h2 class="text-dkc-gold font-semibold">Secunda Secundae — Teologi Kebajikan</h2>
            <p class="text-dkc-text text-sm leading-relaxed mt-1">Penerapan kebajikan secara rinci: iman, harapan, kasih, keadilan, kebijaksanaan, dan karunia Roh Kudus. 189 pertanyaan.</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Iman</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Harapan</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Kasih</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Keadilan</span>
            </div>
          </div>
        </div>
      </a>

      <a href="/summa/part4/" class="glass-card p-5 block hover:border-dkc-gold hover:bg-dkc-surface transition-all group">
        <div class="flex items-start gap-3">
          <span class="text-dkc-gold font-bold text-lg bg-dkc-gold/10 w-10 h-10 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-dkc-gold/20 transition-colors">IV</span>
          <div>
            <h2 class="text-dkc-gold font-semibold">Tertia Pars — Kristus &amp; Sakramen</h2>
            <p class="text-dkc-text text-sm leading-relaxed mt-1">Membahas Inkarnasi, kehidupan Kristus, dan tujuh sakramen. 90 pertanyaan (tidak diselesaikan oleh Aquinas).</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Inkarnasi</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Sakramen</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Ekaristi</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Baptis</span>
            </div>
          </div>
        </div>
      </a>

      <a href="/summa/part5/" class="glass-card p-5 block hover:border-dkc-gold hover:bg-dkc-surface transition-all group">
        <div class="flex items-start gap-3">
          <span class="text-dkc-gold font-bold text-lg bg-dkc-gold/10 w-10 h-10 rounded-lg flex items-center justify-center shrink-0 group-hover:bg-dkc-gold/20 transition-colors">V</span>
          <div>
            <h2 class="text-dkc-gold font-semibold">Supplementum Tertiæ Partis</h2>
            <p class="text-dkc-text text-sm leading-relaxed mt-1">Disusun oleh murid Aquinas dari komentarnya pada Sentences. Membahas pengakuan dosa, tahbisan, pernikahan, kebangkitan, dan akhir zaman. 99 pertanyaan.</p>
            <div class="flex flex-wrap gap-1.5 mt-2">
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Tahbisan</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Pernikahan</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Kebangkitan</span>
              <span class="text-[10px] px-2 py-0.5 rounded-full bg-dkc-surface border border-dkc-border text-dkc-muted">Akhir Zaman</span>
            </div>
          </div>
        </div>
      </a>
    </div>

    <!-- How to Read -->
    <div class="glass-card p-5 mt-6">
      <h3 class="text-dkc-gold font-semibold text-sm mb-3">📖 Cara Membaca Summa Theologiae</h3>
      <p class="text-dkc-text text-sm leading-relaxed">
        Setiap <strong>Pertanyaan (Question)</strong> terdiri dari beberapa <strong>Artikel (Article)</strong>.
        Setiap artikel mengikuti format khas skolastik: <em>Objections</em> (keberatan), <em>On the contrary</em> (sed contra),
        <em>I answer that</em> (respondeo), dan <em>Replies</em> (jawaban terhadap keberatan).
      </p>
    </div>

    <!-- External resources -->
    <div class="glass-card p-5 mt-6">
      <h3 class="text-dkc-gold font-semibold text-sm mb-3">🔗 Sumber Eksternal</h3>
      <div class="space-y-2">
        <a href="https://www.newadvent.org/summa/" target="_blank" rel="noopener" class="flex items-center gap-2 text-dkc-text text-sm hover:text-dkc-gold transition-colors">
          <span>🌐</span> New Advent — Teks lengkap bahasa Inggris
        </a>
        <a href="https://www.corpusthomisticum.org/iopera.html" target="_blank" rel="noopener" class="flex items-center gap-2 text-dkc-text text-sm hover:text-dkc-gold transition-colors">
          <span>🌐</span> Corpus Thomisticum — Teks asli Latin
        </a>
        <a href="https://aquinas101.thomisticinstitute.org/" target="_blank" rel="noopener" class="flex items-center gap-2 text-dkc-text text-sm hover:text-dkc-gold transition-colors">
          <span>🌐</span> Aquinas 101 — Pengantar interaktif
        </a>
      </div>
    </div>

    <!-- Cari -->
    <div class="text-center mt-8">
      <a href="/summa/search/" class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-dkc-gold/10 border border-dkc-gold/20 text-dkc-gold hover:bg-dkc-gold/20 transition-all text-sm font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        Cari di Summa Theologiae
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
