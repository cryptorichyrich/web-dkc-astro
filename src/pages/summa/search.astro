---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";

const summaQuestions = await getCollection("summa");
const searchData = summaQuestions.map((q) => ({
  title: q.data.title,
  part: q.data.part,
  partNum: q.data.partNum,
  questionNumber: q.data.questionNumber,
  partSlug: q.data.partSlug,
  url: `/summa/${q.data.partSlug}/question${q.data.questionNumber}/`,
  snippet: q.body?.substring(0, 300) || "",
}));

const totalQuestions = searchData.length;
const totalParts = 5;
---

<BaseLayout>
  <Navbar />
  <main class="max-w-4xl mx-auto px-4 pt-8 pb-24">
    <div class="text-center mb-8">
      <a href="/summa" class="inline-flex items-center gap-1.5 text-dkc-muted text-xs hover:text-dkc-gold transition-colors mb-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        Kembali ke Summa Index
      </a>
      <span class="text-4xl">🔍</span>
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mt-3">Cari Summa Theologiae</h1>
      <p class="text-dkc-muted text-sm mt-1">{totalQuestions} Pertanyaan · {totalParts} Bagian · Santo Thomas Aquinas, O.P.</p>
    </div>

    <!-- Search Bar -->
    <div class="glass-card p-4 mb-6">
      <div class="flex items-center gap-3">
        <div class="relative flex-1">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-dkc-muted" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input
            type="text"
            id="summa-search-input"
            placeholder="Cari topik, kata kunci, atau nomor pertanyaan…"
            class="w-full bg-dkc-surface border border-dkc-border rounded-xl pl-10 pr-4 py-3 text-sm text-dkc-text placeholder:text-dkc-muted/60 focus:outline-none focus:border-dkc-gold/40 transition-colors"
          />
        </div>
        <span id="result-count" class="text-dkc-muted text-xs shrink-0 hidden"></span>
      </div>
      <p class="text-dkc-muted text-[11px] mt-2 text-center">Ketik untuk mencari — hasil langsung dari teks Summa Theologiae di situs ini</p>
    </div>

    <!-- Results -->
    <div id="search-results" class="space-y-3 mb-6">
      <div class="text-center text-dkc-muted text-sm py-8" id="no-results-msg">
        Ketik kata kunci untuk mencari di {totalQuestions} pertanyaan Summa Theologiae
      </div>
    </div>

    <!-- Stats -->
    <div class="glass-card p-5 mt-6">
      <div class="grid grid-cols-3 gap-4 text-center">
        <div><p class="text-dkc-gold text-xl md:text-2xl font-bold">5</p><p class="text-dkc-muted text-[10px] md:text-xs">Bagian</p></div>
        <div><p class="text-dkc-gold text-xl md:text-2xl font-bold">{totalQuestions}</p><p class="text-dkc-muted text-[10px] md:text-xs">Pertanyaan</p></div>
        <div><p class="text-dkc-gold text-xl md:text-2xl font-bold">2.669</p><p class="text-dkc-muted text-[10px] md:text-xs">Artikel</p></div>
      </div>
    </div>

    <!-- External -->
    <div class="glass-card p-5 mt-4">
      <h3 class="text-dkc-gold font-semibold text-sm mb-3">🔗 Sumber Eksternal</h3>
      <div class="space-y-2">
        <a href="https://www.newadvent.org/summa/" target="_blank" rel="noopener" class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-dkc-surface/60 border border-transparent hover:border-dkc-gold/20 hover:bg-dkc-gold/5 transition-all duration-200 group/ext">
          <span class="text-lg">🌐</span>
          <div class="min-w-0">
            <span class="text-dkc-text text-sm font-medium block group-hover/ext:text-dkc-gold transition-colors">New Advent</span>
            <span class="text-dkc-muted text-[11px]">Teks lengkap bahasa Inggris — Summa Theologiae</span>
          </div>
        </a>
        <a href="https://aquinas101.thomisticinstitute.org/" target="_blank" rel="noopener" class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-dkc-surface/60 border border-transparent hover:border-dkc-gold/20 hover:bg-dkc-gold/5 transition-all duration-200 group/ext">
          <span class="text-lg">🌐</span>
          <div class="min-w-0">
            <span class="text-dkc-text text-sm font-medium block group-hover/ext:text-dkc-gold transition-colors">Aquinas 101</span>
            <span class="text-dkc-muted text-[11px]">Pengantar interaktif — Thomistic Institute</span>
          </div>
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<Fragment slot="head">
  <title>Cari Summa Theologiae — Damai Kasih Channel</title>
  <meta name="description" content={`Cari di ${totalQuestions} pertanyaan Summa Theologiae Santo Thomas Aquinas.`} />
</Fragment>

<script is:inline>
  const SEARCH_DATA = [{searchData.map(d => JSON.stringify(d)).join(",")}];
  
  const input = document.getElementById("summa-search-input");
  const results = document.getElementById("search-results");
  const noResults = document.getElementById("no-results-msg");
  const count = document.getElementById("result-count");

  function doSearch(query) {
    const q = query.toLowerCase().trim();
    if (!q) {
      results.innerHTML = "";
      results.appendChild(noResults);
      noResults.textContent = `Ketik kata kunci untuk mencari di ${SEARCH_DATA.length} pertanyaan Summa Theologiae`;
      noResults.style.display = "";
      count.classList.add("hidden");
      return;
    }

    const matches = SEARCH_DATA.filter(d => 
      d.title.toLowerCase().includes(q) || 
      d.snippet.toLowerCase().includes(q) ||
      d.part.toLowerCase().includes(q)
    );

    if (matches.length === 0) {
      results.innerHTML = `<div class="text-center text-dkc-muted text-sm py-8">Tidak ditemukan untuk "${query}". Coba kata kunci lain.</div>`;
      count.classList.add("hidden");
      return;
    }

    count.textContent = `${matches.length} hasil`;
    count.classList.remove("hidden");

    results.innerHTML = matches.slice(0, 30).map(d => {
      const partNums = { part1: "I", part2: "I-II", part3: "II-II", part4: "III", part5: "Suppl." };
      const pn = partNums[d.partSlug] || d.partSlug;
      return `
        <a href="${d.url}" class="block glass-card p-4 hover:border-dkc-gold hover:bg-dkc-surface transition-all group">
          <div class="flex items-start gap-3">
            <span class="shrink-0 w-8 h-8 rounded-lg bg-dkc-gold/10 border border-dkc-gold/20 flex items-center justify-center text-xs font-bold text-dkc-gold">${d.questionNumber}</span>
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="text-[10px] px-1.5 py-0.5 rounded bg-dkc-surface border border-dkc-border text-dkc-muted">${pn}</span>
                <h3 class="text-dkc-text text-sm font-medium group-hover:text-dkc-gold transition-colors truncate">Question ${d.questionNumber}. ${d.title}</h3>
              </div>
              <p class="text-dkc-muted text-xs line-clamp-2">${d.snippet.replace(/[#*\[\]\(\)]/g, "").substring(0, 200)}</p>
            </div>
          </div>
        </a>
      `;
    }).join("");
  }

  input.addEventListener("input", () => doSearch(input.value));
</script>
