---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';

// Get featured articles (limit 3)
const featuredPosts = await getCollection('blog', (e) => e.data.featured === true).then(col =>
  col.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
).then(col => col.slice(0, 3));

// Get latest articles
const latestPosts = await getCollection('blog').then(col =>
  col.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime())
).then(col => col.slice(0, 6));

interface Props {
  title?: string;
}

const { title = 'Dama Kasih Channel – Katolik Indonesia Apologetics' } = Astro.props;
---

<BaseLayout title={title} description="Premium Indonesian Catholic apologetics. Deep dive into faith with Dama Kasih Channel.">
  <!-- Alpine.js Interactivity for Liturgical Widget -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>

  <div class="min-h-screen bg-dkc-bg">
    <!-- ==========================================
         HERO SECTION — Sacred Editorial Typography
         ========================================== -->
    <section class="relative overflow-hidden">
      <!-- Background Image with Sacred Gradient Overlay -->
      <div class="absolute inset-0 z-0">
        <img src="/assets/img/hero.CbCyhv3__11xOU6.webp"
             alt=""
             class="w-full h-full object-cover object-center"
             loading="eager"
             fetchpriority="high"
             width="1920"
             height="1080" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-dkc-bg"></div>
      </div>

      <!-- Cross Motif — Subtle Gold Accent -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-[1] opacity-12">
        <svg width="240" height="360" viewBox="0 0 24 36" fill="currentColor" class="text-dkc-gold">
          <path d="M12 2l-2 8h-8l2-8 2 8 2 8-2 8h8l-2-8-2-8z" />
        </svg>
      </div>

      <!-- Hero Content — Lora Serif, Centered, Reverent -->
      <div class="relative z-[2] flex flex-col items-center justify-center min-h-[85vh] px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto text-center">
        <p class="text-dkc-gold text-sm uppercase tracking-[0.3em] mb-4 font-sans font-medium">Dama Kasih Channel</p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-lora font-bold text-white leading-tight mb-6 max-w-4xl">
          Apologetics Katolik untuk Indonesia
        </h1>
        <p class="text-lg sm:text-xl text-gray-300 font-light max-w-2xl leading-relaxed mb-10">
          Eksplorasi iman dengan akal budi. Q&A, tafsir alkitab, doktrin, dan kisah inspiratif untuk umat Katolik.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#featured" class="px-8 py-4 bg-dkc-gold text-black font-semibold rounded-none hover:bg-white transition-colors duration-300">
            Mulai Membaca
          </a>
          <a href="#liturgical" class="px-8 py-4 border border-white/30 text-white font-medium hover:bg-white/10 transition-colors duration-300">
            Doa Harian
          </a>
        </div>
      </div>

      <!-- Scroll Indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-[2] animate-bounce">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="text-white/60">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7-7-7" />
        </svg>
      </div>
    </section>

    <!-- ==========================================
         FEATURED ARTICLES — Large Editorial Layout
         ========================================== -->
    <section id="featured" class="py-20 px-4 sm:px-6 max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-3xl font-lora font-bold text-white">Artikel Pilihan</h2>
          <p class="text-gray-400 mt-2">Konten mendalam yang harus Anda baca</p>
        </div>
        <a href="/blog" class="text-dkc-gold hover:text-white transition-colors hidden sm:block">
          Lihat semua →
        </a>
      </div>

      <!-- Featured Grid: First article large, two smaller stacked -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
        <!-- Main Featured (col-span-2 on lg) -->
        {featuredPosts[0] && (
          <article class="lg:col-span-2 group relative overflow-hidden rounded-lg glass-card hover:bg-white/10 transition-all duration-500">
            <a href={`/blog/${featuredPosts[0].slug}`} class="block">
              <div class="flex flex-col h-full">
                {featuredPosts[0].data.coverImage && (
                  <div class="relative h-64 sm:h-80 lg:h-96 overflow-hidden">
                    <img src={featuredPosts[0].data.coverImage}
                         alt={featuredPosts[0].data.title}
                         class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                         loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                  </div>
                )}
                <div class="p-6 sm:p-8 flex-1 flex flex-col">
                  <div class="flex items-center gap-3 mb-4 text-sm text-gray-400">
                    <time datetime={featuredPosts[0].data.publishedAt}>
                      {new Date(featuredPosts[0].data.publishedAt).toLocaleDateString('id-ID', { month: 'long', year: 'numeric' })}
                    </time>
                    {featuredPosts[0].data.tags && featuredPosts[0].data.tags.length > 0 && (
                      <span class="text-dkc-gold">• {featuredPosts[0].data.tags[0]}</span>
                    )}
                  </div>
                  <h3 class="text-2xl sm:text-3xl font-lora font-bold text-white mb-4 leading-tight group-hover:text-dkc-gold transition-colors">
                    {featuredPosts[0].data.title}
                  </h3>
                  {featuredPosts[0].data.subtitle && (
                    <p class="text-gray-300 text-lg leading-relaxed mb-4">{featuredPosts[0].data.subtitle}</p>
                  )}
                  <div class="mt-auto pt-4 border-t border-white/10">
                    <p class="text-gray-400 text-sm">Oleh {featuredPosts[0].data.author}</p>
                  </div>
                </div>
              </div>
            </a>
          </article>
        )}

        <!-- Stacked Side Features -->
        <div class="flex flex-col gap-6 lg:gap-8">
          {featuredPosts.slice(1, 3).map(post => (
            <article key={post.slug} class="group flex-1 flex flex-col overflow-hidden rounded-lg glass-card hover:bg-white/10 transition-all duration-500">
              <a href={`/blog/${post.slug}`} class="block h-full">
                <div class="flex flex-col h-full">
                  {post.data.coverImage && (
                    <div class="relative h-40 sm:h-48 overflow-hidden">
                      <img src={post.data.coverImage}
                           alt={post.data.title}
                           class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                           loading="lazy" />
                      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    </div>
                  )}
                  <div class="p-5 flex-1 flex flex-col">
                    <div class="text-xs text-gray-400 mb-2">
                      {new Date(post.data.publishedAt).toLocaleDateString('id-ID', { month: 'long', year: 'numeric' })}
                    </div>
                    <h3 class="text-lg sm:text-xl font-lora font-bold text-white mb-2 leading-tight group-hover:text-dkc-gold transition-colors">
                      {post.data.title}
                    </h3>
                    {post.data.subtitle && (
                      <p class="text-gray-400 text-sm line-clamp-2">{post.data.subtitle}</p>
                    )}
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>

      <!-- Mobile CTA -->
      <div class="mt-8 text-center sm:hidden">
        <a href="/blog" class="inline-block px-6 py-3 bg-dkc-gold text-black font-semibold">
          Lihat Semua Artikel
        </a>
      </div>
    </section>

    <!-- ==========================================
         QUICK ACCESS TOOLS — Four Icon Cards
         ========================================== -->
    <section class="py-16 bg-black/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <h2 class="text-2xl font-lora font-bold text-white">Akses Cepat</h2>
          <p class="text-gray-400 mt-2">Alat pencarian dan referensi alkitab</p>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 sm:gap-6">
          <!-- Tool 1: Cari Alkitab -->
          <a href="/search" class="group p-6 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 hover:border-dkc-gold/50 transition-all duration-300 text-center">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="mx-auto mb-4 text-dkc-gold">
              <circle cx="11" cy="11" r="8" stroke-width="1.5"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-4.35-4.35"/>
            </svg>
            <h3 class="font-semibold text-white mb-1">Cari Alkitab</h3>
            <p class="text-xs text-gray-400">Pencarian ayat dan kata</p>
          </a>

          <!-- Tool 2: Doktrin Gereja -->
          <a href="/doktrin" class="group p-6 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 hover:border-dkc-gold/50 transition-all duration-300 text-center">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="mx-auto mb-4 text-dkc-gold">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
            <h3 class="font-semibold text-white mb-1">Doktrin Gereja</h3>
            <p class="text-xs text-gray-400">Panduan iman Katolik</p>
          </a>

          <!-- Tool 3: Q&A Apologetics -->
          <a href="/qa" class="group p-6 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 hover:border-dkc-gold/50 transition-all duration-300 text-center">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="mx-auto mb-4 text-dkc-gold">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <h3 class="font-semibold text-white mb-1">Q&A Apologetics</h3>
            <p class="text-xs text-gray-400">Jawaban atas pertanyaan</p>
          </a>

          <!-- Tool 4: Rosary -->
          <a href="/rosary" class="group p-6 bg-white/5 border border-white/10 rounded-lg hover:bg-white/10 hover:border-dkc-gold/50 transition-all duration-300 text-center">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="mx-auto mb-4 text-dkc-gold">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.683 1.7a1 1 0 00-1.414 0l-1.333 1.333a1 1 0 00-.375.918V10a1 1 0 001 1h1.35a1 1 0 00.925-.737l1.33-12.283A1 1 0 0019.683 1.7zM4.437 2.4a1 1 0 00-1.031.352l-1.35 14.635a1 1 0 00.926.737H8.67a1 1 0 00.926-.737l1.335-12.282A1 1 0 004.437 2.4zM12 4.5a1.5 1.5 0 110 3 1.5 1.5 0 010-3z"/>
            </svg>
            <h3 class="font-semibold text-white mb-1">Sajda Rosary</h3>
            <p class="text-xs text-gray-400">Belanjakan roza</p>
          </a>
        </div>
      </div>
    </section>

    <!-- ==========================================
         LITURGICAL WIDGET — Alpine.js Interactive
         ========================================== -->
    <section id="liturgical" class="py-20 px-4 sm:px-6 max-w-7xl mx-auto" x-data="liturgicalWidget()">
      <div class="text-center mb-10">
        <h2 class="text-2xl font-lora font-bold text-white">Informasi Liturgi Hari Ini</h2>
        <p class="text-gray-400 mt-2" x-text="formattedDate"></p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Waktu Shalat (Static for demo) -->
        <div class="p-6 bg-white/5 border border-white/10 rounded-lg text-center">
          <h3 class="text-dkc-gold font-semibold mb-3">Waktu Shalat (Islam)</h3>
          <div class="space-y-2 text-sm text-gray-300">
            <p>Subuh: 04:32 WIB</p>
            <p>Dhuha: 06:02 WIB</p>
            <p>Dzuhur: 11:58 WIB</p>
            <p>Ashar: 15:22 WIB</p>
            <p>Maghrib: 18:28 WIB</p>
            <p>Isya: 19:42 WIB</p>
          </div>
        </div>

        <!-- Rosary Guide — Interactive -->
        <div class="p-6 bg-white/5 border border-white/10 rounded-lg" x-data="{ currentMystery: 0, mysteries: ['Misteri Domesifikasi (Senin & Sabtu)', 'Misteri Duka (Jumat)', 'Misteri Mulia (Rabu & Minggu)', 'Misteri Terang (Kamis)', 'Misteri Waspada (Jumat)'] }">
          <h3 class="text-dkc-gold font-semibold mb-3 text-center">Misteri Rosary Hari Ini</h3>
          <p class="text-gray-300 text-center text-sm mb-4" x-text="mysteries[currentMystery]"></p>
          <div class="flex justify-center gap-2">
            <template x-for="(m, i) in mysteries" :key="i">
              <button @click="currentMystery = i"
                      :class="currentMystery === i ? 'bg-dkc-gold text-black' : 'bg-white/10 text-white hover:bg-white/20'"
                      class="px-3 py-1 text-xs rounded transition-colors duration-200">
                <span x-text="i + 1"></span>
              </button>
            </template>
          </div>
        </div>

        <!-- Liturgical Calendar -->
        <div class="p-6 bg-white/5 border border-white/10 rounded-lg text-center">
          <h3 class="text-dkc-gold font-semibold mb-3">Kalender Liturgi</h3>
          <p class="text-gray-300 mb-2">Hari: <span class="text-white">Rabu</span></p>
          <p class="text-gray-300 mb-2">Minggu: <span class="text-white">Ke-4 Pentakosta</span></p>
          <p class="text-gray-300">Warna liturgi: <span class="text-white">Hijau</span></p>
        </div>
      </div>
    </section>

    <!-- ==========================================
         LATEST ARTICLES — Clean Editorial Grid
         ========================================== -->
    <section id="articles" class="py-20 px-4 sm:px-6 max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="text-3xl font-lora font-bold text-white">Artikel Terbaru</h2>
          <p class="text-gray-400 mt-2">Perbarui iman Anda dengan tulisan terbaru</p>
        </div>
        <a href="/blog" class="text-dkc-gold hover:text-white transition-colors hidden sm:block">
          Arsip →
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {latestPosts.map(post => (
          <article class="group flex flex-col overflow-hidden rounded-lg glass-card hover:bg-white/10 transition-all duration-300">
            <a href={`/blog/${post.slug}`} class="block">
              {post.data.coverImage && (
                <div class="relative h-48 overflow-hidden">
                  <img src={post.data.coverImage}
                       alt={post.data.title}
                       class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                       loading="lazy" />
                </div>
              )}
              <div class="p-5 flex-1 flex flex-col">
                <div class="text-xs text-gray-400 mb-2">
                  {new Date(post.data.publishedAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}
                </div>
                <h3 class="text-lg font-lora font-bold text-white mb-2 leading-tight group-hover:text-dkc-gold transition-colors line-clamp-2">
                  {post.data.title}
                </h3>
                {post.data.subtitle && (
                  <p class="text-gray-400 text-sm line-clamp-2 mb-3">{post.data.subtitle}</p>
                )}
                <div class="mt-auto pt-3 border-t border-white/10">
                  <p class="text-gray-500 text-xs">{post.data.author}</p>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="mt-8 text-center sm:hidden">
        <a href="/blog" class="inline-block px-6 py-3 bg-dkc-gold text-black font-semibold">
          Lihat Artikel Lainnya
        </a>
      </div>
    </section>

    <!-- ==========================================
         YOUTUBE CTA — Subscription Section
         ========================================== -->
    <section class="py-16 bg-gradient-to-b from-transparent to-red-900/20">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl font-lora font-bold text-white mb-4">Ikuti Kami di YouTube</h2>
        <p class="text-gray-300 mb-8 max-w-2xl mx-auto">
          Video penjelasan Alkitab, s ANTARA Doa, warkop Katolik, dan kajian iman tiap minggu. Langganan gratis dengan notifikasi.
        </p>
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
          <a href="https://youtube.com/@damakasihchannel" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto">
            <button class="w-full sm:w-auto px-8 py-4 bg-red-600 hover:bg-red-700 text-white font-bold flex items-center justify-center gap-3 rounded transition-colors duration-300">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              Langganan YouTube
            </button>
          </a>
          <a href="https://youtube.com/@damakasihchannel" target="_blank" rel="noopener noreferrer" class="w-full sm:w-auto">
            <button class="w-full sm:w-auto px-8 py-4 border border-white/30 text-white hover:bg-white/10 transition-colors duration-300">
              Tonton Sekarang
            </button>
          </a>
        </div>
      </div>
    </section>
  </div>

  <!-- Bottom Nav Spacer -->
  <div class="h-20"></div>

  <script>
    // Simple liturgical widget script (Alpine.js alternative)
    (function() {
      // Date formatter for Indonesia
      const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
      const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
      const now = new Date();
      const element = document.querySelector('[x-text="formattedDate"]');
      if (element) {
        const formatted = `${days[now.getDay()]}, ${now.getDate()} ${months[now.getMonth()]} ${now.getFullYear()}`;
        element.textContent = formatted;
      }
    })();
  </script>

  <!-- Alpine.js data for liturgical widget -->
  <script is:inline>
    window.liturgicalWidget = function() {
      return {
        currentDate: new Date(),
        get formattedDate() {
          const days = ['Minggu', 'Senin', 'Selasa', 'Rabu', 'Kamis', 'Jumat', 'Sabtu'];
          const months = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
          return `${days[this.currentDate.getDay()]}, ${this.currentDate.getDate()} ${months[this.currentDate.getMonth()]} ${this.currentDate.getFullYear()}`;
        }
      }
    }
  </script>

</BaseLayout>
