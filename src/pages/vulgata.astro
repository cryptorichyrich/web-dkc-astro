---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Navbar from "@/components/Navbar.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout>
  <Navbar />

  <main class="max-w-4xl mx-auto px-4 pt-6 pb-24">
    <div class="text-center mb-6">
      <h1 class="text-2xl md:text-3xl font-bold text-dkc-gold mb-1">Biblia Sacra Vulgata</h1>
      <p class="text-dkc-muted text-sm">Latin Vulgate — Nova Vulgata cum translatione Anglica</p>
    </div>

    <!-- Testament Selection -->
    <div id="step-testament" class="glass-card p-5 mb-5">
      <h2 class="text-dkc-gold font-bold text-sm mb-4 uppercase tracking-wider">Choose Testament</h2>
      <div class="grid grid-cols-2 gap-3">
        <button data-testament="ot" class="testament-btn rounded-xl border-2 border-amber-700/30 bg-gradient-to-br from-amber-900/20 to-amber-800/10 p-5 text-center transition-all hover:border-amber-600/50">
          <div class="text-3xl mb-2">📖</div>
          <div class="text-dkc-gold font-bold text-sm">VETUS TESTAMENTUM</div>
          <div class="text-dkc-muted text-[11px] mt-1">46 Books</div>
        </button>
        <button data-testament="nt" class="testament-btn rounded-xl border-2 border-red-700/30 bg-gradient-to-br from-red-900/20 to-red-800/10 p-5 text-center transition-all hover:border-red-600/50">
          <div class="text-3xl mb-2">✝️</div>
          <div class="text-dkc-gold font-bold text-sm">NOVUM TESTAMENTUM</div>
          <div class="text-dkc-muted text-[11px] mt-1">27 Books</div>
        </button>
      </div>
    </div>

    <!-- Book Selection -->
    <div id="step-books" class="glass-card p-5 mb-5 hidden">
      <div class="flex items-center justify-between mb-4">
        <h2 id="testament-title" class="text-dkc-gold font-bold text-sm uppercase tracking-wider">—</h2>
        <button id="back-testament" class="text-dkc-muted text-xs border border-dkc-border rounded-lg px-3 py-1 hover:text-dkc-gold hover:border-dkc-gold/30">← Back</button>
      </div>
      <div id="book-grid" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-2"></div>
    </div>

    <!-- Chapter Selection -->
    <div id="step-chapters" class="glass-card p-5 mb-5 hidden">
      <div class="flex items-center justify-between mb-4">
        <h2 id="book-title" class="text-dkc-gold font-bold text-sm uppercase tracking-wider">—</h2>
        <button id="back-books" class="text-dkc-muted text-xs border border-dkc-border rounded-lg px-3 py-1 hover:text-dkc-gold hover:border-dkc-gold/30">← Back</button>
      </div>
      <div id="chapter-grid" class="grid grid-cols-8 sm:grid-cols-10 md:grid-cols-12 gap-1.5"></div>
    </div>

    <!-- Verse Selection -->
    <div id="step-verses" class="glass-card p-5 mb-5 hidden">
      <div class="flex items-center justify-between mb-4">
        <h2 id="verse-title" class="text-dkc-gold font-bold text-sm uppercase tracking-wider">—</h2>
        <button id="back-chapters" class="text-dkc-muted text-xs border border-dkc-border rounded-lg px-3 py-1 hover:text-dkc-gold hover:border-dkc-gold/30">← Back</button>
      </div>
      <div id="verse-grid" class="grid grid-cols-8 sm:grid-cols-10 md:grid-cols-12 gap-1.5"></div>
    </div>

    <!-- Reading Area -->
    <div id="reading-area" class="glass-card p-5 md:p-6 mb-5 hidden">
      <!-- Action Bar -->
      <div class="flex items-center gap-2 mb-4 pb-3 border-b border-dkc-border/40 flex-wrap">
        <button id="tts-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
          <span>Legere</span>
        </button>
        <button id="tts-stop-btn" class="hidden flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-red-500/40 text-red-400 text-xs hover:bg-red-500/10">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
          <span>Stop</span>
        </button>
        <span id="tts-timer" class="hidden text-dkc-muted text-[11px] tabular-nums">00:00</span>
        <button id="bookmark-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
        </button>
        <div class="flex items-center gap-1 ml-auto">
          <button data-fsize="sm" class="font-size-btn px-2 py-1 rounded border border-dkc-border text-dkc-muted text-[10px] hover:text-dkc-gold">A</button>
          <button data-fsize="md" class="font-size-btn px-2 py-1 rounded border border-dkc-border text-dkc-muted text-xs hover:text-dkc-gold">A</button>
          <button data-fsize="lg" class="font-size-btn px-2 py-1 rounded border border-dkc-border text-dkc-muted text-sm hover:text-dkc-gold">A</button>
        </div>
        <button id="share-copy" class="w-7 h-7 rounded-full border border-dkc-border flex items-center justify-center text-dkc-muted hover:text-dkc-gold hover:border-dkc-gold/40" title="Copy link">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        </button>
      </div>
      <!-- Header -->
      <div class="flex justify-between items-center mb-5">
        <div>
          <h2 id="reading-title" class="text-dkc-gold font-bold text-lg">—</h2>
          <p id="reading-subtitle" class="text-dkc-muted text-xs mt-0.5"></p>
        </div>
        <div class="flex gap-2">
          <button id="prev-ch" class="px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold">←</button>
          <button id="next-ch" class="px-3 py-1.5 rounded-lg border border-dkc-border text-dkc-muted text-xs hover:border-dkc-gold/30 hover:text-dkc-gold">→</button>
        </div>
      </div>
      <div id="reading-loading" class="text-center py-12 text-dkc-muted hidden"><div class="inline-block w-6 h-6 border-2 border-dkc-gold/30 border-t-dkc-gold rounded-full animate-spin mb-3"></div><p class="text-sm">Loading...</p></div>
      <div id="reading-content" class="space-y-3 leading-relaxed"></div>
    </div>

    <div id="bottom-nav" class="flex justify-center gap-3 hidden">
      <button id="prev-ch-bottom" class="px-4 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold">← Previous</button>
      <button id="next-ch-bottom" class="px-4 py-2 rounded-lg border border-dkc-border text-dkc-muted text-sm hover:border-dkc-gold/30 hover:text-dkc-gold">Next →</button>
    </div>
  </main>
  <Footer />
</BaseLayout>

<Fragment slot="head">
  <title>Biblia Sacra Vulgata — Damai Kasih Channel</title>
  <meta name="description" content="Latin Vulgate Bible with English translation. Read the Nova Vulgata online." />
</Fragment>

<style is:global>
  #reading-content sup { color: rgba(201,168,76,0.7); font-weight: bold; font-size: 0.7rem; margin-right: 0.25rem; }
  #reading-content .verse-row { border-radius: 0.5rem; padding: 0.35rem 0.5rem; margin: 0 -0.5rem; transition: background-color 0.15s; cursor: pointer; }
  #reading-content .verse-row:hover { background: rgba(201,168,76,0.05); }
  #reading-content .verse-row.highlighted { background: rgba(201,168,76,0.1); box-shadow: inset 0 0 0 1px rgba(201,168,76,0.3); }
  #reading-content .verse-row.flash { background: rgba(201,168,76,0.25); box-shadow: inset 0 0 0 2px rgba(201,168,76,0.5); transition: background-color 0.3s, box-shadow 0.3s; }
  .latin-text { font-style: italic; color: #ef5350 !important; font-size: 1.05em; }
  .english-text { color: var(--color-dkc-muted); font-size: 0.85em; margin-top: 0.15rem; }
  .sel-btn { background: var(--color-dkc-surface); border: 1px solid var(--color-dkc-border); color: var(--color-dkc-muted); border-radius: 0.5rem; padding: 0.4rem 0; font-size: 0.75rem; cursor: pointer; transition: all 0.15s; text-align: center; }
  .sel-btn:hover { border-color: rgba(201,168,76,0.3); color: var(--color-dkc-gold); }
  .sel-btn.active { background: rgba(201,168,76,0.15); color: var(--color-dkc-gold); border-color: rgba(201,168,76,0.4); font-weight: 700; }
  .book-btn-ot { border-color: rgba(180,130,50,0.25); }
  .book-btn-ot:hover,.book-btn-ot.active { border-color: rgba(180,130,50,0.6); background: rgba(180,130,50,0.1); }
  .book-btn-nt { border-color: rgba(200,60,60,0.25); }
  .book-btn-nt:hover,.book-btn-nt.active { border-color: rgba(200,60,60,0.6); background: rgba(200,60,60,0.1); }
  .font-size-active { border-color: rgba(201,168,76,0.5) !important; color: var(--color-dkc-gold) !important; }
</style>

<script>
  const BOOK_NAMES: Record<string,string> = {
    genesis:"Genesis",exodus:"Exodus",leviticus:"Leviticus",numbers:"Numbers",deuteronomy:"Deuteronomy",
    joshua:"Joshua",judges:"Judges",ruth:"Ruth","1samuel":"1 Samuel","2samuel":"2 Samuel",
    "1kings":"1 Kings","2kings":"2 Kings","1chronicles":"1 Chronicles","2chronicles":"2 Chronicles",
    ezra:"Ezra",nehemiah:"Nehemiah",tobias:"Tobit",judith:"Judith",esther:"Esther",
    job:"Job",psalms:"Psalms",proverbs:"Proverbs",ecclesiastes:"Ecclesiastes",songofsolomon:"Song of Solomon",
    wisdomofsolomon:"Wisdom",sirach:"Sirach",isaiah:"Isaiah",jeremiah:"Jeremiah",lamentations:"Lamentations",
    baruch:"Baruch",ezekiel:"Ezekiel",daniel:"Daniel",hosea:"Hosea",joel:"Joel",amos:"Amos",
    obadiah:"Obadiah",jonas:"Jonah",micah:"Micah",nahum:"Nahum",habakkuk:"Habakkuk",
    zephaniah:"Zephaniah",haggai:"Haggai",zechariah:"Zechariah",malachi:"Malachi",
    "1machabees":"1 Maccabees","2machabees":"2 Maccabees",
    matthew:"Matthew",mark:"Mark",luke:"Luke",john:"John",acts:"Acts",
    romans:"Romans","1corinthians":"1 Corinthians","2corinthians":"2 Corinthians",
    galatians:"Galatians",ephesians:"Ephesians",philippians:"Philippians",colossians:"Colossians",
    "1thessalonians":"1 Thessalonians","2thessalonians":"2 Thessalonians",
    "1timothy":"1 Timothy","2timothy":"2 Timothy",titus:"Titus",philemon:"Philemon",
    hebrews:"Hebrews",james:"James","1peter":"1 Peter","2peter":"2 Peter",
    "1john":"1 John","2john":"2 John","3john":"3 John",jude:"Jude",revelation:"Revelation"
  };
  const OT=["genesis","exodus","leviticus","numbers","deuteronomy","joshua","judges","ruth","1samuel","2samuel","1kings","2kings","1chronicles","2chronicles","ezra","nehemiah","tobias","judith","esther","job","psalms","proverbs","ecclesiastes","songofsolomon","wisdomofsolomon","sirach","isaiah","jeremiah","lamentations","baruch","ezekiel","daniel","hosea","joel","amos","obadiah","jonas","micah","nahum","habakkuk","zephaniah","haggai","zechariah","malachi","1machabees","2machabees"];
  const NT=["matthew","mark","luke","john","acts","romans","1corinthians","2corinthians","galatians","ephesians","philippians","colossians","1thessalonians","2thessalonians","1timothy","2timothy","titus","philemon","hebrews","james","1peter","2peter","1john","2john","3john","jude","revelation"];

  let data: any=null, curBook="", curChapter=0, curTest="";
  const hlSet=new Set<number>();
  let ttsTmr:any=null, ttsSec=0;

  const $=id=>document.getElementById(id)!;
  const stepT=$("step-testament"), stepB=$("step-books"), stepC=$("step-chapters"), stepV=$("step-verses");
  const rArea=$("reading-area"), rContent=$("reading-content"), rTitle=$("reading-title"), rSub=$("reading-subtitle"), rLoad=$("reading-loading");
  const bGrid=$("book-grid"), cGrid=$("chapter-grid"), vGrid=$("verse-grid"), btmNav=$("bottom-nav");
  const verseTitle=$("verse-title") as HTMLElement;

  function showStep(s:string) {
    stepT.classList.toggle("hidden",s!=="testament");
    stepB.classList.toggle("hidden",s!=="books");
    stepC.classList.toggle("hidden",s!=="chapters");
    stepV.classList.toggle("hidden",s!=="verses");
  }

  document.querySelectorAll(".testament-btn").forEach(b=>b.addEventListener("click",()=>{
    const t=b.getAttribute("data-testament")!; curTest=t;
    const books=t==="ot"?OT:NT;
    $("testament-title").textContent=t==="ot"?"VETUS TESTAMENTUM":"NOVUM TESTAMENTUM";
    bGrid.innerHTML="";
    for(const k of books){if(!data?.[k])continue;const btn=document.createElement("button");btn.className=`sel-btn book-btn-${t} py-3 text-xs font-medium`;btn.textContent=BOOK_NAMES[k]||k;btn.setAttribute("data-book",k);btn.addEventListener("click",()=>selBook(k));bGrid.appendChild(btn);}
    showStep("books");
    setTimeout(()=>stepB.scrollIntoView({behavior:"smooth",block:"start"}),50);
  }));

  function selBook(k:string){
    curBook=k;curChapter=0;
    $("book-title").textContent=(BOOK_NAMES[k]||k).toUpperCase();
    bGrid.querySelectorAll(".sel-btn").forEach(b=>b.classList.remove("active"));bGrid.querySelector(`[data-book="${k}"]`)?.classList.add("active");
    const bk=data[k];if(!bk)return;
    const chs=Object.keys(bk).map(Number).sort((a,b)=>a-b);
    cGrid.innerHTML="";
    for(const c of chs){const btn=document.createElement("button");btn.className="sel-btn py-2";btn.textContent=String(c);btn.addEventListener("click",()=>selectChapter(k,c));cGrid.appendChild(btn);}
    showStep("chapters");stepB.classList.remove("hidden");
    rArea.classList.add("hidden");btmNav.classList.add("hidden");
    setTimeout(()=>stepC.scrollIntoView({behavior:"smooth",block:"start"}),50);
  }

  // Step 3: Chapter -> show verse grid (NOT text)
  function selectChapter(book:string, ch:number){
    curBook=book; curChapter=ch;
    const bk=data[book]; if(!bk) return;
    const chData=bk[String(ch)]; if(!chData) return;

    // Highlight the clicked chapter
    cGrid.querySelectorAll(".sel-btn").forEach(b=>b.classList.remove("active"));
    for(const btn of Array.from(cGrid.children)){
      if(btn.textContent===String(ch)) btn.classList.add("active");
    }

    // Show verse grid
    const verses = Array.isArray(chData) ? chData : (chData.verses || []);
    verseTitle.textContent = `${BOOK_NAMES[book] || book} ${ch}`;
    vGrid.innerHTML = "";
    for (let i = 0; i < verses.length; i++) {
      const v = verses[i];
      const vNum = typeof v === 'object' ? v.verse : (i + 1);
      const btn = document.createElement("button");
      btn.className = "sel-btn py-2";
      btn.textContent = String(vNum);
      btn.addEventListener("click", () => loadAndScrollTo(book, ch, vNum));
      vGrid.appendChild(btn);
    }
    // Show verses, keep chapters + books visible, hide reading area
    stepV.classList.remove("hidden");
    stepC.classList.remove("hidden");
    stepB.classList.remove("hidden");
    rArea.classList.add("hidden");
    btmNav.classList.add("hidden");

    // Scroll to verse grid
    setTimeout(()=>stepV.scrollIntoView({behavior:"smooth",block:"start"}),50);

    // Update hash
    window.location.hash = `${book}${ch}`;
  }

  function loadChapter(book:string,ch:number){
    curBook=book;curChapter=ch;
    const bk=data[book];const verses=bk?.[String(ch)];if(!verses)return;
    const nm=BOOK_NAMES[book]||book;
    rTitle.textContent=`${nm} ${ch}`;rSub.textContent=`${Object.keys(bk).length} chapters · ${verses.length} verses`;
    const hlKey=`dkc-vhl-${book}-${ch}`;hlSet.clear();for(const v of JSON.parse(localStorage.getItem(hlKey)||"[]"))hlSet.add(v);
    let html="";
    for(const v of verses){
      const isHl=hlSet.has(Number(v.verse));
      html+=`<div class="verse-row${isHl?" highlighted":""}" data-verse="${v.verse}"><sup>${v.verse}</sup><div class="latin-text">${v.latin}</div><div class="english-text">${v.english}</div></div>`;
    }
    rContent.innerHTML=html;rArea.classList.remove("hidden");btmNav.classList.remove("hidden");
    // Keep chapter + verse grids visible as context above the text
    stepC.classList.remove("hidden");
    stepV.classList.remove("hidden");
    stepB.classList.remove("hidden");
    window.location.hash=`${book}${ch}`;updateBm();
    rTitle.scrollIntoView({behavior:"smooth",block:"start"});
  }

  // Load and scroll to specific verse
  function loadAndScrollTo(book:string, chapter:number, verse:number){
    loadChapter(book, chapter);
    setTimeout(() => {
      const el = rContent.querySelector(`[data-verse="${verse}"]`) as HTMLElement;
      if (el) {
        el.classList.add("flash");
        el.scrollIntoView({ behavior: "smooth", block: "center" });
        setTimeout(() => el.classList.remove("flash"), 2000);
      }
    }, 100);
  }

  $("back-testament").addEventListener("click",()=>{rArea.classList.add("hidden");btmNav.classList.add("hidden");showStep("testament");});
  $("back-books").addEventListener("click",()=>{rArea.classList.add("hidden");btmNav.classList.add("hidden");showStep("books");stepB.classList.remove("hidden");});
  $("back-chapters").addEventListener("click",()=>{rArea.classList.add("hidden");btmNav.classList.add("hidden");showStep("chapters");stepB.classList.remove("hidden");stepC.classList.remove("hidden");});

  function getAdj(d:number){
    const bk=data[curBook];if(!bk)return null;const chs=Object.keys(bk).map(Number).sort((a,b)=>a-b);const i=chs.indexOf(curChapter)+d;
    if(i>=0&&i<chs.length)return{book:curBook,chapter:chs[i]};
    const all=curTest==="ot"?OT:NT;const bi=all.indexOf(curBook)+d;
    if(bi>=0&&bi<all.length&&data[all[bi]]){const nb=all[bi];const nc=Object.keys(data[nb]).map(Number).sort((a,b)=>a-b);return{book:nb,chapter:d>0?nc[0]:nc[nc.length-1]};}
    return null;
  }
  function goAdj(d:number){const a=getAdj(d);if(a)loadChapter(a.book,a.chapter);}
  $("prev-ch").addEventListener("click",()=>goAdj(-1));$("next-ch").addEventListener("click",()=>goAdj(1));
  $("prev-ch-bottom").addEventListener("click",()=>goAdj(-1));$("next-ch-bottom").addEventListener("click",()=>goAdj(1));
  document.addEventListener("keydown",e=>{if(e.key==="ArrowLeft")goAdj(-1);if(e.key==="ArrowRight")goAdj(1);});

  // TTS
  const ttsBtn=$("tts-btn"),ttsStop=$("tts-stop-btn"),ttsTmrEl=$("tts-timer");
  ttsBtn.addEventListener("click",()=>{
    if(!("speechSynthesis" in window))return;speechSynthesis.cancel();
    const txt=Array.from(rContent.querySelectorAll(".latin-text")).map(e=>e.textContent).join(" ");if(!txt)return;
    const u=new SpeechSynthesisUtterance(txt);u.lang="la-Latn";u.rate=0.8;
    ttsBtn.classList.add("hidden");ttsStop.classList.remove("hidden");ttsTmrEl.classList.remove("hidden");ttsSec=0;
    ttsTmr=setInterval(()=>{ttsSec++;ttsTmrEl.textContent=`${String(Math.floor(ttsSec/60)).padStart(2,"0")}:${String(ttsSec%60).padStart(2,"0")}`;},1000);
    u.onend=()=>{ttsBtn.classList.remove("hidden");ttsStop.classList.add("hidden");ttsTmrEl.classList.add("hidden");clearInterval(ttsTmr);};
    speechSynthesis.speak(u);
  });
  ttsStop.addEventListener("click",()=>{speechSynthesis.cancel();ttsBtn.classList.remove("hidden");ttsStop.classList.add("hidden");ttsTmrEl.classList.add("hidden");clearInterval(ttsTmr);});

  // Highlight
  rContent.addEventListener("click",e=>{const row=(e.target as HTMLElement).closest(".verse-row") as HTMLElement;if(!row)return;const v=Number(row.getAttribute("data-verse"));if(!v)return;const k=`dkc-vhl-${curBook}-${curChapter}`;if(hlSet.has(v)){hlSet.delete(v);row.classList.remove("highlighted");}else{hlSet.add(v);row.classList.add("highlighted");}localStorage.setItem(k,JSON.stringify([...hlSet]));});

  // Bookmark
  const BMK="dkc-vulgata-bookmarks",bmBtn=$("bookmark-btn");
  function getBm(){return JSON.parse(localStorage.getItem(BMK)||"[]");}
  function updateBm(){const r=`${curBook} ${curChapter}`;const b=getBm();bmBtn.style.borderColor=b.includes(r)?"rgba(201,168,76,0.6)":"";bmBtn.style.color=b.includes(r)?"var(--color-dkc-gold)":"";}
  bmBtn.addEventListener("click",()=>{const r=`${curBook} ${curChapter}`;const b=getBm();if(b.includes(r))localStorage.setItem(BMK,JSON.stringify(b.filter((x:string)=>x!==r)));else{b.push(r);localStorage.setItem(BMK,JSON.stringify(b));}updateBm();});

  // Font size
  const FM:Record<string,string>={sm:"13px",md:"15px",lg:"18px"};
  document.querySelectorAll(".font-size-btn").forEach(b=>b.addEventListener("click",()=>{const s=b.getAttribute("data-fsize")||"md";rContent.style.fontSize=FM[s];document.querySelectorAll(".font-size-btn").forEach(x=>x.classList.remove("font-size-active"));b.classList.add("font-size-active");localStorage.setItem("dkc-vf-size",s);}));
  const sf=localStorage.getItem("dkc-vf-size");if(sf&&FM[sf]){rContent.style.fontSize=FM[sf];document.querySelector(`.font-size-btn[data-fsize="${sf}"]`)?.classList.add("font-size-active");}else document.querySelector('.font-size-btn[data-fsize="md"]')?.classList.add("font-size-active");

  // Share
  $("share-copy").addEventListener("click",()=>{navigator.clipboard.writeText(`${location.origin}/vulgata#${curBook}${curChapter}`);$("share-copy").style.borderColor="rgba(201,168,76,0.6)";setTimeout(()=>$("share-copy").style.borderColor="",1500);});


  // Init
  async function init(){
    rLoad.classList.remove("hidden");
    const r=await fetch("/assets/data/vulgate_bible.json");data=await r.json();rLoad.classList.add("hidden");
    const h=location.hash.slice(1);if(h){
      const m=h.match(/^([a-z0-9_]+?)(\d+)$/);
      if(m&&data[m[1]]?.[m[2]]){
        curTest=OT.includes(m[1])?"ot":"nt";
        selectChapter(m[1],parseInt(m[2]));
      }
    }
  }
  init();
</script>
